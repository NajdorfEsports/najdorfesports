{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/roster/index.html",
        "http://localhost/matches/index.html",
        "http://localhost/news/index.html",
        "http://localhost/coaching/index.html",
        "http://localhost/zh-TW/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "budgets": [
          {
            "path": "/*",
            "resourceSizes": [
              { "resourceType": "script", "budget": 60 },
              { "resourceType": "font", "budget": 360 },
              { "resourceType": "image", "budget": 400 }
            ],
            "resourceCounts": [{ "resourceType": "third-party", "budget": 0 }]
          }
        ]
      }
    },
    "assertMatrix": [
      {
        "matchingUrlPattern": "^(?!.*zh-).*$",
        "assertions": {
          "categories:performance": ["error", { "minScore": 0.97 }],
          "categories:best-practices": ["error", { "minScore": 1 }],
          "categories:seo": ["error", { "minScore": 0.97 }],
          "categories:accessibility": ["error", { "minScore": 0.97 }]
        }
      },
      {
        "matchingUrlPattern": ".*zh-.*",
        "assertions": {
          "categories:performance": ["error", { "minScore": 0.9 }],
          "categories:best-practices": ["error", { "minScore": 1 }],
          "categories:seo": ["error", { "minScore": 0.97 }],
          "categories:accessibility": ["error", { "minScore": 0.97 }]
        }
      }
    ],
    "upload": { "target": "temporary-public-storage" }
  }
}
