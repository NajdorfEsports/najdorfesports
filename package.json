{
  "name": "najdorfesports",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:full": "npm run build && playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks || true",
    "fetch:matches": "node scripts/fetch-liquipedia.mjs",
    "fetch:heroes": "node scripts/fetch-hero-icons.mjs",
    "fetch:maps": "node scripts/fetch-map-icons.mjs",
    "fetch:player": "node scripts/fetch-player.mjs",
    "fetch:social": "node scripts/fetch-social-stats.mjs",
    "build:og": "node scripts/generate-og.mjs",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/sitemap": "^3.4.0",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^5.18.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.94.0",
    "zod": "^4.4.3"
  }
