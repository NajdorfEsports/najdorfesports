---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePageBody from '../components/page/HomePageBody.astro';
import { site } from '../data/site';
// SportsOrganization is emitted by BaseLayout. `enrichedOrg` upgrades it to
// the form that embeds the athlete roster + coach (Task E).
---
<BaseLayout
  title="Najdorf Esports | OWCS Pacific Overwatch Team"
  description={site.description}
  ogImage="/branding/og/home.png"
  exactTitle
  enrichedOrg
>
  <HomePageBody />
</BaseLayout>
