---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePageBody from '../components/page/HomePageBody.astro';
import { useT, getLocale } from '../i18n';

const t = useT(getLocale(Astro));
// SportsOrganization is emitted by BaseLayout; `enrichedOrg` embeds the roster.
---
<BaseLayout
  title={t.pageMeta.homeTitle}
  description={t.pageMeta.homeDescription}
  ogImage="/branding/og/home.png"
  exactTitle
  enrichedOrg
>
  <HomePageBody />
</BaseLayout>
