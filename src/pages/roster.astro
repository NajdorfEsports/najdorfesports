---
import BaseLayout from '../layouts/BaseLayout.astro';
import RosterPageBody from '../components/page/RosterPageBody.astro';
import { useT, getLocale } from '../i18n';
import { site } from '../data/site';
import { buildRosterJsonLd, rosterMetaCounts } from '../data/roster-jsonld';

const locale = getLocale(Astro);
const t = useT(locale);

const personJsonLd = buildRosterJsonLd();
const { headcount, countries } = rosterMetaCounts();
---
<BaseLayout
  title={t.nav.roster}
  description={`The ${site.name} active OWCS Pacific roster. ${headcount} players across ${countries.join(', ')}.`}
  ogImage="/branding/og/roster.png"
  jsonLd={personJsonLd}
>
  <RosterPageBody />
</BaseLayout>
