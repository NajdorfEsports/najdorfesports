---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Shop"
  description="Najdorf Esports official store. Opening soon."
  ogImage="/branding/og/shop.png"
>
  <section class="mx-auto max-w-2xl px-4 sm:px-6 pt-24 pb-24 text-center">
    <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">Shop</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-3 tracking-wide">Store opening soon.</h1>
    <p class="text-[var(--color-text-dim)] mt-4">
      Jerseys, mousepads, and limited drops launching with OWCS Pacific Stage 2.
    </p>
  </section>
</BaseLayout>
