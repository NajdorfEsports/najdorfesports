---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import SocialRow from '../../components/layout/SocialRow.astro';
import { owcs } from '../../data/site';
---
<BaseLayout
  title="Shop"
  description="Najdorf Esports first run drops alongside OWCS Pacific Stage 2 — get notified on Discord or X."
  ogImage="/branding/og/shop.png"
>
  <section class="shop-hero relative overflow-hidden mx-auto max-w-3xl px-4 sm:px-6 pt-20 pb-24 text-center">
    {/* Faint bishop watermark — same motif as the news covers so the page
        reads as part of the brand, not a stub. */}
    <span class="shop-hero__bishop" aria-hidden="true">
      <svg viewBox="0 0 64 96" fill="none" stroke="currentColor" stroke-width="1.4">
        <path fill-rule="evenodd" d="M32 6 C 40 18, 44 30, 44 38 C 44 46, 38 50, 32 50 C 26 50, 20 46, 20 38 C 20 30, 24 18, 32 6 Z"/>
        <path d="M28 12 L 38 22 L 36 24 L 26 14 Z"/>
        <rect x="26" y="46" width="12" height="12"/>
        <rect x="20" y="56" width="24" height="6" rx="1"/>
        <path d="M22 60 L 42 60 L 46 78 L 18 78 Z"/>
        <path d="M14 78 L 50 78 L 52 88 L 12 88 Z"/>
        <ellipse cx="32" cy="90" rx="22" ry="3.5"/>
      </svg>
    </span>

    <p class="text-sm uppercase tracking-[0.25em] text-[var(--color-accent)] relative z-10">Shop</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-3 tracking-wide relative z-10">
      Drops with the LAN.
    </h1>
    <p class="text-[var(--color-text-dim)] mt-4 max-w-xl mx-auto leading-relaxed relative z-10">
      The first run launches alongside <strong class="text-[var(--color-text)]">OWCS Pacific {owcs.stage}</strong>
      &mdash; jerseys cut for the matchup, mousepads at competition spec, and a
      first-edition piece you can wear to the watch parties. Main event opens
      <strong class="text-[var(--color-text)]">June 4</strong>.
    </p>
    <p class="text-[var(--color-text-dim)] mt-4 max-w-xl mx-auto relative z-10">
      Best place to hear when it goes live:
    </p>

    <div class="mt-6 flex flex-wrap justify-center gap-3 relative z-10">
      <Button href="https://discord.gg/7X2QbvUW3z" external variant="primary">Join Discord</Button>
      <Button href="https://x.com/najdorfesports" external variant="secondary">Follow on X</Button>
    </div>

    <div class="mt-10 relative z-10">
      <SocialRow size="sm" />
    </div>
  </section>
</BaseLayout>

<style>
  /* Faint bishop watermark behind the hero copy. Mirrors the news-cover
   * treatment so the page reads as branded, not as an empty stub. */
  .shop-hero__bishop {
    position: absolute;
    right: -8%;
    top: 8%;
    width: auto;
    color: var(--color-accent);
    opacity: 0.07;
    pointer-events: none;
  }
  .shop-hero__bishop svg {
    display: block;
    width: auto;
    height: 22rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .shop-hero__bishop {
      animation: shop-bishop-drift 14s ease-in-out infinite alternate;
    }
    @keyframes shop-bishop-drift {
      from { transform: translate(0, 0) rotate(0deg); }
      to   { transform: translate(-10px, 8px) rotate(-2deg); }
    }
  }
</style>
