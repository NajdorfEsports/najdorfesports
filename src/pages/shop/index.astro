---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import SocialRow from '../../components/layout/SocialRow.astro';
import BishopMark from '../../components/ui/BishopMark.astro';
import { owcs } from '../../data/site';
import { getLocale } from '../../i18n';
import { formatDate } from '../../i18n/format';

const locale = getLocale(Astro);
const mainEventStartLabel = formatDate(owcs.mainEventStart, locale, {
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Shop"
  description="Najdorf Esports first run drops alongside OWCS Pacific Stage 2. Get notified on Discord or X."
  ogImage="/branding/og/shop.png"
  localized={false}
>
  <section
    class="shop-hero relative overflow-hidden mx-auto max-w-3xl px-4 sm:px-6 pt-20 pb-24 text-center"
  >
    {
      /* Faint bishop watermark, same motif as the news covers so the page
        reads as part of the brand, not a stub. */
    }
    <span class="shop-hero__bishop" aria-hidden="true">
      <BishopMark strokeWidth={1.4} />
    </span>

    <p class="text-sm uppercase tracking-[0.25em] text-[var(--color-accent)] relative z-10">Shop</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-3 tracking-wide relative z-10">
      Drops with the LAN.
    </h1>
    <p class="text-[var(--color-text-dim)] mt-4 max-w-xl mx-auto leading-relaxed relative z-10">
      The first run launches alongside <strong class="text-[var(--color-text)]"
        >OWCS Pacific {owcs.stage}</strong
      >: jerseys cut for the matchup, mousepads at competition spec, and a first-edition piece you
      can wear to the watch parties. Main event opens
      <strong class="text-[var(--color-text)]">{mainEventStartLabel}</strong>.
    </p>
    <p class="text-[var(--color-text-dim)] mt-4 max-w-xl mx-auto relative z-10">
      Best place to hear when it goes live:
    </p>

    <div class="mt-6 flex flex-wrap justify-center gap-3 relative z-10">
      <Button href="https://discord.gg/7X2QbvUW3z" external variant="primary">Join Discord</Button>
      <Button href="https://x.com/najdorfesports" external variant="secondary">Follow on X</Button>
    </div>

    <div class="mt-10 relative z-10">
      <SocialRow size="sm" />
    </div>
  </section>
</BaseLayout>

<style>
  /* Faint bishop watermark behind the hero copy. Mirrors the news-cover
   * treatment so the page reads as branded, not as an empty stub. */
  .shop-hero__bishop {
    position: absolute;
    right: -8%;
    top: 8%;
    width: auto;
    color: var(--color-accent);
    opacity: 0.07;
    pointer-events: none;
  }
  .shop-hero__bishop :global(svg) {
    display: block;
    width: auto;
    height: 22rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .shop-hero__bishop {
      animation: shop-bishop-drift 14s ease-in-out infinite alternate;
    }
    @keyframes shop-bishop-drift {
      from {
        transform: translate(0, 0) rotate(0deg);
      }
      to {
        transform: translate(-10px, 8px) rotate(-2deg);
      }
    }
  }
</style>
