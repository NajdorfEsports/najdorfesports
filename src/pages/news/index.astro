---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../i18n/format';
import { DEFAULT_LOCALE } from '../../i18n';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);
---
<BaseLayout
  title="News"
  description="Announcements, brand updates, and match reports from Najdorf Esports."
>
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pt-12">
    <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">News</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-2 tracking-wide">From the team</h1>
  </section>

  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-10 space-y-4">
    {posts.map((post) => (
      <a
        href={`/news/${post.id}`}
        class="block bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-6 hover:border-[var(--color-accent-2)] transition-colors"
      >
        <p class="text-xs uppercase tracking-wider text-[var(--color-text-dim)]">
          {formatDate(post.data.date, DEFAULT_LOCALE, { month: 'long', day: 'numeric', year: 'numeric' })}
        </p>
        <h2 class="font-display text-2xl sm:text-3xl mt-2 tracking-wide">{post.data.title}</h2>
        {post.data.description && (
          <p class="text-sm text-[var(--color-text-dim)] mt-2">{post.data.description}</p>
        )}
      </a>
    ))}
  </section>
</BaseLayout>
