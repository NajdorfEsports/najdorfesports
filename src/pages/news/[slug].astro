---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCover from '../../components/news/NewsCover.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleUrl = `${site.url}/news/${post.id}/`;
const ogImage = `${site.url}/branding/og/news-${post.id}.png`;
const orgId = `${site.url}/#org`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.data.title,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Organization', name: post.data.author, '@id': orgId },
  publisher: { '@id': orgId },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  image: ogImage,
  ...(post.data.description ? { description: post.data.description } : {}),
};
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={`/branding/og/news-${post.id}.png`}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 pt-12 pb-16">
    <NewsCover
      title={post.data.title}
      date={post.data.date}
      eyebrow={post.data.eyebrow}
      tone={post.data.tone}
      variant="hero"
    />

    <div class="prose mt-8">
      <Content />
    </div>

    <hr class="border-[var(--color-border)] mt-12" />
    <p class="mt-4 text-sm text-[var(--color-text-dim)]">
      <a href="/news/" class="text-[var(--color-accent-2)] hover:underline">← All news</a>
    </p>
  </article>
</BaseLayout>

<style is:global>
  .prose {
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .prose p { margin-bottom: 1.25em; }
  .prose strong { color: var(--color-text); font-weight: 700; }
  .prose em { color: var(--color-text-dim); }
  .prose a { color: var(--color-accent-2); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--color-accent); }
  .prose h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-top: 2em;
    margin-bottom: 0.5em;
    letter-spacing: 0.01em;
  }
  .prose h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin-top: 1.75em;
    margin-bottom: 0.4em;
  }
  .prose ul, .prose ol { padding-left: 1.4em; margin-bottom: 1.25em; }
  .prose li { margin-bottom: 0.4em; }
  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1em;
    color: var(--color-text-dim);
    margin: 1.5em 0;
  }
  .prose hr { border-color: var(--color-border); margin: 2.5em 0; }
  .prose code {
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }
</style>
