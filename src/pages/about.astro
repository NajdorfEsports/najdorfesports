---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutPageBody from '../components/page/AboutPageBody.astro';
import { useT, getLocale } from '../i18n';
import { site } from '../data/site';

const locale = getLocale(Astro);
const t = useT(locale);
---
<BaseLayout
  title={t.nav.about}
  description={`About ${site.name}, an Overwatch organization based in the Pacific region.`}
  ogImage="/branding/og/about.png"
>
  <AboutPageBody />
</BaseLayout>
