---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialRow from '../components/layout/SocialRow.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="About"
  description={`About ${site.name} — a competitive Overwatch organization headquartered in the Pacific region.`}
>
  <section class="mx-auto max-w-3xl px-4 sm:px-6 pt-12 pb-16">
    <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">About</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-2 tracking-wide">{site.name}</h1>

    <p class="text-lg text-[var(--color-text)] mt-6 leading-relaxed">
      Najdorf Esports is a competitive Overwatch organization headquartered in the
      Pacific region, founded in {site.yearFounded}. We are currently competing in
      OWCS Pacific Stage 2, with the main event running June 4 through July 9, 2026.
      Our identity is borrowed from the Najdorf Variation of the Sicilian Defence —
      patient, prepared, and aggressive at the right moment.
    </p>

    <hr class="border-[var(--color-border)] my-8" />

    <p class="text-[var(--color-text-dim)] italic">
      Previously competing as Rankers in OWCS Pacific.
    </p>

    <section class="mt-12">
      <h2 class="font-display text-2xl tracking-wide">Contact</h2>
      <p class="mt-3">
        <a
          href={`mailto:${site.contactEmail}`}
          class="text-[var(--color-accent-2)] hover:text-[var(--color-accent)] underline underline-offset-4"
        >
          {site.contactEmail}
        </a>
      </p>
      <p class="text-sm text-[var(--color-text-dim)] mt-2">
        Partnership inquiries, press requests, player questions — all to the address above.
      </p>

      <div class="mt-6">
        <SocialRow />
      </div>
    </section>
  </section>
</BaseLayout>
