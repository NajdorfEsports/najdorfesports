---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutPageBody from '../components/page/AboutPageBody.astro';
import { useT, getLocale } from '../i18n';

const locale = getLocale(Astro);
const t = useT(locale);
---

<BaseLayout
  title={t.pageMeta.aboutTitle}
  description={t.pageMeta.aboutDescription}
  ogImage="/branding/og/about.png"
  exactTitle
>
  <AboutPageBody />
</BaseLayout>
