---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPageBody from '../../components/page/AboutPageBody.astro';
import { useT, DEFAULT_LOCALE, type Locale } from '../../i18n';
import { site } from '../../data/site';

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);
---
<BaseLayout
  title={t.nav.about}
  description={`關於 ${site.name} — 一支位於太平洋區、征戰 OWCS Pacific 的 Overwatch 戰隊。`}
>
  <AboutPageBody />
</BaseLayout>
