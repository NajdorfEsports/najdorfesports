---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPageBody from '../../components/page/AboutPageBody.astro';
import { useT, getLocale } from '../../i18n';
import { site } from '../../data/site';

const locale = getLocale(Astro);
const t = useT(locale);
---
<BaseLayout
  title={t.nav.about}
  description={`關於 ${site.name}，一支位於太平洋區、征戰 OWCS Pacific 的 Overwatch 戰隊。`}
  ogImage="/branding/og/about.png"
>
  <AboutPageBody />
</BaseLayout>
