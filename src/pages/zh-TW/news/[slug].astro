---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsArticle from '../../../components/news/NewsArticle.astro';
import { getCollection } from 'astro:content';
import { site } from '../../../data/site';
import { pathFor, type Locale } from '../../../i18n';

const LOCALE: Locale = 'zh-TW';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft && data.locale === 'zh-TW');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const articlePath = pathFor(LOCALE, `/news/${post.data.slug}/`);
const articleUrl = `${site.url}${articlePath}`;
const ogImagePath = `/branding/og/news-${post.data.slug}.png`;
const orgId = `${site.url}/#org`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.data.title,
  inLanguage: LOCALE,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Organization', name: post.data.author, '@id': orgId },
  publisher: { '@id': orgId },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  image: `${site.url}${ogImagePath}`,
  ...(post.data.description ? { description: post.data.description } : {}),
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImagePath}
  jsonLd={jsonLd}
>
  <NewsArticle post={post} locale={LOCALE} />
</BaseLayout>
