---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsList from '../../../components/news/NewsList.astro';
import { getCollection } from 'astro:content';
import { useT, type Locale } from '../../../i18n';

const LOCALE: Locale = 'zh-TW';
const t = useT(LOCALE);

const posts = (
  await getCollection('news', ({ data }) => !data.draft && data.locale === LOCALE)
).sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout
  title={t.news.eyebrow}
  description={t.news.metaDescription}
  ogImage="/branding/og/news.png"
>
  <NewsList posts={posts} locale={LOCALE} />
</BaseLayout>
