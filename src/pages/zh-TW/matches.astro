---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MatchesPageBody from '../../components/page/MatchesPageBody.astro';
import { useT, getLocale } from '../../i18n';
import { owcs } from '../../data/site';
import { buildMatchesJsonLd } from '../../data/matches-jsonld';

const locale = getLocale(Astro);
const t = useT(locale);

const jsonLd = buildMatchesJsonLd();
---

<BaseLayout
  title={t.nav.matches}
  description={t.matches.metaDescription(owcs.league)}
  ogImage="/branding/og/matches.png"
  jsonLd={jsonLd.length > 0 ? jsonLd : undefined}
>
  <MatchesPageBody />
</BaseLayout>
