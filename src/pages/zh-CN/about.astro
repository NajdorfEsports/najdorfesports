---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPageBody from '../../components/page/AboutPageBody.astro';
import { useT, getLocale } from '../../i18n';
import { site } from '../../data/site';

const locale = getLocale(Astro);
const t = useT(locale);
---
<BaseLayout
  title={t.nav.about}
  description={`关于 ${site.name}，一支位于太平洋赛区、征战 OWCS Pacific 的 Overwatch 战队。`}
  ogImage="/branding/og/about.png"
>
  <AboutPageBody />
</BaseLayout>
