---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPageBody from '../../components/page/AboutPageBody.astro';
import { useT, getLocale } from '../../i18n';
import { site } from '../../data/site';

const locale = getLocale(Astro);
const t = useT(locale);
---
<BaseLayout
  title={t.nav.about}
  description={`${site.name} 在 OWCS Pacific 第二阶段前收购了 Rankers 的阵容。认识现役《守望先锋》选手与教练、了解我们的故事，并看看如何与我们合作。`}
  ogImage="/branding/og/about.png"
>
  <AboutPageBody />
</BaseLayout>
