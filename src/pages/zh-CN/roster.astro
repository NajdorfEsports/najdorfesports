---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RosterPageBody from '../../components/page/RosterPageBody.astro';
import { useT, getLocale } from '../../i18n';
import { site } from '../../data/site';
import { rosterMetaCounts } from '../../data/roster-jsonld';

const locale = getLocale(Astro);
const t = useT(locale);

const { headcount, countries } = rosterMetaCounts();
---
<BaseLayout
  title={t.nav.roster}
  description={`${site.name} 现役 OWCS Pacific 名单，共 ${headcount} 名选手，来自 ${countries.join('、')}。`}
  ogImage="/branding/og/roster.png"
  enrichedOrg
>
  <RosterPageBody />
</BaseLayout>
