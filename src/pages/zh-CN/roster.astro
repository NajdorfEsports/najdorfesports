---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RosterPageBody from '../../components/page/RosterPageBody.astro';
import { useT, DEFAULT_LOCALE, type Locale } from '../../i18n';
import { site } from '../../data/site';
import { buildRosterJsonLd, rosterMetaCounts } from '../../data/roster-jsonld';

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);

const personJsonLd = buildRosterJsonLd();
const { headcount, countries } = rosterMetaCounts();
---
<BaseLayout
  title={t.nav.roster}
  description={`${site.name} 现役 OWCS Pacific 名单，共 ${headcount} 名选手，来自 ${countries.join('、')}。`}
  ogImage="/branding/og/roster.png"
  jsonLd={personJsonLd}
>
  <RosterPageBody />
</BaseLayout>
