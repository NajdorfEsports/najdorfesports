---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePageBody from '../../components/page/HomePageBody.astro';
import { site } from '../../data/site';
// SportsOrganization is emitted by BaseLayout; `enrichedOrg` embeds the roster.
---
<BaseLayout
  title={site.name}
  description={`${site.name} 是一支位于太平洋赛区的 Overwatch 战队，目前征战 OWCS Pacific。`}
  ogImage="/branding/og/home.png"
  enrichedOrg
>
  <HomePageBody />
</BaseLayout>
