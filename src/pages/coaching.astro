import CoachingPageBody from '../components/page/CoachingPageBody.astro';
import { useT, getLocale } from '../i18n';

const locale = getLocale(Astro);
const t = useT(locale);
---

<BaseLayout title={t.pageMeta.coachingTitle} description={t.pageMeta.coachingDescription}>
  <CoachingPageBody />
</BaseLayout>
