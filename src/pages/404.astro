---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="404"
  description="The page you were looking for does not exist."
  localized={false}
>
  <section class="relative isolate overflow-hidden">
    <div class="texture-board" aria-hidden="true"></div>
    <div class="mx-auto max-w-2xl px-4 sm:px-6 pt-24 pb-24 text-center">
      <p
        class="font-display text-[8rem] sm:text-[10rem] leading-none text-[var(--color-accent)] tracking-tight"
      >
        404
      </p>
      <h1 class="font-display text-3xl sm:text-4xl mt-4 tracking-wide">
        This page made an illegal move.
      </h1>
      <p class="text-[var(--color-text-dim)] mt-4">Return to start and try a different opening.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/" variant="primary">Back to home</Button>
        <Button href="/matches/" variant="secondary">Matches</Button>
      </div>
    </div>
  </section>
</BaseLayout>
