---
/**
 * Roster page body. Rendered at `/roster/`, `/zh-TW/roster/`, `/zh-CN/roster/`.
 * Per-URL locale comes from Astro.currentLocale; the Person JSON-LD block is
 * locale-independent and gets passed back to the page for inclusion in <head>.
 *
 * Every role (players, coach, managers) gets the poster-style PlayerCard
 * grid in its own ROLE_ORDER section, signature-hero backdrop included;
 * the owner wants staff presented exactly like the players.
 */
import PlayerCard from '../player/PlayerCard.astro';
import AchievementStrip from '../team/AchievementStrip.astro';
import MatchTicker from '../match/MatchTicker.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import { site, ROLE_ORDER, type RosterEntry, type Role } from '../../data/site';
import { loadRoster, loadMatches, loadAchievements } from '../../data/loaders';
import { getLocale, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);

const roster = loadRoster();
const matches = loadMatches();
const achievements = loadAchievements();

const PLAYER_ROLES: Role[] = ['Tank', 'DPS', 'Support', 'Flex'];

// Group by role for display (coach and managers included, each role its own
// section), sorted by the shared ROLE_ORDER so the order stays consistent
// with any future consumer (ticker, strip, etc.).
const grouped: Partial<Record<Role, RosterEntry[]>> = {};
for (const p of roster) {
  (grouped[p.role] ??= []).push(p);
}
const sections = (Object.keys(ROLE_ORDER) as Role[])
  .sort((a, b) => ROLE_ORDER[a] - ROLE_ORDER[b])
  .filter((r) => grouped[r] && grouped[r]!.length > 0)
  .map((r) => ({ role: r, players: grouped[r]!.sort((a, b) => a.handle.localeCompare(b.handle)) }));

// "Players" counts athletes only: a coach or manager is not a player. Excludes
// inactive entries too, so the stat matches the home hero count.
const headcount = roster.filter(
  (p) => p.status !== 'inactive' && PLAYER_ROLES.includes(p.role),
).length;

// Hoist the cast out of the JSX. `<string, string>` in inline TS would
// confuse Astro's parser into seeing an HTML tag.
const regionLabel: string = (t.regions as Record<string, string>)[site.region] ?? site.region;
---

<MatchTicker matches={matches} />

<section class="relative isolate overflow-hidden border-b border-(--color-border)">
  <div class="texture-board" aria-hidden="true"></div>
  <div class="mx-auto max-w-(--max-content) px-4 sm:px-6 pt-12 pb-10">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <p class="eyebrow">{t.roster.eyebrow}</p>
        <h1 class="font-display text-(length:--text-h1) mt-2 tracking-tight leading-none">
          {t.roster.h1}
        </h1>
      </div>
      <dl class="flex items-center gap-8 text-sm">
        <div>
          <dt class="text-(--color-text-dim) uppercase tracking-wider text-[0.65rem]">
            {t.roster.playersLabel}
          </dt>
          <dd
            class="font-display text-3xl mt-1 leading-none tabular-nums text-(--color-accent-2)"
            data-count-up
            data-target={headcount}
          >
            {headcount}
          </dd>
        </div>
        <div>
          <dt class="text-(--color-text-dim) uppercase tracking-wider text-[0.65rem]">
            {t.roster.regionLabel}
          </dt>
          <dd class="font-display text-3xl mt-1 leading-none text-(--color-accent-2)">
            {regionLabel}
          </dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<AchievementStrip achievements={achievements} />

<section class="mx-auto max-w-(--max-content) px-4 sm:px-6 mt-12 space-y-12">
  {
    sections.map((section, si) => (
      <div>
        <SectionHeader heading={t.roles[section.role] ?? section.role}>
          <span class="text-xs uppercase tracking-wider text-(--color-accent-2) tabular-nums">
            {section.players.length}
          </span>
        </SectionHeader>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-6">
          {/* Only the page's first card sits above the fold; its art loads
              eagerly so it can be the LCP instead of a lazy-load wait. */}
          {section.players.map((p, i) => (
            <PlayerCard player={p} index={i} eager={si === 0 && i === 0} />
          ))}
        </div>
      </div>
    ))
  }
</section>
