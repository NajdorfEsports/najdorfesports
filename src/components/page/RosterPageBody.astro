---
/**
 * Roster page body. Rendered at `/roster/`, `/zh-TW/roster/`, `/zh-CN/roster/`.
 * Per-URL locale comes from Astro.currentLocale; the Person JSON-LD block is
 * locale-independent and gets passed back to the page for inclusion in <head>.
 */
import PlayerCard from '../player/PlayerCard.astro';
import AchievementStrip from '../team/AchievementStrip.astro';
import MatchTicker from '../match/MatchTicker.astro';
import { site, ROLE_ORDER, type RosterEntry, type Role } from '../../data/site';
import { loadRoster, loadMatches, loadAchievements } from '../../data/loaders';
import { DEFAULT_LOCALE, useT, type Locale } from '../../i18n';

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);

const roster = loadRoster();
const matches = loadMatches();
const achievements = loadAchievements();

// Group by role for display, sorted by the shared ROLE_ORDER so the order
// stays consistent with any future consumer (ticker, strip, etc.).
const grouped: Partial<Record<Role, RosterEntry[]>> = {};
for (const p of roster) {
  (grouped[p.role] ??= []).push(p);
}
const sections = (Object.keys(ROLE_ORDER) as Role[])
  .sort((a, b) => ROLE_ORDER[a] - ROLE_ORDER[b])
  .filter((r) => grouped[r] && grouped[r]!.length > 0)
  .map((r) => ({ role: r, players: grouped[r]!.sort((a, b) => a.handle.localeCompare(b.handle)) }));

const headcount = roster.filter((p) => p.status !== 'inactive').length;

// Hoist the cast out of the JSX. `<string, string>` in inline TS would
// confuse Astro's parser into seeing an HTML tag.
const regionLabel: string = (t.regions as Record<string, string>)[site.region] ?? site.region;
---
<MatchTicker matches={matches} />

<section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pt-12">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-2)]">
        {t.roster.eyebrow}
      </p>
      <h1 class="font-display text-5xl sm:text-6xl mt-2 tracking-tight leading-none">
        {t.roster.h1}
      </h1>
    </div>
    <dl class="flex items-center gap-8 text-sm">
      <div>
        <dt class="text-[var(--color-text-dim)] uppercase tracking-wider text-[0.65rem]">
          {t.roster.playersLabel}
        </dt>
        <dd
          class="font-display text-3xl mt-1 leading-none tabular-nums text-[var(--color-accent-2)]"
          data-count-up
          data-target={headcount}
        >0</dd>
      </div>
      <div>
        <dt class="text-[var(--color-text-dim)] uppercase tracking-wider text-[0.65rem]">
          {t.roster.regionLabel}
        </dt>
        <dd class="font-display text-3xl mt-1 leading-none text-[var(--color-accent-2)]">{regionLabel}</dd>
      </div>
    </dl>
  </div>
</section>

<AchievementStrip achievements={achievements} />

<section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-12 space-y-10">
  {sections.map((section) => (
    <div>
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-display text-2xl tracking-wide">{t.roles[section.role] ?? section.role}</h2>
        {/* Gold-leading divider: first 4rem gold accent then fades into the
            standard border colour. Pulls the eye across the role label. */}
        <span
          class="flex-1 h-px"
          style="background: linear-gradient(to right, var(--color-accent-2) 0, var(--color-accent-2) 4rem, var(--color-border) 12rem);"
        ></span>
        <span class="text-xs uppercase tracking-wider text-[var(--color-accent-2)] tabular-nums">
          {section.players.length}
        </span>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {section.players.map((p, i) => (
          <PlayerCard player={p} index={i} />
        ))}
      </div>
    </div>
  ))}
</section>
