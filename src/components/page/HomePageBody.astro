---
/**
 * Home page body. Same markup is rendered at `/`, `/zh-TW/`, and `/zh-CN/`.
 * Astro.currentLocale is resolved per-URL by Astro's i18n router, so this
 * component picks up the right locale automatically.
 *
 * Composition (2026-06 redesign): the page reads like a scoresheet. Each
 * section carries a half-move of the Najdorf line as a quiet aria-hidden
 * index (src/lib/notation.ts):
 *   1. e4      hero
 *   1... c5    match center (live/countdown + results + where to watch)
 *   2. Nf3     roster preview
 *   2... d6    season so far (achievements + broadcast reach)
 *   3. d4      highlights
 *   3... cxd4  latest news
 * Sponsors and the community band close the page without indexes (they are
 * outro chrome, not chapters).
 */
import OWCSBadge from '../ui/OWCSBadge.astro';
import NextMatchCountdown from '../match/NextMatchCountdown.astro';
import MatchTicker from '../match/MatchTicker.astro';
import LiveHero from '../match/LiveHero.astro';
import WatchHub from '../match/WatchHub.astro';
import RosterPreview from '../team/RosterPreview.astro';
import AchievementStrip from '../team/AchievementStrip.astro';
import HighlightsStrip from '../team/HighlightsStrip.astro';
import SponsorsRow from '../team/SponsorsRow.astro';
import BroadcastReach from '../team/BroadcastReach.astro';
import CommunityCTA from '../team/CommunityCTA.astro';
import Button from '../ui/Button.astro';
import BishopMark from '../ui/BishopMark.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import NewsCover from '../news/NewsCover.astro';
import { getCollection } from 'astro:content';
import { competedAsFor, type Sponsor } from '../../data/site';
import { loadRoster, loadMatches, loadAchievements } from '../../data/loaders';
import { splitMatches, recordOf, seriesScore } from '../../lib/matches';
import { moveLabel } from '../../lib/notation';
import sponsorsData from '../../data/sponsors.json';
import { getLocale, pathFor, useT } from '../../i18n';
import { formatDate, translateTournament, translatePlacement } from '../../i18n/format';

const locale = getLocale(Astro);
const t = useT(locale);

const allMatches = loadMatches();
const roster = loadRoster();
const achievements = loadAchievements();

const now = Date.now();
// Bucketing lives in src/lib/matches.ts so the "an unscored match never
// renders as a result" rule is unit tested. Recent results draw from
// `completed` only: a past-dated match still awaiting its score shows up
// on /matches as TBD, never here as a fake W/L.
const { upcoming, past, completed } = splitMatches(allMatches, now);
const recentRows = completed.slice(0, 3).map((m) => ({ match: m, score: seriesScore(m) }));

const nextMatch = upcoming[0];

// Live hero candidate: the most recent match still within the +3h post-window,
// otherwise the next upcoming match. The script ultimately decides whether
// to enter live mode; the server just hands it the best candidate it has at
// build time. Pages are short-cached on the edge so this stays fresh enough.
const LIVE_POST_MS = 3 * 60 * 60 * 1000;
const inProgress = past.find((m) => new Date(m.date).getTime() > now - LIVE_POST_MS);
const liveCandidate = inProgress ?? nextMatch;

// News is per-locale now: show the current locale's articles. A locale with
// a missing translation simply shows fewer (or older) posts here.
const newsPosts = (await getCollection('news', ({ data }) => !data.draft && data.locale === locale))
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 2);

// Real-data hero stats
const players = roster.filter((p) => ['Tank', 'DPS', 'Support', 'Flex'].includes(p.role));
const countries = new Set(players.map((p) => p.country).filter(Boolean));
const { wins, losses } = recordOf(allMatches);

const topAchievement = [...achievements].sort((a, b) => +new Date(b.date) - +new Date(a.date))[0];
// "As Rankers" attribution if the headline achievement predates the org
// (Stage 1). Rendered as an aside on the hero so we don't claim it as ours.
const heroCompetedAs = topAchievement ? competedAsFor(topAchievement.event) : null;

// Localized hrefs for the two CTAs and the "All matches" / "All news" links.
const matchesHref = pathFor(locale, '/matches/');
const rosterHref = pathFor(locale, '/roster/');
const newsHref = pathFor(locale, '/news/');

// Next-fixture context handed to the highlights rail so its "more film on
// the way" placeholder names a real series instead of inventing one.
const nextFilm = nextMatch
  ? {
      opponent: nextMatch.opponent,
      date: formatDate(nextMatch.date, locale, { month: 'short', day: 'numeric' }),
    }
  : undefined;
---

<MatchTicker matches={allMatches} />

{
  /*
  Two heroes share this slot: the always-rendered default and the
  hidden-by-default live mode. The LiveHero module swaps them when current
  time falls in [match - 30m, match + 3h]. Both are server-rendered so
  there is no FOUC and SEO crawlers see the default.

  The default hero: a board-grid texture and ONE architectural bishop
  cropped at the right frame edge (replacing the old five drifting
  pieces), the wordmark rising as two groups, then the data-driven status
  block and a hairline scoresheet row for the stats. The section's bottom
  border is the baseline the rest of the page hangs from.
*/
}
<section
  data-hero-default
  class="relative overflow-hidden isolate border-b border-(--color-border)"
>
  {
    /* Ambient motion layer (decorative): a drifting accent glow, a sparse
       particle field, and a cursor-follow glow. Sits below the texture grid
       and content. The particles + cursor tracking are added by
       src/scripts/hero-ambient.ts and disabled under reduced motion; with JS
       off this is just the static glow. */
  }
  <div class="hero-ambient" aria-hidden="true">
    <div class="hero-glow"></div>
    <div class="hero-particles" data-hero-particles></div>
    <div class="hero-cursor-glow" data-hero-cursor></div>
  </div>
  <div class="texture-board" aria-hidden="true"></div>
  {
    /* The architectural bishop: oversized, faint linework, deliberately
      cropped by the section edge. Hidden from narrow viewports where it
      would crowd the wordmark. */
  }
  <div
    class="absolute -right-16 -bottom-40 hidden md:block text-(--color-accent) opacity-[0.07]"
    aria-hidden="true"
  >
    <BishopMark width={420} height={630} strokeWidth={1.2} />
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-b from-(--color-surface) to-(--color-bg) opacity-60 -z-10"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-(--max-content) px-4 sm:px-6 pt-14 sm:pt-24 pb-12">
    <p class="hero-fade-in section-header__move-like" aria-hidden="true" style="--delay:0ms">
      {moveLabel(0)}
    </p>
    <h1
      class="font-display text-(length:--text-hero) tracking-tight leading-[0.95] mt-2"
      style="overflow-wrap: anywhere"
    >
      <span class="hero-fade-in inline-block text-(--color-accent)" style="--delay:60ms"
        >NAJDORF</span
      >
      <span class="hero-fade-in inline-block" style="--delay:180ms">ESPORTS</span>
    </h1>

    <p
      class="hero-fade-in mt-4 font-display text-lg sm:text-xl text-(--color-accent-2) tracking-[0.3em]"
      style="--delay:420ms"
    >
      {t.hero.subhead}
    </p>

    <p
      class="hero-fade-in mt-6 max-w-xl text-base sm:text-lg text-(--color-text-dim) leading-relaxed"
      style="--delay:520ms"
    >
      {
        topAchievement && (
          <span class="text-(--color-text)">
            {t.hero.achievement(
              translatePlacement(topAchievement.placement, locale),
              translateTournament(topAchievement.event.replace(/^.*?·\s*/, ''), locale),
            )}
            {heroCompetedAs && (
              <span class="text-(--color-text-dim)"> ({t.competedAs(heroCompetedAs)})</span>
            )}{' '}
          </span>
        )
      }
      {t.hero.tagline}
    </p>

    {
      /*
      Data-driven status line: current W-L record + next fixture, both derived
      from the match data so they advance automatically after each result.
      Hides itself cleanly before any match exists.
    */
    }
    {
      (wins + losses > 0 || nextMatch) && (
        <p
          class="hero-fade-in mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm"
          style="--delay:600ms"
        >
          {wins + losses > 0 && (
            <span class="inline-flex items-baseline gap-2">
              <span class="text-[0.65rem] uppercase tracking-[0.2em] text-(--color-text-dim)">
                {t.roster.recordLabel}
              </span>
              <span class="font-display tracking-wide tabular-nums text-(--color-text)">
                {t.matches.record(wins, losses)}
              </span>
            </span>
          )}
          {nextMatch && (
            <span class="inline-flex items-baseline gap-2">
              <span class="text-[0.65rem] uppercase tracking-[0.2em] text-(--color-text-dim)">
                {t.home.nextMatchLabel}
              </span>
              <span class="text-(--color-text)">
                {t.nextMatch.vs(nextMatch.opponent)} ·{' '}
                {formatDate(nextMatch.date, locale, { month: 'short', day: 'numeric' })}
              </span>
            </span>
          )}
        </p>
      )
    }

    <div class="hero-fade-in mt-8 flex flex-wrap gap-3" style="--delay:680ms">
      <Button href={matchesHref} variant="primary">{t.hero.matchSchedule}</Button>
      <Button href={rosterHref} variant="secondary">{t.hero.meetRoster}</Button>
    </div>

    {
      /*
      Scoresheet stat row: hairline-ruled cells instead of boxed tiles.
      Each numeric value carries `data-count-up` + `data-target` so the
      count-up module animates it on entry; the SERVER renders the real
      value so crawlers and no-JS visitors always see the truth.
    */
    }
    <dl class="hero-fade-in mt-12 flex max-w-lg" style="--delay:780ms">
      <div class="flex-1 pr-5">
        <dt class="text-[0.6rem] uppercase tracking-[0.2em] text-(--color-text-dim)">
          {t.roster.playersLabel}
        </dt>
        <dd
          class="font-display text-3xl sm:text-4xl leading-none tabular-nums mt-2"
          data-count-up
          data-target={players.length}
        >
          {players.length}
        </dd>
      </div>
      <div class="flex-1 px-5 border-l border-(--color-border)">
        <dt class="text-[0.6rem] uppercase tracking-[0.2em] text-(--color-text-dim)">
          {countries.size === 1 ? t.roster.countryLabel : t.roster.countriesLabel}
        </dt>
        <dd
          class="font-display text-3xl sm:text-4xl leading-none tabular-nums mt-2"
          data-count-up
          data-target={countries.size}
        >
          {countries.size}
        </dd>
      </div>
      <div class="flex-[1.4] pl-5 border-l border-(--color-border)">
        <dt class="text-[0.6rem] uppercase tracking-[0.2em] text-(--color-text-dim)">
          {t.roster.recordLabel}
        </dt>
        {
          wins + losses > 0 ? (
            <dd class="font-display text-3xl sm:text-4xl leading-none tabular-nums mt-2 flex items-baseline gap-1">
              {/* whitespace-nowrap: the zh suffixes (勝/負) must never
                  wrap away from their number; a too-narrow viewport
                  breaks at the dash between the two records instead. */}
              <span
                class="whitespace-nowrap"
                data-count-up
                data-target={wins}
                data-count-suffix={t.match.win}
              >
                {wins}
                {t.match.win}
              </span>
              <span class="text-(--color-text-dim) text-2xl">–</span>
              <span
                class="whitespace-nowrap"
                data-count-up
                data-target={losses}
                data-count-suffix={t.match.loss}
              >
                {losses}
                {t.match.loss}
              </span>
            </dd>
          ) : (
            <dd class="font-display text-2xl sm:text-3xl leading-none mt-2 text-(--color-text-dim)">
              0W &middot; 0L
            </dd>
          )
        }
      </div>
    </dl>
  </div>
</section>

<LiveHero match={liveCandidate} />

{/* 1... c5: one band for everything match-shaped. */}
<section class="reveal section" aria-label={t.home.matchCenterHeading}>
  <SectionHeader
    move={moveLabel(1)}
    eyebrow={t.owcsBadge.descriptor}
    heading={t.home.matchCenterHeading}
  >
    <a
      href={matchesHref}
      class="link-arrow has-glyph text-sm uppercase tracking-wider text-(--color-accent-2) hover:text-(--color-accent)"
    >
      <span>{t.home.allMatches}</span>
    </a>
  </SectionHeader>

  <div class="mt-6">
    <OWCSBadge prominent />
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <NextMatchCountdown match={nextMatch} />
    </div>

    <div class="bg-(--color-surface) border border-(--color-border) rounded-md p-6 flex flex-col">
      <p class="text-xs uppercase tracking-wider text-(--color-accent-2)">
        {t.home.recentResults}
      </p>
      {
        recentRows.length > 0 ? (
          <>
            <ul class="mt-4 space-y-1 flex-1">
              {recentRows.map(({ match: m, score }) => (
                <li>
                  <a
                    href={m.streamUrl ?? matchesHref}
                    target={m.streamUrl ? '_blank' : undefined}
                    rel={m.streamUrl ? 'noopener' : undefined}
                    class="result-row group flex items-center justify-between gap-3 text-sm py-2.5 px-2 -mx-2 rounded-sm transition-colors hover:bg-(--color-surface-2)"
                  >
                    <span class="truncate min-w-0 group-hover:text-(--color-text) transition-colors">
                      {t.match.vs(m.opponent)}
                    </span>
                    <span class="flex items-center gap-2 shrink-0">
                      {score && (
                        <span class="font-display text-sm text-(--color-text-dim) tabular-nums">
                          {score.ours}–{score.theirs}
                        </span>
                      )}
                      {/* Explicit two-branch pill: only a final result ever
                          renders a letter. Anything else renders nothing. */}
                      {(m.result === 'win' || m.result === 'loss') && (
                        <span
                          class:list={[
                            'inline-flex items-center justify-center w-6 h-6 rounded-sm border font-display text-sm font-bold transition-transform group-hover:scale-110',
                            m.result === 'win'
                              ? 'text-(--color-win) border-(--color-win)'
                              : 'text-(--color-loss) border-(--color-loss)',
                          ]}
                        >
                          {m.result === 'win' ? t.match.win : t.match.loss}
                        </span>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </>
        ) : (
          <p class="text-sm text-(--color-text-dim) mt-3">{t.home.recentEmpty}</p>
        )
      }
    </div>
  </div>

  <div class="mt-6">
    <WatchHub compact />
  </div>
</section>

{/* 2. Nf3: the roster slat rail. */}
<div class="reveal">
  <RosterPreview players={roster} move={moveLabel(2)} />
</div>

{/* 2... d6: season so far. */}
<section class="reveal section" aria-label={t.achievement.ariaLabel}>
  <SectionHeader
    move={moveLabel(3)}
    eyebrow={t.hero.subhead}
    heading={t.achievement.recentResults}
  />
  <div class="mt-6 space-y-6">
    <AchievementStrip achievements={achievements} compact />
    <BroadcastReach compact />
  </div>
</section>

{/* 3. d4: highlights, built for 9:16 film. */}
<div class="reveal">
  <HighlightsStrip move={moveLabel(4)} nextFilm={nextFilm} />
</div>

{/* 3... cxd4: latest news with real covers. */}
<section class="reveal section">
  <SectionHeader move={moveLabel(5)} heading={t.home.latest}>
    <a
      href={newsHref}
      class="link-arrow has-glyph text-sm uppercase tracking-wider text-(--color-accent-2) hover:text-(--color-accent)"
    >
      <span>{t.home.allNews}</span>
    </a>
  </SectionHeader>

  <div class="grid gap-6 md:grid-cols-2 mt-6">
    {
      newsPosts.map((post) => (
        <a
          href={pathFor(locale, `/news/${post.data.slug}/`)}
          class="surface-hover block rounded-md group"
        >
          <NewsCover
            title={post.data.title}
            date={post.data.date}
            eyebrow={post.data.eyebrow}
            tone={post.data.tone}
            variant="card"
            locale={locale}
          />
          {post.data.description && (
            <p class="text-sm text-(--color-text-dim) mt-3 line-clamp-2 px-1">
              {post.data.description}
            </p>
          )}
          <p class="link-arrow has-glyph text-xs uppercase tracking-wider text-(--color-accent-2) mt-2 px-1 group-hover:text-(--color-accent)">
            <span>{t.home.read}</span>
          </p>
        </a>
      ))
    }
  </div>
</section>

<div class="reveal">
  <SponsorsRow
    sponsors={sponsorsData as Sponsor[]}
    invite={{
      eyebrow: t.sponsorInvite.eyebrow,
      heading: t.sponsorInvite.heading,
      body: t.sponsorInvite.body,
      cta: t.sponsorInvite.cta,
      href: pathFor(locale, '/partners/'),
    }}
  />
</div>

<div class="reveal">
  <CommunityCTA />
</div>

<style>
  /* Local twin of SectionHeader's move index for the hero (which composes
     its header by hand around the wordmark). */
  .section-header__move-like {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
    color: color-mix(in oklab, var(--color-accent-2) 60%, var(--color-text-dim));
  }
</style>

<script>
  import '../../scripts/hero-ambient.ts';
</script>
