---
/**
 * Partners / Business inquiries page body. Rendered at /partners/ and the two
 * localized mirrors. Honest, no inflated claims, no invented sponsor logos:
 * the "founding slots open" line stands in for a partners wall until real
 * partners exist.
 */
import { site } from '../../data/site';
import { getLocale, useT } from '../../i18n';
import StatStrip from '../team/StatStrip.astro';
import { loadMatches, loadRoster } from '../../data/loaders';
import { headlineStats } from '../../lib/derived-stats';

const locale = getLocale(Astro);
const t = useT(locale);

// Original monoline icons (symmetric, brand-blue) so the offer inventory reads
// like a deck rather than a list of dark boxes. Inline SVG, sized in the tag.
const offers = [
  {
    ...t.partners.offerJersey,
    icon: '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3 5 6l2 3 2-1.5V21h6V7.5L17 9l2-3-4-3a3 3 0 0 1-6 0Z"/></svg>',
  },
  {
    ...t.partners.offerBroadcast,
    icon: '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M8.5 8.5a5 5 0 0 0 0 7M15.5 8.5a5 5 0 0 1 0 7M6 6a9 9 0 0 0 0 12M18 6a9 9 0 0 1 0 12"/></svg>',
  },
  {
    ...t.partners.offerDiscord,
    icon: '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16v11H8l-4 4z"/><path d="M9 10h6M9 13h3"/></svg>',
  },
  {
    ...t.partners.offerLogo,
    icon: '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="13" rx="1.5"/><path d="M12 9l2.2 2.5L12 14l-2.2-2.5z"/></svg>',
  },
  {
    ...t.partners.offerSocial,
    icon: '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10v4h3l6 4V6l-6 4z"/><path d="M17 9.2a4 4 0 0 1 0 5.6"/></svg>',
  },
];

// Sponsor-facing headline numbers (real / derived). Self-hides the peak when
// none is logged. Reach-led order for a partner pitch.
const hs = headlineStats(loadMatches(), loadRoster(), Date.now());
const partnerStats = [
  ...(hs.peakViewers != null ? [{ value: hs.peakViewers, label: t.statStrip.peakViewers }] : []),
  ...(hs.winRatePct != null
    ? [{ value: hs.winRatePct, label: t.statStrip.winRate, suffix: '%' }]
    : []),
  { value: hs.matchesPlayed, label: t.statStrip.matchesPlayed },
  { value: hs.countries, label: t.statStrip.countries },
];
---

<section class="relative isolate overflow-hidden border-b border-(--color-border)">
  <div class="texture-board" aria-hidden="true"></div>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 pt-12 pb-10">
    <p class="eyebrow">{t.partners.eyebrow}</p>
    <h1 class="font-display text-(length:--text-h1) mt-2 tracking-wide leading-none">
      {t.partners.title}
    </h1>
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 sm:px-6 pb-16">
  <p class="text-lg text-[var(--color-text)] mt-10 leading-relaxed max-w-prose">
    {t.partners.intro}
  </p>
  <p class="text-[var(--color-text-dim)] mt-4 leading-relaxed max-w-prose">{t.partners.standing}</p>

  <div class="mt-10">
    <StatStrip stats={partnerStats} eyebrow={t.statStrip.byTheNumbers} />
  </div>

  <section class="mt-12">
    <h2 class="font-display text-(length:--text-h2) tracking-wide">{t.partners.offerHeading}</h2>
    <p class="text-sm text-[var(--color-text-dim)] mt-2 leading-relaxed">{t.partners.offerNote}</p>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2" role="list">
      {
        offers.map((o) => (
          <li class="offer-card surface-hover flex items-start gap-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-5">
            <span class="offer-icon" aria-hidden="true" set:html={o.icon} />
            <div class="min-w-0">
              <h3 class="font-display text-lg tracking-wide text-[var(--color-text)]">{o.title}</h3>
              <p class="text-sm text-[var(--color-text-dim)] mt-2 leading-relaxed">{o.body}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section
    class="mt-12 border-l-4 border-[var(--color-accent)] bg-[var(--color-surface)] px-5 py-5 rounded-r-md"
  >
    <h2 class="font-display text-xl tracking-wide">{t.partners.foundingHeading}</h2>
    <p class="text-[var(--color-text-dim)] mt-2 leading-relaxed">{t.partners.foundingBody}</p>
  </section>

  <section class="mt-12">
    <h2 class="font-display text-(length:--text-h2) tracking-wide">{t.partners.contactHeading}</h2>
    <p class="mt-3">
      <Fragment set:html={'<!--email_off-->'} />
      <a
        href={`mailto:${site.contactEmail}`}
        class="text-[var(--color-accent-2)] hover:text-[var(--color-accent)] underline underline-offset-4"
      >
        {site.contactEmail}
      </a>
      <Fragment set:html={'<!--/email_off-->'} />
    </p>
    <p class="text-sm text-[var(--color-text-dim)] mt-2">{t.partners.contactResponse}</p>
  </section>
</section>

<style>
  /* Brand-blue icon tile that anchors each offer card. */
  .offer-icon {
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    border-radius: 0.5rem;
    background: color-mix(in oklab, var(--color-accent) 12%, var(--color-surface-2));
    color: var(--color-accent-2);
  }
</style>
