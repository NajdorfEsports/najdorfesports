---
/**
 * About page body. Rendered at `/about/`, `/zh-TW/about/`, `/zh-CN/about/`.
 * Per-URL locale comes from Astro.currentLocale; all copy lives in i18n
 * (t.about) and is FROZEN: this pass restyles containers only. The roster
 * CTA points at the data-driven roster route via pathFor, so no player
 * names are hardcoded here. The Najdorf line sits beside the story as an
 * aria-hidden margin annotation (the org's namesake, locale-neutral).
 */
import Button from '../ui/Button.astro';
import StatStrip from '../team/StatStrip.astro';
import { site } from '../../data/site';
import { fullLine } from '../../lib/notation';
import { getLocale, pathFor, useT } from '../../i18n';
import { loadMatches, loadRoster } from '../../data/loaders';
import { headlineStats } from '../../lib/derived-stats';

const locale = getLocale(Astro);
const t = useT(locale);
const rosterHref = pathFor(locale, '/roster/');

// "By the numbers" snapshot so the story is not a wall of prose. Real /
// derived only (see lib/derived-stats.ts); the peak self-hides when unlogged.
const hs = headlineStats(loadMatches(), loadRoster(), Date.now());
const aboutStats = [
  { value: hs.players, label: t.statStrip.players },
  { value: hs.countries, label: t.statStrip.countries },
  ...(hs.winRatePct != null
    ? [{ value: hs.winRatePct, label: t.statStrip.winRate, suffix: '%' }]
    : []),
  ...(hs.peakViewers != null ? [{ value: hs.peakViewers, label: t.statStrip.peakViewers }] : []),
];
---

<section class="relative isolate overflow-hidden border-b border-(--color-border)">
  <div class="texture-board" aria-hidden="true"></div>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 pt-12 pb-10">
    <p class="eyebrow">{t.about.eyebrow}</p>
    <h1 class="font-display text-(length:--text-h1) mt-2 tracking-wide leading-none">
      {site.name}
    </h1>
    <p class="text-lg text-(--color-text) mt-4 leading-relaxed">{t.about.heroTagline}</p>
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 sm:px-6 pb-16">
  <div class="mt-10">
    <StatStrip stats={aboutStats} eyebrow={t.statStrip.byTheNumbers} />
  </div>

  <section class="mt-12 relative">
    <p class="about-notation" aria-hidden="true">{fullLine()}</p>
    <h2 class="font-display text-(length:--text-h2) tracking-wide">{t.about.storyHeading}</h2>
    <p class="mt-4 text-(--color-text-dim) leading-relaxed max-w-prose">{t.about.story1}</p>
    <p class="mt-3 text-(--color-text-dim) leading-relaxed max-w-prose">{t.about.story2}</p>
  </section>

  <section class="mt-12">
    <h2 class="font-display text-(length:--text-h2) tracking-wide">{t.about.teamHeading}</h2>
    <p class="mt-4 text-(--color-text-dim) leading-relaxed max-w-prose">{t.about.teamBody}</p>
    <div class="mt-6">
      <Button href={rosterHref} variant="secondary">{t.about.rosterLink}</Button>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="font-display text-(length:--text-h2) tracking-wide">{t.about.partnersHeading}</h2>
    <p class="mt-4 text-(--color-text-dim) leading-relaxed max-w-prose">{t.about.partners1}</p>
    <p class="mt-3 text-(--color-text-dim) leading-relaxed max-w-prose">{t.about.partners2}</p>
  </section>

  <section class="mt-12">
    <h2 class="font-display text-(length:--text-h2) tracking-wide">{t.about.contactHeading}</h2>
    <p class="mt-3 text-(--color-text-dim)">
      {t.about.contactLabel}
      <Fragment set:html={'<!--email_off-->'} />
      <a
        href={`mailto:${site.contactEmail}`}
        class="text-(--color-accent-2) hover:text-(--color-accent) underline underline-offset-4"
      >
        {site.contactEmail}
      </a>
      <Fragment set:html={'<!--/email_off-->'} />
    </p>
  </section>
</section>

<style>
  /* The namesake line as a quiet annotation above the story: scoresheet
     type, never translated, invisible to assistive tech. */
  .about-notation {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
    color: color-mix(in oklab, var(--color-accent-2) 50%, var(--color-text-dim));
    margin-bottom: 0.875rem;
  }
</style>
