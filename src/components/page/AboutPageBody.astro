---
/**
 * About page body. Rendered at `/about/`, `/zh-TW/about/`, `/zh-CN/about/`.
 * Per-URL locale comes from Astro.currentLocale.
 */
import SocialRow from '../layout/SocialRow.astro';
import { site } from '../../data/site';
import { DEFAULT_LOCALE, useT, type Locale } from '../../i18n';

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);
---
<section class="mx-auto max-w-3xl px-4 sm:px-6 pt-12 pb-16">
  <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">{t.about.eyebrow}</p>
  <h1 class="font-display text-4xl sm:text-5xl mt-2 tracking-wide">{site.name}</h1>

  <p class="text-lg text-[var(--color-text)] mt-6 leading-relaxed">
    {t.about.body(site.yearFounded, site.region)}
  </p>

  <hr class="border-[var(--color-border)] my-8" />

  <p class="text-[var(--color-text-dim)] italic">
    {t.about.previously}
  </p>

  <section class="mt-12">
    <h2 class="font-display text-2xl tracking-wide">{t.about.contactHeading}</h2>
    <p class="mt-3">
      <a
        href={`mailto:${site.contactEmail}`}
        class="text-[var(--color-accent-2)] hover:text-[var(--color-accent)] underline underline-offset-4"
      >
        {site.contactEmail}
      </a>
    </p>
    <p class="text-sm text-[var(--color-text-dim)] mt-2">
      {t.about.contactNote}
    </p>

    <div class="mt-8">
      <p class="text-[0.65rem] uppercase tracking-[0.25em] text-[var(--color-accent-2)] mb-3">
        {t.about.followHeading}
      </p>
      <SocialRow />
    </div>
  </section>
</section>
