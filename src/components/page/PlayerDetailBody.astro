---
/**
 * Individual player detail page body. Rendered at /roster/<handle>/ and the
 * two localized mirrors. Driven entirely by the merged roster entry so it
 * stays in sync with the roster data.
 *
 * Visual: the player's signature hero ART (under Blizzard's Fan Content
 * Policy), never a photo, matching the roster-card source pattern. Designed to
 * degrade gracefully: a brand-new player with no bio and no socials still
 * reads as an intentional page (large hero art + handle + role + nationality),
 * not a broken/empty shell. Every optional section is omitted when its data is
 * absent.
 */
import CountryFlag from '../player/CountryFlag.astro';
import BishopMark from '../ui/BishopMark.astro';
import heroIcons from '../../data/heroes.json';
import { type RosterEntry, type Role } from '../../data/site';
import { getLocale, pathFor, useT } from '../../i18n';
import { displayCountry } from '../../i18n/format';

interface Props {
  player: RosterEntry;
}
const { player } = Astro.props;

const locale = getLocale(Astro);
const t = useT(locale);

const heroMap = heroIcons as Record<string, string>;
const heroes = (player.signatureHeroes ?? [])
  .map((name) => ({ name, iconUrl: heroMap[name] }))
  .filter((h): h is { name: string; iconUrl: string } => !!h.iconUrl);
const bannerHero = heroes[0];

const hasCountry = !!(player.country && player.country !== 'TBD');
const countryName = displayCountry(player.countryCode, player.country, locale);

const roles = [player.role, ...(player.altRoles ?? [])].filter(
  (r, i, a) => a.indexOf(r) === i,
);

const roleAccent: Record<string, string> = {
  Tank: 'var(--color-accent)',
  DPS: 'var(--color-accent-2)',
  Support: '#4ADE80',
  Flex: '#A78BFA',
  Coach: '#60A5FA',
  Manager: '#60A5FA',
};
const accent = roleAccent[player.role] ?? 'var(--color-accent-2)';

function ageFromBirth(iso?: string): number | null {
  if (!iso) return null;
  const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return null;
  const [, y, mo, d] = m;
  const now = new Date();
  let age = now.getUTCFullYear() - Number(y);
  const todayMD = now.getUTCMonth() * 100 + now.getUTCDate();
  const birthMD = (Number(mo) - 1) * 100 + Number(d);
  if (todayMD < birthMD) age -= 1;
  return age >= 0 && age < 100 ? age : null;
}
const age = ageFromBirth(player.birthDate);

// Outbound links, each rendered only when present. Liquipedia stays (kept per
// the brief); Twitch / X / Bilibili appear only where the player lists them.
const links = [
  player.liquipediaUrl ? { label: t.player.liquipedia, url: player.liquipediaUrl } : null,
  player.twitch ? { label: t.player.twitch, url: player.twitch } : null,
  player.twitter ? { label: t.player.twitter, url: player.twitter } : null,
  player.bilibili ? { label: t.player.bilibili, url: player.bilibili } : null,
].filter((l): l is { label: string; url: string } => l !== null);

const rosterHref = pathFor(locale, '/roster/');
const avatarAlt = t.player.avatarAlt(
  player.handle,
  t.roles[player.role as Role] ?? player.role,
  bannerHero?.name,
);
---
<article class="mx-auto max-w-4xl px-4 sm:px-6 pt-8 pb-16" style={`--accent:${accent};`}>
  <a
    href={rosterHref}
    class="link-arrow has-glyph text-xs uppercase tracking-wider text-[var(--color-accent-2)] hover:text-[var(--color-accent)] inline-flex"
  >
    <span>{t.playerPage.backToRoster}</span>
  </a>

  <div class="mt-6 grid gap-8 sm:grid-cols-[auto_1fr] items-start">
    {/* Signature hero art (or a branded bishop panel if no icon is known). */}
    {bannerHero ? (
      <div
        class="player-detail__art"
        style={`background-image:url('${bannerHero.iconUrl}');`}
        role="img"
        aria-label={avatarAlt}
      ></div>
    ) : (
      <div class="player-detail__art player-detail__art--mono" role="img" aria-label={avatarAlt}>
        <BishopMark width={88} height={132} strokeWidth={1.4} />
      </div>
    )}

    <div class="min-w-0">
      <h1 class="font-display text-5xl sm:text-6xl tracking-tight leading-none break-words">
        {player.handle}
      </h1>

      <div class="mt-4 flex items-center gap-2 flex-wrap text-xs uppercase tracking-wider">
        {roles.map((r) => {
          const a = roleAccent[r] ?? accent;
          return (
            <span
              class="px-2.5 py-1 rounded-sm border font-semibold"
              style={`color:${a};border-color:${a};`}
            >
              {t.roles[r as Role] ?? r}
            </span>
          );
        })}
        {hasCountry && (
          <span class="flex items-center gap-1.5 text-[var(--color-text-dim)] ml-1 normal-case">
            <CountryFlag code={player.countryCode} name={countryName} size="md" />
            <span class="text-sm">{countryName}</span>
          </span>
        )}
      </div>

      {(player.realName || age !== null) && (
        <p class="mt-4 text-[var(--color-text-dim)]">
          {player.realName && (
            <span class="text-[var(--color-text)]">{player.realName}</span>
          )}
          {player.realName && age !== null && ' · '}
          {age !== null && <span class="tabular-nums">{age}</span>}
        </p>
      )}
    </div>
  </div>

  {heroes.length > 0 && (
    <section class="mt-12">
      <h2 class="text-[0.7rem] uppercase tracking-[0.25em] text-[var(--color-accent-2)]">
        {t.playerPage.heroPool}
      </h2>
      <ul class="mt-4 flex flex-wrap gap-3" role="list">
        {heroes.map((h) => (
          <li class="flex items-center gap-2.5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-full pl-1.5 pr-4 py-1.5">
            <img
              src={h.iconUrl}
              alt={h.name}
              width="36"
              height="36"
              loading="lazy"
              decoding="async"
              class="w-9 h-9 rounded-full object-cover"
              style="object-position:50% 18%;"
            />
            <span class="font-display text-sm tracking-wide">{h.name}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {links.length > 0 && (
    <section class="mt-10">
      <h2 class="text-[0.7rem] uppercase tracking-[0.25em] text-[var(--color-accent-2)]">
        {t.playerPage.links}
      </h2>
      <ul class="mt-4 flex flex-wrap gap-3" role="list">
        {links.map((l) => (
          <li>
            <a
              href={l.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md px-4 py-2 text-sm uppercase tracking-wider text-[var(--color-text-dim)] hover:text-[var(--color-text)] hover:border-[var(--accent)] transition-colors"
            >
              <span class="link-arrow has-glyph"><span>{l.label}</span></span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</article>

<style>
  /* Large signature-hero art panel. Cover-cropped with the face biased upward,
     same framing intent as PlayerAvatar (50% 14%). A subtle accent ring + a
     bottom vignette keep it cohesive with the card treatment. */
  .player-detail__art {
    width: 140px;
    height: 180px;
    border-radius: 0.5rem;
    background-size: cover;
    background-position: 50% 12%;
    background-repeat: no-repeat;
    border: 1px solid var(--color-border);
    box-shadow:
      inset 0 -16px 28px -12px rgba(11, 11, 15, 0.75),
      0 0 0 1px color-mix(in oklab, var(--accent) 22%, transparent);
  }
  @media (min-width: 640px) {
    .player-detail__art { width: 180px; height: 230px; }
  }
  .player-detail__art--mono {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-2) 100%);
    color: var(--color-text-dim);
  }
</style>
