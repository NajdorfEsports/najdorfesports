---
/**
 * Individual player detail page body. Rendered at /roster/<handle>/ and the
 * two localized mirrors. Driven entirely by the merged roster entry so it
 * stays in sync with the roster data.
 *
 * Visual (motion-system redesign): a copyright-safe branded identity band,
 * a role-tinted field with an animated diagonal hatch, the handle at hero
 * scale beside the player's role-signature chess piece framed by concentric
 * rings (no borrowed art). Then the hero pool as portrait tiles, a per-player
 * bio slot, outbound links, and the Liquipedia attribution the data requires.
 * Degrades gracefully: a brand-new player with no socials still reads as an
 * intentional page.
 */
import { Image } from 'astro:assets';
import CountryFlag from '../player/CountryFlag.astro';
import ChessPiece from '../brand/ChessPiece.astro';
import { type RosterEntry, type Role } from '../../data/site';
import { type PieceName } from '../../lib/pieces';
import { roleAccent, ageFromBirth } from '../../lib/player';
import { resolveHeroIcons } from '../../lib/heroes';
import { getLocale, pathFor, useT } from '../../i18n';
import { displayCountry } from '../../i18n/format';

interface Props {
  player: RosterEntry;
}
const { player } = Astro.props;

const locale = getLocale(Astro);
const t = useT(locale);

const heroes = resolveHeroIcons(player.signatureHeroes);

const hasCountry = !!(player.country && player.country !== 'TBD');
const countryName = displayCountry(player.countryCode, player.country, locale);

const roles = [player.role, ...(player.altRoles ?? [])].filter((r, i, a) => a.indexOf(r) === i);

const accent = roleAccent(player.role);

const age = ageFromBirth(player.birthDate);

// Outbound links, each rendered only when present. Liquipedia stays (kept per
// the brief); Twitch / X / Bilibili appear only where the player lists them.
const links = [
  player.liquipediaUrl ? { label: t.player.liquipedia, url: player.liquipediaUrl } : null,
  player.twitch ? { label: t.player.twitch, url: player.twitch } : null,
  player.twitter ? { label: t.player.twitter, url: player.twitter } : null,
  player.bilibili ? { label: t.player.bilibili, url: player.bilibili } : null,
].filter((l): l is { label: string; url: string } => l !== null);

const rosterHref = pathFor(locale, '/roster/');

// Each role gets a signature chess piece: the wall (Rook), the striker
// (Knight), the long-range support (Bishop), the do-everything Flex (Queen),
// and the staff who run the show (King / Queen). Reused across players in a
// role; it is the brand's piece family, not a per-player stat.
const ROLE_PIECE: Record<string, PieceName> = {
  Tank: 'Rook',
  DPS: 'Knight',
  Support: 'Bishop',
  Flex: 'Queen',
  Coach: 'King',
  Manager: 'Queen',
};
const signaturePiece: PieceName = ROLE_PIECE[player.role] ?? 'Bishop';
---

{
  /* Identity band: a copyright-safe branded header. A role-tinted field with
    an animated diagonal hatch, the nameplate on the left, and the player's
    role-signature chess piece framed by concentric rings on the right. No
    borrowed art. */
}
<section
  class="player-banner relative isolate overflow-hidden border-b border-(--color-border)"
  style={`--role:${accent};--accent:${accent};`}
>
  <div class="player-banner__field" aria-hidden="true"></div>
  <div class="player-banner__bars" aria-hidden="true">
    <span class="naj-hatch"></span>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 pt-10 pb-10 sm:pt-12">
    <a
      href={rosterHref}
      class="link-arrow has-glyph text-xs uppercase tracking-wider text-(--color-accent-2) hover:text-(--color-accent) inline-flex"
    >
      <span>{t.playerPage.backToRoster}</span>
    </a>

    <div class="mt-8 grid items-center gap-8 sm:grid-cols-[1.5fr_1fr]">
      <div class="min-w-0">
        <h1 class="font-display text-(length:--text-h1) tracking-tight leading-none break-words">
          {player.handle}
        </h1>

        <div class="mt-5 flex items-center gap-2 flex-wrap text-xs uppercase tracking-wider">
          {
            roles.map((r) => {
              const a = roleAccent(r);
              return (
                <span
                  class="px-2.5 py-1 rounded-sm border font-semibold bg-(--color-bg)/60 backdrop-blur-sm"
                  style={`color:${a};border-color:${a};`}
                >
                  {t.roles[r as Role] ?? r}
                </span>
              );
            })
          }
          {
            hasCountry && (
              <span class="flex items-center gap-1.5 text-(--color-text-dim) ml-1 normal-case">
                <CountryFlag code={player.countryCode} name={countryName} size="md" />
                <span class="text-sm">{countryName}</span>
              </span>
            )
          }
        </div>

        {
          (player.realName || age !== null) && (
            <p class="mt-4 text-(--color-text-dim)">
              {player.realName && <span class="text-(--color-text)">{player.realName}</span>}
              {player.realName && age !== null && ' · '}
              {age !== null && <span class="tabular-nums">{age}</span>}
            </p>
          )
        }
      </div>

      {
        /* Role-signature chess piece, framed by concentric rings. Decorative:
          the role is already announced by the badges above. */
      }
      <div class="player-banner__sig" style={`color:${accent};`}>
        <span class="player-banner__ring" aria-hidden="true"></span>
        <span class="player-banner__ring player-banner__ring--2" aria-hidden="true"></span>
        <div class="player-banner__piece">
          <ChessPiece piece={signaturePiece} sway width={120} />
        </div>
        <span class="player-banner__sig-label">{t.playerPage.signature} · {signaturePiece}</span>
      </div>
    </div>
  </div>
</section>

<article class="mx-auto max-w-4xl px-4 sm:px-6 pb-16" style={`--accent:${accent};`}>
  {
    heroes.length > 0 && (
      <section class="mt-12">
        <h2 class="text-[0.7rem] uppercase tracking-[0.25em] text-(--color-accent-2)">
          {t.playerPage.heroPool}
        </h2>
        <ul class="mt-4 flex flex-wrap gap-4" role="list">
          {heroes.map((h) => (
            <li class="flex flex-col items-center gap-2 w-20">
              <Image
                src={h.image}
                alt={h.name}
                width={72}
                densities={[1, 2]}
                loading="lazy"
                decoding="async"
                class="chip-ink w-18 h-18 rounded-md object-cover border border-(--color-border)"
                style="object-position:50% 14%;"
              />
              <span class="text-[0.65rem] uppercase tracking-wider text-(--color-text-dim) text-center leading-tight">
                {h.name}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {/* Per-player bio slot is rendered in Phase 4 (bio + bioLang). */}

  {
    links.length > 0 && (
      <section class="mt-12">
        <h2 class="text-[0.7rem] uppercase tracking-[0.25em] text-(--color-accent-2)">
          {t.playerPage.links}
        </h2>
        <ul class="mt-4 flex flex-wrap gap-3" role="list">
          {links.map((l) => (
            <li>
              <a
                href={l.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 bg-(--color-surface) border border-(--color-border) rounded-md px-4 py-2 text-sm uppercase tracking-wider text-(--color-text-dim) hover:text-(--color-text) hover:border-(--accent) transition-colors"
              >
                <span class="link-arrow has-glyph">
                  <span>{l.label}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {/* Player data on this page comes from Liquipedia; attribution required. */}
  <p class="mt-14 text-xs text-(--color-text-dim)">
    {t.matches.attribution.before}<a
      href="https://liquipedia.net/overwatch/"
      target="_blank"
      rel="noopener"
      class="link-slide text-(--color-accent-2)">Liquipedia</a
    >{t.matches.attribution.between}<a
      href="https://creativecommons.org/licenses/by-sa/3.0/"
      target="_blank"
      rel="noopener"
      class="link-slide text-(--color-accent-2)">CC BY-SA 3.0</a
    >{t.matches.attribution.after}
  </p>
</article>

<style>
  /* Role-tinted field: a soft radial glow toward the piece side plus a linear
     role wash. The role color arrives on --role (set inline per player). */
  .player-banner__field {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    background:
      radial-gradient(
        120% 130% at 88% 22%,
        color-mix(in oklab, var(--role) 26%, transparent),
        transparent 60%
      ),
      linear-gradient(
        100deg,
        var(--color-surface) 28%,
        color-mix(in oklab, var(--role) 9%, var(--color-surface)) 100%
      );
  }
  /* Animated diagonal hatch, masked to the right (piece) side so it never
     crowds the nameplate. The child .naj-hatch carries the shared sweep loop
     (frozen under reduced motion by motion.css). */
  .player-banner__bars {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.5;
    -webkit-mask-image: linear-gradient(90deg, transparent 26%, #000 92%);
    mask-image: linear-gradient(90deg, transparent 26%, #000 92%);
  }

  /* Signature piece centered in two concentric, role-tinted rings. */
  .player-banner__sig {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 190px;
    padding: 1.25rem;
  }
  .player-banner__ring {
    position: absolute;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--role) 32%, transparent);
    pointer-events: none;
  }
  .player-banner__ring--2 {
    width: 204px;
    height: 204px;
    border-color: color-mix(in oklab, var(--role) 16%, transparent);
  }
  .player-banner__piece {
    position: relative;
    z-index: 1;
  }
  .player-banner__sig-label {
    position: absolute;
    bottom: 0.25rem;
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--role) 60%, var(--color-text-dim));
  }
</style>
