---
/**
 * /games/ hub, shared by all three locales. One card per game (the daily
 * crossword, OWdle, and Gambit); add a card here when game #4 ships. Each card
 * carries an original, copyright-safe animated background (GameCardBg).
 */
import SectionHeader from '../ui/SectionHeader.astro';
import GameCardBg from '../games/GameCardBg.astro';
import { getLocale, pathFor, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);
const g = t.games.hub;

const cards = [
  {
    href: pathFor(locale, '/games/crossword/'),
    bg: 'crossword' as const,
    title: g.crosswordTitle,
    badge: g.newDaily,
    desc: g.crosswordDesc,
    cta: g.crosswordCta,
  },
  {
    href: pathFor(locale, '/games/owdle/'),
    bg: 'owdle' as const,
    title: g.owdleTitle,
    badge: g.newHeroDaily,
    desc: g.owdleDesc,
    cta: g.owdleCta,
  },
  {
    href: pathFor(locale, '/games/gambit/'),
    bg: 'gambit' as const,
    title: g.gambitTitle,
    badge: g.newDailyRun,
    desc: g.gambitDesc,
    cta: g.gambitCta,
  },
];
---

<section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pt-10 pb-4">
  <SectionHeader heading={g.heading} eyebrow={g.eyebrow} level="h1" />
  <p class="mt-4 max-w-2xl text-[var(--color-text-dim)]">{g.sub}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {
      cards.map((c) => (
        <a
          href={c.href}
          class="surface-hover group relative isolate block overflow-hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6"
          style="box-shadow: var(--shadow-card)"
        >
          <GameCardBg game={c.bg} />
          <div class="relative">
            <div class="flex items-start justify-between gap-4">
              <h2 class="font-display text-2xl tracking-wide">{c.title}</h2>
              <span class="shrink-0 rounded border border-[var(--color-accent)]/40 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-[var(--color-accent-2)]">
                {c.badge}
              </span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-dim)]">{c.desc}</p>
            <span class="link-slide mt-4 inline-block text-sm font-medium uppercase tracking-wide text-[var(--color-accent-2)] group-hover:text-[var(--color-text)]">
              {c.cta}
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
