---
/**
 * Coaching page body. Rendered at /coaching/, /zh-TW/coaching/, /zh-CN/coaching/.
 * Per-URL locale comes from Astro.currentLocale; shared chrome lives in i18n
 * (t.coaching). Per-coach facts and prose come from src/data/coaching.ts.
 *
 * Flow: hero, coach browser (filters + card grid), one booking section per coach
 * (payment then tier), how it works, FAQ, help. Booking is handled by embedded
 * Cal.com bookers: each Book control is a real anchor to the public Cal.com page
 * that the inline init script upgrades to a popup (so booking works with JS off).
 * The inline script also drives the filters and the payment selector (vanilla,
 * no framework).
 */
import Button from '../ui/Button.astro';
import CoachCard from '../coaching/CoachCard.astro';
import CoachFilters from '../coaching/CoachFilters.astro';
import BookingFlow from '../coaching/BookingFlow.astro';
import { COACHES, COACHING_DISCORD_INVITE } from '../../data/coaching';
import { site } from '../../data/site';
import { getLocale, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);
const c = t.coaching;

const steps = [
  { title: c.how.step1Title, body: c.how.step1Body },
  { title: c.how.step2Title, body: c.how.step2Body },
  { title: c.how.step3Title, body: c.how.step3Body },
  { title: c.how.step4Title, body: c.how.step4Body },
];

const faqs = [
  { q: c.faq.q1, a: c.faq.a1 },
  { q: c.faq.q2, a: c.faq.a2 },
  { q: c.faq.q3, a: c.faq.a3 },
  { q: c.faq.q4, a: c.faq.a4 },
  { q: c.faq.q5, a: c.faq.a5 },
  { q: c.faq.q6, a: c.faq.a6 },
  { q: c.faq.q7, a: c.faq.a7 },
];
---

<article>
  {/* Hero on the board texture, matching the sitewide header band. */}
  <section class="relative isolate overflow-hidden border-b border-(--color-border)">
    <div class="texture-board" aria-hidden="true"></div>
    <div class="mx-auto max-w-(--max-content) px-4 sm:px-6 pt-12 pb-10">
      <p class="eyebrow">{c.hero.eyebrow}</p>
      <h1 class="font-display text-(length:--text-h1) mt-2 tracking-wide leading-none max-w-3xl">
        {c.hero.heading}
      </h1>
      <p class="text-lg text-[var(--color-text)] mt-4 leading-relaxed max-w-2xl">
        {c.hero.subheading}
      </p>
      <div class="mt-6">
        <Button href="#coaches">{c.hero.cta}</Button>
      </div>
    </div>
  </section>

  {/* Coach browser */}
  <section id="coaches" class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-8 scroll-mt-20">
    <h2 class="font-display text-2xl sm:text-3xl tracking-wide">{c.browse.heading}</h2>
    <p class="mt-2 max-w-2xl text-[var(--color-text-dim)] leading-relaxed">{c.browse.lede}</p>

    <div class="mt-6">
      <CoachFilters />
    </div>

    <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {COACHES.map((coach) => <CoachCard coach={coach} />)}
    </ul>
    <p data-no-match hidden class="mt-6 text-[var(--color-text-dim)]">
      {c.browse.noMatch}
    </p>
  </section>

  {/* Booking sections, one per coach */}
  {COACHES.map((coach) => <BookingFlow coach={coach} />)}

  {/* How it works */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-10">
    <h2 class="font-display text-2xl tracking-wide">{c.how.heading}</h2>
    <ol class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" role="list">
      {
        steps.map((s, i) => (
          <li class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-5">
            <span class="font-display text-3xl text-[var(--color-accent)]">{i + 1}</span>
            <h3 class="font-display text-lg tracking-wide mt-2">{s.title}</h3>
            <p class="mt-2 text-sm text-[var(--color-text-dim)] leading-relaxed">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  {/* FAQ (native details, no JS) */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-10">
    <h2 class="font-display text-2xl tracking-wide">{c.faq.heading}</h2>
    <div class="mt-6 max-w-3xl border-y border-[var(--color-border)]">
      {
        faqs.map((f) => (
          <details class="coaching-faq border-b border-[var(--color-border)] last:border-b-0">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4">
              <span class="font-semibold text-[var(--color-text)]">{f.q}</span>
              <svg
                class="coaching-faq__chevron shrink-0 text-[var(--color-text-dim)]"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </summary>
            <p class="pb-4 text-[var(--color-text-dim)] leading-relaxed">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  {/* Help / Discord + email */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pb-16">
    <div
      class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-l-4 border-[var(--color-accent)] bg-[var(--color-surface)] px-5 py-5 rounded-r-md"
    >
      <div>
        <p class="text-[var(--color-text)]">{c.help.text}</p>
        <p class="mt-1 text-sm text-[var(--color-text-dim)]">
          {c.help.emailIntro}{' '}
          <Fragment set:html={'<!--email_off-->'} /><a
            class="text-[var(--color-accent-2)] underline underline-offset-2"
            href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a
          ><Fragment set:html={'<!--/email_off-->'} />
        </p>
      </div>
      <Button href={COACHING_DISCORD_INVITE} external variant="secondary">
        {c.help.discordCta}
      </Button>
    </div>
  </section>
</article>

<script>
  // All client behavior for this page (filters, payment selector, lazy
  // Cal embed with first-click replay) lives in src/scripts/coaching.ts,
  // bundled by Astro into a processed module so the CSP needs no
  // 'unsafe-inline'. It loads only on pages rendering this component.
  import '../../scripts/coaching.ts';
</script>

<style>
  /* FAQ accordion chrome. Native <details>, zero JS. */
  .coaching-faq summary::-webkit-details-marker {
    display: none;
  }
  .coaching-faq__chevron {
    transition: transform 0.2s ease-out;
  }
  .coaching-faq[open] .coaching-faq__chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .coaching-faq__chevron {
      transition: none;
    }
  }
</style>
