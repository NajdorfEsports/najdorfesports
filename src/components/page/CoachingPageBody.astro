---
/**
 * Coaching page body. Rendered at /coaching/, /zh-TW/coaching/, /zh-CN/coaching/.
 * Per-URL locale comes from Astro.currentLocale; shared chrome lives in i18n
 * (t.coaching). Per-coach facts and prose come from src/data/coaching.ts and
 * region options from src/data/regions.ts.
 *
 * Flow: hero, coach browser (filters + card grid), one booking section per coach
 * (region then payment then tier), how it works, FAQ, help. Booking is handled
 * by embedded Cal.com bookers: each Book control is a real anchor to the public
 * Cal.com page that the inline init script upgrades to a popup (so booking works
 * with JS off). The inline script also drives the filters and the region and
 * payment selectors (vanilla, no framework).
 */
import Button from '../ui/Button.astro';
import CoachCard from '../coaching/CoachCard.astro';
import CoachFilters from '../coaching/CoachFilters.astro';
import BookingFlow from '../coaching/BookingFlow.astro';
import { COACHES, COACHING_DISCORD_INVITE } from '../../data/coaching';
import { site } from '../../data/site';
import { getLocale, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);
const c = t.coaching;

const steps = [
  { title: c.how.step1Title, body: c.how.step1Body },
  { title: c.how.step2Title, body: c.how.step2Body },
  { title: c.how.step3Title, body: c.how.step3Body },
  { title: c.how.step4Title, body: c.how.step4Body },
];

const faqs = [
  { q: c.faq.q1, a: c.faq.a1 },
  { q: c.faq.q2, a: c.faq.a2 },
  { q: c.faq.q3, a: c.faq.a3 },
  { q: c.faq.q4, a: c.faq.a4 },
  { q: c.faq.q5, a: c.faq.a5 },
  { q: c.faq.q6, a: c.faq.a6 },
  { q: c.faq.q7, a: c.faq.a7 },
];
---

<article>
  {/* Hero */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pt-12 pb-8">
    <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">{c.hero.eyebrow}</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-2 tracking-wide max-w-3xl">{c.hero.heading}</h1>
    <p class="text-lg text-[var(--color-text)] mt-4 leading-relaxed max-w-2xl">
      {c.hero.subheading}
    </p>
    <div class="mt-6">
      <Button href="#coaches">{c.hero.cta}</Button>
    </div>
  </section>

  {/* Coach browser */}
  <section id="coaches" class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-8 scroll-mt-20">
    <h2 class="font-display text-2xl sm:text-3xl tracking-wide">{c.browse.heading}</h2>
    <p class="mt-2 max-w-2xl text-[var(--color-text-dim)] leading-relaxed">{c.browse.lede}</p>

    <div class="mt-6">
      <CoachFilters />
    </div>

    <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {COACHES.map((coach) => <CoachCard coach={coach} />)}
    </ul>
    <p data-no-match hidden class="mt-6 text-[var(--color-text-dim)]">
      {c.browse.noMatch}
    </p>
  </section>

  {/* Booking sections, one per coach */}
  {COACHES.map((coach) => <BookingFlow coach={coach} />)}

  {/* How it works */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-10">
    <h2 class="font-display text-2xl tracking-wide">{c.how.heading}</h2>
    <ol class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" role="list">
      {
        steps.map((s, i) => (
          <li class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-5">
            <span class="font-display text-3xl text-[var(--color-accent)]">{i + 1}</span>
            <h3 class="font-display text-lg tracking-wide mt-2">{s.title}</h3>
            <p class="mt-2 text-sm text-[var(--color-text-dim)] leading-relaxed">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  {/* FAQ (native details, no JS) */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-10">
    <h2 class="font-display text-2xl tracking-wide">{c.faq.heading}</h2>
    <div class="mt-6 max-w-3xl border-y border-[var(--color-border)]">
      {
        faqs.map((f) => (
          <details class="coaching-faq border-b border-[var(--color-border)] last:border-b-0">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4">
              <span class="font-semibold text-[var(--color-text)]">{f.q}</span>
              <svg
                class="coaching-faq__chevron shrink-0 text-[var(--color-text-dim)]"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </summary>
            <p class="pb-4 text-[var(--color-text-dim)] leading-relaxed">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  {/* Help / Discord + email */}
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pb-16">
    <div
      class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-l-4 border-[var(--color-accent)] bg-[var(--color-surface)] px-5 py-5 rounded-r-md"
    >
      <div>
        <p class="text-[var(--color-text)]">{c.help.text}</p>
        <p class="mt-1 text-sm text-[var(--color-text-dim)]">
          {c.help.emailIntro}{' '}
          <Fragment set:html={'<!--email_off-->'} /><a
            class="text-[var(--color-accent-2)] underline underline-offset-2"
            href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a
          ><Fragment set:html={'<!--/email_off-->'} />
        </p>
      </div>
      <Button href={COACHING_DISCORD_INVITE} external variant="secondary">
        {c.help.discordCta}
      </Button>
    </div>
  </section>
</article>

<script is:inline>
  // Cal.com popup embed loader (vanilla, no React island), LAZY by doctrine:
  // the site ships zero third-party scripts at page load, so embed.js is fetched
  // from app.cal.com only on the first hover/focus/touch/click of a Book control
  // (the stub below queues every Cal() call until then). Keep the origin and
  // brand color in sync with CAL_ORIGIN / CAL_BRAND_COLOR in src/data/coaching.ts
  // and --color-accent in src/styles/global.css. The booker is forced to dark.
  // Each Book control is also a real anchor to the Cal.com page, so booking still
  // works if embed.js is blocked or JS is off.
  (function (C, A, L) {
    let p = function (a, ar) {
      a.q.push(ar);
    };
    let d = C.document;
    C.Cal =
      C.Cal ||
      function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () {
            p(api, arguments);
          };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === 'string') {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ['initNamespace', namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
  })(window, 'https://app.cal.com/embed/embed.js', 'init');

  // Load embed.js and apply the dark UI config on first booking intent.
  // Idempotent; everything before the script arrives is queued by the stub.
  // Marks __najdorfCalReady once Cal has registered its custom elements (and
  // therefore its own data-cal-link click handler), so the first-click race
  // handler below can stand down.
  function najdorfCalArm() {
    if (window.__najdorfCalArmed || typeof window.Cal !== 'function') return;
    window.__najdorfCalArmed = true;
    window.Cal('init', { origin: 'https://app.cal.com' });
    window.Cal('ui', {
      cssVarsPerTheme: { light: { 'cal-brand': '#215BFF' }, dark: { 'cal-brand': '#215BFF' } },
      hideEventTypeDetails: false,
      theme: 'dark',
      layout: 'month_view',
    });
    if (window.customElements && window.customElements.whenDefined) {
      window.customElements.whenDefined('cal-modal-box').then(function () {
        window.__najdorfCalReady = true;
      });
    }
  }

  // Coach browser filters + per-coach region/payment selectors. All client-side,
  // no cookies, no geolocation, nothing persisted. Visibility uses inline
  // display so Tailwind's display utilities cannot override it.
  function najdorfShowMethod(section, method) {
    section.querySelectorAll('[data-method-btn]').forEach(function (b) {
      b.setAttribute(
        'aria-pressed',
        b.getAttribute('data-method-btn') === method ? 'true' : 'false',
      );
    });
    section.querySelectorAll('.book-control').forEach(function (el) {
      el.style.display = el.getAttribute('data-method') === method ? '' : 'none';
    });
  }

  function najdorfCurrentMethod(section) {
    var pressed = section.querySelector('[data-method-btn][aria-pressed="true"]');
    return pressed ? pressed.getAttribute('data-method-btn') : 'stripe';
  }

  function najdorfShowRegion(section, regionBtn) {
    section.querySelectorAll('[data-region]').forEach(function (b) {
      b.setAttribute('aria-pressed', b === regionBtn ? 'true' : 'false');
    });
    var methods = (regionBtn.getAttribute('data-methods') || '').split(',').filter(Boolean);
    var active = najdorfCurrentMethod(section);
    var available = [];
    section.querySelectorAll('[data-method-btn]').forEach(function (b) {
      var m = b.getAttribute('data-method-btn');
      var ok = methods.indexOf(m) !== -1;
      b.style.display = ok ? '' : 'none';
      if (ok) available.push(m);
    });
    if (available.indexOf(active) === -1) active = available[0] || active;
    najdorfShowMethod(section, active);
  }

  function najdorfApplyFilters() {
    var role = najdorfVal('filter-role');
    var lang = najdorfVal('filter-language');
    var hero = najdorfVal('filter-hero');
    var visible = 0;
    document.querySelectorAll('[data-coach-card]').forEach(function (card) {
      var slug = card.getAttribute('data-coach-card');
      var okRole = !role || card.getAttribute('data-role') === role;
      var okLang = !lang || (card.getAttribute('data-langs') || '').split(',').indexOf(lang) !== -1;
      var okHero =
        !hero || (card.getAttribute('data-heroes') || '').split(',').indexOf(hero) !== -1;
      var show = okRole && okLang && okHero;
      card.hidden = !show;
      var booking = document.querySelector('[data-booking="' + slug + '"]');
      if (booking) booking.hidden = !show;
      if (show) visible++;
    });
    var empty = document.querySelector('[data-no-match]');
    if (empty) empty.hidden = visible !== 0;
  }

  function najdorfVal(id) {
    var el = document.getElementById(id);
    return el ? el.value : '';
  }

  function najdorfCoachingSetup() {
    // Note: the Cal embed is NOT armed here (lazy by doctrine); only the
    // filter and region/payment UI is initialized on load and SPA navigation.
    document.querySelectorAll('[data-booking]').forEach(function (section) {
      var pressed =
        section.querySelector('[data-region][aria-pressed="true"]') ||
        section.querySelector('[data-region]');
      if (pressed) najdorfShowRegion(section, pressed);
    });
    najdorfApplyFilters();
  }

  if (!window.__najdorfCoachingBound) {
    window.__najdorfCoachingBound = true;

    // Lazy-load the Cal embed on first booking intent (hover/focus/touch of a
    // Book control), so the popup is usually ready before the click lands.
    ['pointerover', 'focusin', 'touchstart'].forEach(function (evt) {
      document.addEventListener(
        evt,
        function (e) {
          if (e.target.closest && e.target.closest('[data-cal-link]')) najdorfCalArm();
        },
        { passive: true },
      );
    });

    // First-click race: a Book anchor clicked before embed.js has bound its own
    // data-cal-link handler. Prevent the fallback navigation, arm the embed, and
    // replay the click once it is live so it opens the popup. If the embed never
    // registers (blocked or offline), fall back to opening the real Cal.com link.
    document.addEventListener('click', function (e) {
      var btn = e.target.closest && e.target.closest('a[data-cal-link]');
      if (!btn || window.__najdorfCalReady || window.__najdorfCalReplay) return;
      e.preventDefault();
      window.__najdorfCalReplay = true;
      najdorfCalArm();
      var href = btn.getAttribute('href');
      var done = false;
      var finish = function (replay) {
        if (done) return;
        done = true;
        window.__najdorfCalReplay = false;
        if (replay) btn.click();
        else if (href) window.open(href, '_blank', 'noopener');
      };
      if (window.customElements && window.customElements.whenDefined) {
        window.customElements.whenDefined('cal-modal-box').then(function () {
          finish(true);
        });
      }
      // Fallback if the embed never registers in time.
      setTimeout(function () {
        finish(false);
      }, 2500);
    });

    document.addEventListener('click', function (e) {
      var regionBtn = e.target.closest && e.target.closest('[data-region]');
      if (regionBtn) {
        var rs = regionBtn.closest('[data-booking]');
        if (rs) najdorfShowRegion(rs, regionBtn);
        return;
      }
      var methodBtn = e.target.closest && e.target.closest('[data-method-btn]');
      if (methodBtn) {
        var ms = methodBtn.closest('[data-booking]');
        if (ms) najdorfShowMethod(ms, methodBtn.getAttribute('data-method-btn'));
        return;
      }
    });

    document.addEventListener('change', function (e) {
      if (e.target.closest && e.target.closest('#coach-filters')) najdorfApplyFilters();
    });

    // Smooth-scroll in-page anchors (hero CTA, "View sessions"), honoring
    // reduced-motion. Acts only when the target exists on the page.
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a[href^="#"]');
      if (!a) return;
      var id = a.getAttribute('href').slice(1);
      if (!id) return;
      var target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
      if (history.replaceState) history.replaceState(null, '', '#' + id);
    });

    document.addEventListener('astro:page-load', najdorfCoachingSetup);
  }

  najdorfCoachingSetup();
</script>

<style>
  /* FAQ accordion chrome. Native <details>, zero JS. */
  .coaching-faq summary::-webkit-details-marker {
    display: none;
  }
  .coaching-faq__chevron {
    transition: transform 0.2s ease-out;
  }
  .coaching-faq[open] .coaching-faq__chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .coaching-faq__chevron {
      transition: none;
    }
  }
</style>
