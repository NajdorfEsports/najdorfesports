---
/**
 * Press / Media kit page body. Rendered at /press/ and the two localized
 * mirrors. The page is built but kept DORMANT (unlinked, noindex, excluded
 * from the sitemap) until the owner is ready to surface it.
 *
 * Logo pack = direct download links to the real files already in the repo
 * (PNG rasters + the two SVG vectors). No fabricated assets. The fact sheet is
 * generated from live site data so it never goes stale. Bios are role-only.
 */
import { site, competedAsFor } from '../../data/site';
import { loadRoster, loadMatches, loadAchievements } from '../../data/loaders';
import { recordOf } from '../../lib/matches';
import { getLocale, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);

// --- Downloadable logo pack (existing repo files only) ---------------------
const logoFiles = [
  { label: 'Full logo · PNG', href: '/branding/najdorf-esports-logo.png' },
  { label: 'Bishop mark · PNG', href: '/branding/bishop-logo.png' },
  { label: 'Bishop mark (white) · PNG', href: '/branding/bishop-logo-dark.png' },
  { label: 'Bishop mark · SVG', href: '/branding/logo-mark.svg' },
  { label: 'Wordmark · SVG', href: '/branding/wordmark.svg' },
];

// Brand colors mirror src/styles/tokens.css (--color-accent / --color-accent-2)
// and the BaseLayout theme-color.
const brandColors = [
  { label: t.press.colorPrimary, hex: '#215BFF' },
  { label: t.press.colorSecondary, hex: '#6B8DFF' },
  { label: t.press.colorBackground, hex: '#0B0B0F' },
];

// --- Fact sheet (data-driven) ----------------------------------------------
const roster = loadRoster().filter((p) => p.status !== 'inactive');
const PLAYER_ROLES = new Set(['Tank', 'DPS', 'Support', 'Flex']);
const playerHandles = roster.filter((p) => PLAYER_ROLES.has(p.role)).map((p) => p.handle);
const coachHandles = roster.filter((p) => p.role === 'Coach').map((p) => p.handle);
const rosterValue =
  coachHandles.length > 0
    ? `${playerHandles.join(', ')} (${t.roles.Coach}: ${coachHandles.join(', ')})`
    : playerHandles.join(', ');

const topAch = [...loadAchievements()].sort((a, b) => +new Date(b.date) - +new Date(a.date))[0];
const achTag = topAch ? competedAsFor(topAch.event) : null;

const stage2Played = loadMatches().filter(
  (m) => /Stage 2/.test(m.tournament) && (m.result === 'win' || m.result === 'loss'),
);
const { wins: s2w, losses: s2l } = recordOf(stage2Played);

const results: string[] = [];
if (topAch) {
  results.push(`${topAch.placement}, ${topAch.event}${achTag ? ` (${t.competedAs(achTag)})` : ''}`);
}
if (stage2Played.length > 0) {
  results.push(`OWCS Pacific 2026 · Stage 2: ${t.matches.record(s2w, s2l)}`);
}

const facts: Array<{ label: string; value: string }> = [
  { label: t.press.factOrg, value: site.name },
  { label: t.press.factFounded, value: String(site.yearFounded) },
  { label: t.press.factRegion, value: 'OWCS Pacific' },
  { label: t.press.factGame, value: 'Overwatch 2' },
  { label: t.press.factRoster, value: rosterValue },
];
---

<section class="mx-auto max-w-3xl px-4 sm:px-6 pt-12 pb-16">
  <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">{t.press.eyebrow}</p>
  <h1 class="font-display text-4xl sm:text-5xl mt-2 tracking-wide">{t.press.title}</h1>
  <p class="text-lg text-[var(--color-text)] mt-6 leading-relaxed">
    {t.press.intro}{' '}
    <Fragment set:html={'<!--email_off-->'} />
    <a
      href={`mailto:${site.contactEmail}`}
      class="text-[var(--color-accent-2)] hover:text-[var(--color-accent)] underline underline-offset-4"
      >{site.contactEmail}</a
    >
    <Fragment set:html={'<!--/email_off-->'} />.
  </p>

  {/* Brand assets */}
  <section class="mt-12">
    <h2 class="font-display text-2xl tracking-wide">{t.press.assetsHeading}</h2>
    <p class="text-sm text-[var(--color-text-dim)] mt-2 leading-relaxed">{t.press.assetsNote}</p>

    <h3 class="text-[0.7rem] uppercase tracking-[0.25em] text-[var(--color-accent-2)] mt-6">
      {t.press.downloadHeading}
    </h3>
    <ul class="mt-3 grid gap-3 sm:grid-cols-2" role="list">
      {
        logoFiles.map((f) => (
          <li>
            <a
              href={f.href}
              download
              class="flex items-center justify-between gap-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md px-4 py-3 text-sm hover:border-[var(--color-accent-2)] transition-colors"
            >
              <span>{f.label}</span>
              <span class="text-[var(--color-accent-2)]" aria-hidden="true">
                ↓
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <h3 class="text-[0.7rem] uppercase tracking-[0.25em] text-[var(--color-accent-2)] mt-8">
      {t.press.colorsHeading}
    </h3>
    <ul class="mt-3 flex flex-wrap gap-4" role="list">
      {
        brandColors.map((c) => (
          <li class="flex items-center gap-3">
            <span
              class="inline-block w-9 h-9 rounded-md border border-[var(--color-border)]"
              style={`background:${c.hex};`}
              aria-hidden="true"
            />
            <span class="text-sm">
              <span class="block text-[var(--color-text-dim)] text-xs uppercase tracking-wider">
                {c.label}
              </span>
              <span class="font-display tracking-wide tabular-nums">{c.hex}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </section>

  {/* Fact sheet */}
  <section class="mt-12">
    <h2 class="font-display text-2xl tracking-wide">{t.press.factHeading}</h2>
    <dl class="mt-4 divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
      {
        facts.map((f) => (
          <div class="grid grid-cols-[8rem_1fr] gap-4 py-3">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-text-dim)] pt-0.5">
              {f.label}
            </dt>
            <dd class="text-[var(--color-text)]">{f.value}</dd>
          </div>
        ))
      }
      {
        results.length > 0 && (
          <div class="grid grid-cols-[8rem_1fr] gap-4 py-3">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-text-dim)] pt-0.5">
              {t.press.factResults}
            </dt>
            <dd class="text-[var(--color-text)] space-y-1">
              {results.map((r) => (
                <p>{r}</p>
              ))}
            </dd>
          </div>
        )
      }
    </dl>
  </section>

  {/* Team (role-only bios, never a name) */}
  <section class="mt-12">
    <h2 class="font-display text-2xl tracking-wide">{t.press.teamHeading}</h2>
    <div class="mt-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-5">
      <p class="font-display text-lg tracking-wide text-[var(--color-accent-2)]">
        {t.press.ownerRole}
      </p>
      <p class="text-sm text-[var(--color-text-dim)] mt-2 leading-relaxed">{t.press.ownerBody}</p>
    </div>
  </section>

  {/* Fair use of marks */}
  <section class="mt-12">
    <h2 class="font-display text-2xl tracking-wide">{t.press.marksHeading}</h2>
    <p class="text-[var(--color-text-dim)] mt-2 leading-relaxed">{t.press.marksBody}</p>
  </section>
</section>
