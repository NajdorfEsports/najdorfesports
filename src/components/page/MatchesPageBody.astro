---
/**
 * Shared body for the /matches pages (en + zh-TW + zh-CN). Locale-aware:
 * tournament headings run through translateTournament and records/labels
 * through the i18n dict. The thin page wrappers supply BaseLayout (title,
 * description, JSON-LD); this renders the ticker, schedule header, upcoming
 * list, past results grouped by tournament, and the Liquipedia attribution.
 */
import MatchCard from '../match/MatchCard.astro';
import MatchEmptyState from '../match/EmptyState.astro';
import MatchTicker from '../match/MatchTicker.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import { owcs, competedAsFor, type MatchEntry } from '../../data/site';
import { loadMatches } from '../../data/loaders';
import { splitMatches, recordOf } from '../../lib/matches';
import { getLocale, useT } from '../../i18n';
import { translateTournament } from '../../i18n/format';

const locale = getLocale(Astro);
const t = useT(locale);

const allMatches = loadMatches();

// Bucketing + records come from src/lib/matches.ts (unit tested). The
// past list keeps unscored matches in their tournament sections, where
// MatchCard renders them as a neutral TBD; records count finals only.
const { upcoming, past, completed } = splitMatches(allMatches, Date.now());

// Recent form: the last five decided series as W/L pills, newest first, for an
// at-a-glance read of how the team is trending. Drawn-only matches are skipped.
const recentForm = completed.filter((m) => m.result === 'win' || m.result === 'loss').slice(0, 5);

// Group past matches by tournament so each stage has its own section.
const pastByTournament = new Map<string, MatchEntry[]>();
for (const m of past) {
  const arr = pastByTournament.get(m.tournament) ?? [];
  arr.push(m);
  pastByTournament.set(m.tournament, arr);
}

const { wins, losses } = recordOf(allMatches);
const hasRecord = wins + losses > 0;

// Precompute the per-tournament sections with translated headings + records.
const pastSections = Array.from(pastByTournament.entries()).map(([tournament, matches]) => {
  const { wins: w, losses: l } = recordOf(matches);
  return {
    heading: translateTournament(tournament, locale),
    record: t.matches.record(w, l),
    competedAs: competedAsFor(tournament),
    matches,
  };
});
---

<MatchTicker matches={allMatches} />

<section class="relative isolate overflow-hidden border-b border-(--color-border)">
  <div class="texture-board" aria-hidden="true"></div>
  <div class="mx-auto max-w-(--max-content) px-4 sm:px-6 pt-12 pb-10">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <p class="eyebrow">{t.matches.eyebrow(owcs.league, owcs.year)}</p>
        <h1 class="font-display text-(length:--text-h1) mt-2 tracking-tight leading-none">
          {t.nav.matches}
        </h1>
      </div>
      {
        (hasRecord || upcoming.length > 0) && (
          <dl class="flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
            {upcoming.length > 0 && (
              <div>
                <dt class="text-(--color-text-dim) uppercase tracking-wider text-[0.65rem]">
                  {t.matches.upcoming}
                </dt>
                <dd class="font-display text-3xl mt-1 leading-none tabular-nums">
                  {upcoming.length}
                </dd>
              </div>
            )}
            {hasRecord && (
              <div>
                <dt class="text-(--color-text-dim) uppercase tracking-wider text-[0.65rem]">
                  {t.matches.recordLabel}
                </dt>
                {/* Wins in the ticker's brand blue, losses in the loss
                    red: the owner wants the record to read like the old
                    scrolling strip. */}
                <dd class="font-display text-3xl mt-1 leading-none tabular-nums">
                  <span class="text-(--color-accent-2)">{t.matches.recordWins(wins)}</span>
                  <span class="text-(--color-text-dim)">{t.matches.recordJoin}</span>
                  <span class="text-(--color-loss)">{t.matches.recordLosses(losses)}</span>
                </dd>
              </div>
            )}
            {recentForm.length > 0 && (
              <div>
                <dt class="text-(--color-text-dim) uppercase tracking-wider text-[0.65rem]">
                  {t.matches.formLabel}
                </dt>
                <dd
                  class="mt-1.5 flex items-center gap-1.5"
                  aria-label={recentForm
                    .map((m) => (m.result === 'win' ? t.match.win : t.match.loss))
                    .join(' ')}
                >
                  {recentForm.map((m) => (
                    <span
                      class:list={[
                        'form-pill',
                        m.result === 'win' ? 'form-pill--w' : 'form-pill--l',
                      ]}
                      aria-hidden="true"
                    >
                      {m.result === 'win' ? t.match.win : t.match.loss}
                    </span>
                  ))}
                </dd>
              </div>
            )}
          </dl>
        )
      }
    </div>
  </div>
</section>

<style>
  /* Recent-form pills in the schedule header: W in brand blue, L in loss red,
     matching the split record above. */
  .form-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 0.25rem;
    border: 1px solid;
    font-family: var(--font-display);
    font-size: 0.8rem;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .form-pill--w {
    color: var(--color-accent-2);
    border-color: color-mix(in oklab, var(--color-accent-2) 50%, transparent);
  }
  .form-pill--l {
    color: var(--color-loss);
    border-color: color-mix(in oklab, var(--color-loss) 45%, transparent);
  }
</style>

<section class="reveal mx-auto max-w-(--max-content) px-4 sm:px-6 mt-10">
  <SectionHeader heading={t.matches.upcoming}>
    <span class="text-xs uppercase tracking-wider text-(--color-text-dim) tabular-nums">
      {upcoming.length}
    </span>
  </SectionHeader>
  {
    upcoming.length > 0 ? (
      <div class="space-y-3 mt-6">
        {upcoming.map((m, i) => (
          <MatchCard match={m} index={i} />
        ))}
      </div>
    ) : (
      <div class="mt-6">
        <MatchEmptyState variant="upcoming" />
      </div>
    )
  }
</section>

{
  past.length > 0 ? (
    pastSections.map((sec) => (
      <section class="reveal mx-auto max-w-(--max-content) px-4 sm:px-6 mt-12">
        <SectionHeader heading={sec.heading}>
          <span class="flex items-center gap-3">
            {sec.competedAs && (
              <span class="text-[0.7rem] uppercase tracking-wider text-(--color-accent-2) border border-(--color-border) rounded-full px-2 py-0.5">
                {t.competedAs(sec.competedAs)}
              </span>
            )}
            <span class="text-xs uppercase tracking-wider text-(--color-text-dim) tabular-nums">
              {sec.record}
            </span>
          </span>
        </SectionHeader>
        <div class="space-y-3 mt-6">
          {/* Past sections sit below the fold; every backdrop lazy-loads. */}
          {sec.matches.map((m, i) => (
            <MatchCard match={m} index={upcoming.length + i} />
          ))}
        </div>
      </section>
    ))
  ) : (
    <section class="reveal mx-auto max-w-(--max-content) px-4 sm:px-6 mt-12">
      <SectionHeader heading={t.matches.pastResults} />
      <div class="mt-6">
        <MatchEmptyState variant="past" />
      </div>
    </section>
  )
}

<section
  class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-16 text-xs text-[var(--color-text-dim)]"
>
  <p>
    {t.matches.attribution.before}<a
      href="https://liquipedia.net/overwatch/"
      target="_blank"
      rel="noopener"
      class="link-slide text-[var(--color-accent-2)]">Liquipedia</a
    >{t.matches.attribution.between}<a
      href="https://creativecommons.org/licenses/by-sa/3.0/"
      target="_blank"
      rel="noopener"
      class="link-slide text-[var(--color-accent-2)]">CC BY-SA 3.0</a
    >{t.matches.attribution.after}
  </p>
</section>
