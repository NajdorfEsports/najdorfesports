---
/**
 * OWdle, the daily hero-guessing game (/games/owdle/), shared by all
 * three locales.
 *
 * Same architecture as the crossword: everything that can be
 * server-rendered is (heading, board header, legend, stats skeleton,
 * how-to, disclaimer), all localized through useT. The engine
 * (src/scripts/owdle.ts, a processed module, CSP-clean) carries the hero
 * dataset in its bundle, so the page makes zero runtime requests.
 *
 * No-JS doctrine: the fallback notice and the how-to copy are visible by
 * default; the interactive shell starts [hidden] and is revealed BY the
 * engine once it boots (the crossword's inverse-reveal pattern).
 *
 * IP posture (Tier 1, owner-approved): hero names and factual attributes
 * only, no Blizzard art, audio, or prose; the required non-affiliation
 * disclaimer renders at the bottom of the page in every locale.
 */
import SectionHeader from '../ui/SectionHeader.astro';
import { getLocale, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);
const c = t.games.owdle;
const isZh = locale !== 'en';

// Strings the engine needs at runtime (templates use {placeholders}).
const l10n = {
  unknownHero: c.unknownHero,
  shareLabel: c.shareLabel,
  shareCopied: c.shareCopied,
  winBody: c.winBody('{hero}', '{count}'),
  winBodyOne: c.winBodyOne('{hero}'),
  stateExact: c.legendExact,
  statePartial: c.legendPartial,
  stateMiss: c.legendMiss,
  dirHigher: c.legendHigher,
  dirLower: c.legendLower,
  roleValues: c.roleValues,
  subRoleValues: c.subRoleValues,
  genderValues: c.genderValues,
  attackValues: c.attackValues,
  cols: {
    role: c.colRole,
    subRole: c.colSubRole,
    gender: c.colGender,
    nationality: c.colOrigin,
    baseHp: c.colHp,
    attackType: c.colAttack,
    releaseYear: c.colYear,
  },
};

const HEADER_COLS = [
  c.colHero,
  c.colRole,
  c.colSubRole,
  c.colGender,
  c.colOrigin,
  c.colHp,
  c.colAttack,
  c.colYear,
];

const LEGEND = [
  { cls: 'is-exact', glyph: '✓', label: c.legendExact },
  { cls: 'is-partial', glyph: '~', label: c.legendPartial },
  { cls: 'is-miss', glyph: '✕', label: c.legendMiss },
  { cls: 'is-dir', glyph: '↑', label: c.legendHigher },
  { cls: 'is-dir', glyph: '↓', label: c.legendLower },
];
---

<section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pt-10 pb-16">
  <SectionHeader heading={c.heading} eyebrow={c.eyebrow} level="h1" />
  <p class="mt-4 max-w-2xl text-[var(--color-text-dim)]">{c.intro}</p>
  {
    isZh && (
      <p class="mt-2 max-w-2xl text-sm text-[var(--color-accent-2)]" data-zh-notice>
        {c.zhValuesNotice}
      </p>
    )
  }

  <div id="owdle-app" data-l10n={JSON.stringify(l10n)}>
    {
      /* Visible whenever the engine has not (yet) booted: no-JS or a
        blocked script. The engine hides it on success. */
    }
    <div
      class="mt-8 max-w-2xl rounded border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-sm text-[var(--color-text-dim)]"
      data-ow-fallback
    >
      {c.noJsNotice}
    </div>

    <div class="mt-8" hidden data-ow-ui>
      <div
        class="flex flex-wrap items-center justify-between gap-4 text-sm text-[var(--color-text-dim)] tabular-nums"
      >
        <span>
          {c.puzzleLabel}
          <span data-ow-number>#</span>
        </span>
        <span>
          {c.nextHeroLabel}: <span data-ow-countdown>--:--:--</span>
        </span>
      </div>

      <form class="mt-4 max-w-md" data-ow-form>
        <label class="block text-sm font-medium" for="ow-guess-input">{c.inputLabel}</label>
        <div class="relative mt-2">
          <div class="flex gap-2">
            <input
              id="ow-guess-input"
              class="ow-input"
              type="text"
              autocomplete="off"
              autocapitalize="off"
              spellcheck="false"
              placeholder={c.inputPlaceholder}
              role="combobox"
              aria-expanded="false"
              aria-controls="ow-suggestions"
              aria-autocomplete="list"
            />
            <button type="submit" class="ow-btn">{c.guessButton}</button>
          </div>
          <ul
            id="ow-suggestions"
            class="ow-suggestions"
            role="listbox"
            aria-label={c.suggestionsLabel}
            hidden
            data-ow-suggestions
          >
          </ul>
        </div>
        <p class="mt-2 min-h-5 text-sm text-[var(--color-loss)]" aria-live="polite" data-ow-error>
        </p>
      </form>

      <div
        class="mt-4 rounded border border-[var(--color-accent)]/50 bg-[var(--color-surface)] p-4"
        hidden
        data-ow-complete
      >
        <p class="font-display text-xl tracking-wide text-[var(--color-accent-2)]">
          {c.winHeading}
        </p>
        <p class="mt-1 text-sm text-[var(--color-text-dim)]" data-ow-complete-body></p>
        <button type="button" class="ow-btn mt-3" data-ow-share>{c.shareLabel}</button>
      </div>

      <div class="mt-3 flex justify-end">
        <button type="button" class="ow-btn" aria-pressed="false" data-ow-fit>{c.fitToggle}</button>
      </div>

      <div
        class="ow-board-wrap mt-2"
        tabindex="0"
        role="region"
        aria-label={c.ariaBoard}
        data-ow-board-wrap
      >
        <div class="ow-board" role="table" aria-label={c.ariaBoard} data-ow-board>
          <div class="ow-row ow-head" role="row">
            {
              HEADER_COLS.map((label) => (
                <div class="ow-cell ow-head-cell" role="columnheader">
                  {label}
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <section class="mt-6 max-w-2xl">
        <h2 class="font-display text-lg tracking-wide">{c.legendHeading}</h2>
        <ul class="mt-2 grid gap-1.5 text-sm text-[var(--color-text-dim)] sm:grid-cols-2">
          {
            LEGEND.map((item) => (
              <li class="flex items-center gap-2">
                <span class={`ow-chip ${item.cls}`} aria-hidden="true">
                  {item.glyph}
                </span>
                {item.label}
              </li>
            ))
          }
        </ul>
      </section>

      <section
        class="mt-8 max-w-2xl rounded border border-[var(--color-border)] bg-[var(--color-surface)] p-4"
      >
        <h2 class="font-display text-lg tracking-wide">{c.statsHeading}</h2>
        <dl class="mt-3 grid grid-cols-2 gap-3 text-sm sm:grid-cols-4">
          <div>
            <dt class="text-[var(--color-text-dim)]">{c.statsPlayed}</dt>
            <dd class="mt-0.5 text-lg font-semibold tabular-nums" data-stat="played">0</dd>
          </div>
          <div>
            <dt class="text-[var(--color-text-dim)]">{c.statsWon}</dt>
            <dd class="mt-0.5 text-lg font-semibold tabular-nums" data-stat="won">0</dd>
          </div>
          <div>
            <dt class="text-[var(--color-text-dim)]">{c.statsStreak}</dt>
            <dd class="mt-0.5 text-lg font-semibold tabular-nums" data-stat="currentStreak">0</dd>
          </div>
          <div>
            <dt class="text-[var(--color-text-dim)]">{c.statsMaxStreak}</dt>
            <dd class="mt-0.5 text-lg font-semibold tabular-nums" data-stat="maxStreak">0</dd>
          </div>
        </dl>
        <h3 class="mt-4 text-sm font-medium">{c.distHeading}</h3>
        <ol class="mt-2 space-y-1 text-xs" data-ow-dist></ol>
        <p class="mt-3 text-sm text-[var(--color-text-dim)]" hidden data-ow-yesterday>
          {c.yesterdayLabel}: <span class="font-semibold" data-ow-yesterday-name></span>
        </p>
        <p class="mt-3 text-xs text-[var(--color-text-dim)]">{c.statsNote}</p>
      </section>
    </div>
  </div>

  <section class="mt-12 max-w-2xl">
    <h2 class="font-display text-xl tracking-wide">{c.howToHeading}</h2>
    <ul class="mt-3 space-y-2 text-sm leading-relaxed text-[var(--color-text-dim)]">
      <li>{c.howTo1}</li>
      <li>{c.howTo2}</li>
      <li>{c.howTo3}</li>
      <li>{c.howTo4}</li>
    </ul>
  </section>

  <footer class="mt-12 max-w-2xl border-t border-[var(--color-border)] pt-4">
    <p class="text-xs leading-relaxed text-[var(--color-text-dim)]">{c.disclaimer}</p>
    <p class="mt-2 text-xs text-[var(--color-text-dim)]">{c.dataCredit}</p>
  </footer>
</section>

<style>
  .ow-input {
    flex: 1 1 auto;
    min-width: 0;
    min-height: 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-surface);
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    color: var(--color-text);
    transition:
      border-color 150ms ease-out,
      box-shadow 200ms ease-out;
  }
  .ow-input:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-accent) 25%, transparent);
  }
  /* Unknown-hero flash: color-only, decays back to the natural state (the
     global reduced-motion net collapses it to a single frame). */
  .ow-input.is-error {
    animation: ow-input-flash 600ms ease-out;
  }
  @keyframes ow-input-flash {
    from {
      border-color: var(--color-loss);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-loss) 25%, transparent);
    }
  }

  .ow-btn {
    display: inline-block;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.5rem 0.875rem;
    min-height: 2.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-dim);
    cursor: pointer;
    transition:
      color 120ms ease-out,
      border-color 120ms ease-out,
      transform 0.2s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ow-btn:hover {
    color: var(--color-text);
    border-color: var(--color-accent-2);
    transform: translateY(-1px);
    box-shadow: 0 8px 18px -10px color-mix(in oklab, var(--color-accent) 60%, transparent);
  }
  .ow-btn:active {
    transform: translateY(0);
    transition-duration: 50ms;
  }
  .ow-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
    transform: none;
    box-shadow: none;
  }
  .ow-btn[aria-pressed='true'] {
    border-color: var(--color-accent);
    color: var(--color-accent-2);
  }
  .ow-btn.is-copied {
    border-color: var(--color-win);
    color: var(--color-win);
  }
  @media (prefers-reduced-motion: no-preference) {
    .ow-btn.is-copied {
      animation: ow-copied-pop 300ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes ow-copied-pop {
      40% {
        transform: scale(1.05);
      }
    }
  }

  .ow-suggestions {
    position: absolute;
    z-index: 20;
    margin-top: 0.25rem;
    width: 100%;
    max-height: 16rem;
    overflow-y: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.25rem;
    background: color-mix(in srgb, var(--color-surface-2) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: var(--shadow-card);
  }
  .ow-suggestions :global(.ow-suggestion) {
    display: block;
    width: 100%;
    min-height: 2.75rem;
    padding: 0.625rem 0.75rem;
    font-size: 0.9375rem;
    text-align: left;
    color: var(--color-text-dim);
    cursor: pointer;
    border-radius: 0.375rem;
    transition:
      background-color 120ms ease-out,
      color 120ms ease-out,
      box-shadow 120ms ease-out;
  }
  /* The engine marks the keyboard-active option on the li (where
     aria-activedescendant points), so match the button through it. */
  .ow-suggestions :global(.ow-suggestion:hover),
  .ow-suggestions :global(li.is-active .ow-suggestion) {
    color: var(--color-text);
    background: color-mix(in oklab, var(--color-accent) 14%, var(--color-surface-2));
    box-shadow: inset 2px 0 0 var(--color-accent);
  }
  /* Cascade only when the menu transitions hidden to shown; narrowing an
     already-open list repaints instantly (the engine drops is-opening). */
  @media (prefers-reduced-motion: no-preference) {
    .ow-suggestions.is-opening {
      animation: ow-menu-in 200ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .ow-suggestions.is-opening :global(li) {
      animation: ow-menu-item 240ms cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: calc(var(--ow-n, 0) * 24ms);
    }
    @keyframes ow-menu-in {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
    }
    @keyframes ow-menu-item {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
    }
  }

  .ow-board-wrap {
    overflow-x: auto;
    /* Flipping cells project a few px of vertical overhang; keep that from
       flashing a vertical scrollbar (the board never scrolls vertically). */
    overflow-y: hidden;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-card);
    -webkit-overflow-scrolling: touch;
  }
  .ow-board-wrap:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .ow-board {
    --ow-cols: minmax(7.5rem, 1.4fr) repeat(7, minmax(5.75rem, 1fr));
    /* Reveal timing, single source of truth: owdle.ts reads these via
       getComputedStyle and parses the unit (the minifier may rewrite
       600ms as .6s). */
    --ow-flip: 600ms;
    --ow-stagger: 100ms;
    --ow-flip-neutral: var(--color-surface-2);
    min-width: 54rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: var(--color-bg);
  }
  .ow-board :global(.ow-row) {
    display: grid;
    grid-template-columns: var(--ow-cols);
    gap: 2px;
  }
  .ow-board :global(.ow-cell) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.125rem;
    min-height: 3.5rem;
    padding: 0.375rem 0.375rem;
    border-radius: 3px;
    background-color: var(--color-surface);
    background-image: linear-gradient(180deg, rgb(255 255 255 / 0.04), transparent 55%);
    font-size: 0.8125rem;
    font-weight: 600;
    text-align: center;
    overflow-wrap: anywhere;
  }
  .ow-board :global(.ow-cell:first-child) {
    position: sticky;
    left: 0;
    z-index: 1;
  }
  /* The pinned name column casts a soft edge over cells scrolling beneath
     it (only when the board can actually scroll, so not in fit mode). */
  .ow-board-wrap:not(.is-fit) :global(.ow-cell:first-child) {
    box-shadow: 6px 0 12px -8px rgb(0 0 0 / 0.6);
  }
  .ow-board :global(.ow-head-cell) {
    min-height: 2.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    background-color: color-mix(in oklab, var(--color-surface) 55%, var(--color-bg));
    background-image: none;
  }
  .ow-board :global(.ow-name) {
    font-weight: 700;
  }
  .ow-board :global(.ow-glyph) {
    font-size: 0.75rem;
    font-weight: 700;
    opacity: 0.9;
  }
  .ow-board :global(.is-exact) {
    --ow-cell-bg: color-mix(in oklab, var(--color-win) 38%, var(--color-surface));
    --ow-cell-glow: var(--color-win);
  }
  .ow-board :global(.is-partial) {
    --ow-cell-bg: color-mix(in oklab, #d97706 40%, var(--color-surface));
    --ow-cell-glow: #d97706;
  }
  .ow-board :global(.is-miss) {
    --ow-cell-bg: color-mix(in oklab, var(--color-loss) 26%, var(--color-surface));
    --ow-cell-glow: var(--color-loss);
  }
  .ow-board :global(.is-exact),
  .ow-board :global(.is-partial),
  .ow-board :global(.is-miss) {
    background-color: var(--ow-cell-bg);
    /* Inset ring so verdict tiles read as lit from within. */
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--ow-cell-glow) 28%, transparent);
  }
  /* Desktop row hover; pointer devices only. */
  @media (hover: hover) {
    .ow-board :global(.ow-row:not(.ow-head) .ow-cell) {
      transition: filter 150ms ease-out;
    }
    .ow-board :global(.ow-row:not(.ow-head):hover .ow-cell) {
      filter: brightness(1.07);
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    /* Name cell: opacity-only fade. It is the sticky column; transforms on
       sticky elements invite compositing surprises, and it has no verdict
       to reveal anyway. */
    .ow-board :global(.ow-row.is-new .ow-cell:first-child) {
      animation: ow-name-in 360ms ease-out both;
    }
    /* Attribute cells: card flip. The neutral face accelerates edge-on,
       then the verdict face snaps open on the site expo-out curve; the
       background swaps inside the 50-51% window while the cell is edge-on,
       so the color change itself is never visible. Per-cell perspective
       keeps every flip axis-symmetric regardless of horizontal scroll, and
       the backwards fill holds delayed cells on the neutral face. */
    .ow-board :global(.ow-row.is-new .ow-cell:not(:first-child)) {
      animation: ow-flip var(--ow-flip) both;
      animation-delay: calc(var(--ow-i, 0) * var(--ow-stagger));
    }
    /* The verdict glyph pops in exactly at each cell's flip midpoint. */
    .ow-board :global(.ow-row.is-new .ow-cell:not(:first-child) .ow-glyph) {
      animation: ow-glyph-in 280ms cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: calc(var(--ow-i, 0) * var(--ow-stagger) + var(--ow-flip) / 2);
    }
    /* Winning row: each cell glows once right after its flip lands. The
       pulse animates box-shadow and brightness only, never transform, so
       it cannot fight the flip; every keyframe carries the resting inset
       ring so it never flickers off. */
    .ow-board :global(.ow-row.is-new.is-win .ow-cell:not(:first-child)) {
      animation:
        ow-flip var(--ow-flip) both,
        ow-win-pulse 700ms ease-out;
      animation-delay:
        calc(var(--ow-i, 0) * var(--ow-stagger)),
        calc(var(--ow-i, 0) * var(--ow-stagger) + var(--ow-flip) + 80ms);
    }
    @keyframes ow-name-in {
      from {
        opacity: 0;
      }
    }
    @keyframes ow-flip {
      0% {
        transform: perspective(40rem) rotateX(0deg);
        background-color: var(--ow-flip-neutral);
        animation-timing-function: cubic-bezier(0.55, 0.08, 0.7, 0.3);
      }
      50% {
        transform: perspective(40rem) rotateX(-90deg);
        background-color: var(--ow-flip-neutral);
        animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
      }
      51% {
        background-color: var(--ow-cell-bg);
      }
      100% {
        transform: perspective(40rem) rotateX(0deg);
        background-color: var(--ow-cell-bg);
      }
    }
    @keyframes ow-glyph-in {
      from {
        opacity: 0;
        transform: scale(0.4);
      }
    }
    @keyframes ow-win-pulse {
      0%,
      100% {
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--ow-cell-glow) 28%, transparent);
        filter: brightness(1);
      }
      40% {
        box-shadow:
          inset 0 0 0 1px color-mix(in oklab, var(--ow-cell-glow) 28%, transparent),
          0 0 16px 0 color-mix(in oklab, var(--color-win) 50%, transparent);
        filter: brightness(1.3);
      }
    }
  }

  /* Fit-to-screen mode: compress the grid into the viewport width. */
  .ow-board-wrap.is-fit {
    overflow-x: hidden;
  }
  .ow-board-wrap.is-fit .ow-board {
    min-width: 100%;
    --ow-cols: minmax(2.5rem, 1.3fr) repeat(7, minmax(1.5rem, 1fr));
  }
  .ow-board-wrap.is-fit :global(.ow-cell) {
    font-size: 0.5625rem;
    padding: 0.25rem 0.125rem;
    min-height: 2.75rem;
  }
  .ow-board-wrap.is-fit :global(.ow-head-cell) {
    font-size: 0.5rem;
  }

  /* Win box entrance: the box settles in, then its children rise in a mini
     cascade. The engine only adds is-celebrate on the non-reduced-motion
     path (the global net zeroes durations but not delays, so a delayed
     both-fill animation must never run under reduce). */
  @media (prefers-reduced-motion: no-preference) {
    [data-ow-complete].is-celebrate {
      animation: ow-box-in 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    [data-ow-complete].is-celebrate > * {
      animation: ow-rise 450ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    [data-ow-complete].is-celebrate > :nth-child(1) {
      animation-delay: 60ms;
    }
    [data-ow-complete].is-celebrate > :nth-child(2) {
      animation-delay: 140ms;
    }
    [data-ow-complete].is-celebrate > :nth-child(3) {
      animation-delay: 220ms;
    }
    @keyframes ow-box-in {
      from {
        opacity: 0;
        transform: translateY(6px) scale(0.98);
      }
    }
    @keyframes ow-rise {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    [data-ow-error].is-shake {
      animation: ow-shake 320ms ease-in-out;
    }
    @keyframes ow-shake {
      20% {
        transform: translateX(-4px);
      }
      40% {
        transform: translateX(4px);
      }
      60% {
        transform: translateX(-3px);
      }
      80% {
        transform: translateX(2px);
      }
    }
  }

  .ow-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--color-surface-2);
    flex-shrink: 0;
  }
  .ow-chip.is-exact {
