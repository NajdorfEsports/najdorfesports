---
/**
 * Cal.com popup trigger, styled to match Button.astro (primary / secondary).
 *
 * Button.astro has no arbitrary-attribute passthrough, so this dedicated
 * component carries the `data-cal-*` attributes the embed binds to on click.
 * The page's single Cal init script (in CoachingPageBody) wires every button;
 * `data-cal-config` forces the booker into dark theme regardless of the
 * visitor's system setting.
 */
interface Props {
  /** Cal.com event link "account/event-slug". */
  calLink: string;
  label: string;
  ariaLabel?: string;
  variant?: 'primary' | 'secondary';
}
const { calLink, label, ariaLabel, variant = 'primary' } = Astro.props;

const calConfig = JSON.stringify({ theme: 'dark' });

// Mirrors Button.astro's class tokens (md size) so the two read identically,
// plus w-full so the button fills the offering card footer.
const base =
  'btn-lift inline-flex w-full items-center justify-center font-semibold uppercase tracking-wider rounded-sm px-5 py-2.5 text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]';
const variants = {
  primary: 'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent)]/90',
  secondary:
    'bg-transparent border border-[var(--color-accent-2)] text-[var(--color-accent-2)] hover:bg-[var(--color-accent-2)] hover:text-[var(--color-bg)]',
}[variant];
---

<button
  type="button"
  class={`${base} ${variants}`}
  data-cal-link={calLink}
  data-cal-config={calConfig}
  aria-label={ariaLabel ?? label}
>
  {label}
</button>
