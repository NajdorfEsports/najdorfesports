---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  /** Opt-in cursor-magnet behaviour for hero CTAs. Driven by an inline
   *  script that listens for pointermove and writes --mx / --my CSS vars.
   *  Touch / coarse-pointer / reduced-motion users get only static :hover. */
  magnet?: boolean;
}

const { href, variant = 'primary', size = 'md', external = false, magnet = false } = Astro.props;

const base =
  'btn-lift inline-flex items-center justify-center font-semibold uppercase tracking-wider rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]';

const sizes = {
  sm: 'px-3 py-1.5 text-xs',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3 text-base',
}[size];

const variants = {
  primary:
    'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent)]/90',
  secondary:
    'bg-transparent border border-[var(--color-accent-2)] text-[var(--color-accent-2)] hover:bg-[var(--color-accent-2)] hover:text-[var(--color-bg)]',
  ghost:
    'bg-[var(--color-surface-2)] text-[var(--color-text)] hover:bg-[var(--color-surface)]',
}[variant];

const cls = `${base} ${sizes} ${variants}${magnet ? ' magnet' : ''}`;
const magnetAttr = magnet ? { 'data-magnet': '' } : {};
---
{href ? (
  <a
    href={href}
    class={cls}
    {...magnetAttr}
    {...external ? { target: '_blank', rel: 'noopener' } : {}}
  >
    <slot />
  </a>
) : (
  <button type="button" class={cls} {...magnetAttr}><slot /></button>
)}
