---
import { owcs } from '../../data/site';
import { formatDate } from '../../i18n/format';

interface Props {
  variant?: 'upcoming' | 'past';
}
const { variant = 'upcoming' } = Astro.props;

const startPretty = formatDate(owcs.mainEventStart, 'en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const messages = {
  upcoming: `No upcoming matches yet. ${owcs.league} ${owcs.stage} main event begins ${startPretty}.`,
  past: `No completed matches yet. ${owcs.stage} results will appear here once the main event begins.`,
};
---
<div class="border border-dashed border-[var(--color-border)] rounded-md p-8 text-center text-[var(--color-text-dim)]">
  <p class="text-sm sm:text-base">{messages[variant]}</p>
</div>
