---
import type { MatchEntry } from '../../data/site';
import { getLocale, useT } from '../../i18n';
import { formatDate, translateTournament, MATCH_TIME_ZONE } from '../../i18n/format';

/**
 * Season strip under the header. STATIC, not a marquee: the old CSS loop
 * fought the motion language (nothing loops) and kept stamping later LCP
 * entries as longer items slid into view. The strip now reads left to
 * right as "what's next, then what just happened" (upcoming soonest-first,
 * then results newest-first) and overflows into a natural swipe/scroll.
 */
interface Props {
  matches: ReadonlyArray<MatchEntry>;
  fallback?: string;
}
const locale = getLocale(Astro);
const t = useT(locale);

const { matches, fallback = t.ticker.fallback } = Astro.props;

const now = Date.now();

interface TickerItem {
  key: string;
  label: string;
  variant: 'live' | 'upcoming' | 'win' | 'loss' | 'tbd' | 'neutral';
  href?: string;
}

const upcoming = matches
  .filter((m) => +new Date(m.date) >= now)
  .sort((a, b) => +new Date(a.date) - +new Date(b.date));
const past = matches
  .filter((m) => +new Date(m.date) < now)
  .sort((a, b) => +new Date(b.date) - +new Date(a.date));

const items: TickerItem[] = [];
for (const m of [...upcoming, ...past]) {
  const isPast = +new Date(m.date) < now;
  const dateStr = formatDate(m.date, locale, {
    month: 'short',
    day: 'numeric',
    timeZone: MATCH_TIME_ZONE,
  });
  const tournament = translateTournament(m.tournament, locale);
  const href = m.liquipediaUrl;
  if (!isPast) {
    items.push({
      key: `up-${m.id}`,
      label: t.ticker.upcoming(dateStr, m.opponent, tournament),
      variant: 'upcoming',
      href,
    });
  } else if (m.result === 'win') {
    items.push({
      key: `w-${m.id}`,
      label: t.ticker.win(m.opponent, tournament),
      variant: 'win',
      href,
    });
  } else if (m.result === 'loss') {
    items.push({
      key: `l-${m.id}`,
      label: t.ticker.loss(m.opponent, tournament),
      variant: 'loss',
      href,
    });
  } else {
    items.push({
      key: `tbd-${m.id}`,
      label: t.ticker.tbd(m.opponent, tournament),
      variant: 'tbd',
      href,
    });
  }
}

if (items.length === 0) {
  items.push({ key: 'fallback', label: fallback, variant: 'neutral' });
}
---

<div class="ticker" aria-label={t.ticker.ariaLabel} role="region">
  <ul class="ticker__track">
    {
      items.map((item) => (
        <li class:list={['ticker__item', `ticker__item--${item.variant}`]}>
          {item.href ? (
            <a href={item.href} target="_blank" rel="noopener" class="ticker__link">
              {item.label}
            </a>
          ) : (
            <span>{item.label}</span>
          )}
        </li>
      ))
    }
  </ul>
  <div class="ticker__edge ticker__edge--right" aria-hidden="true"></div>
</div>

<style>
  .ticker {
    position: relative;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .ticker__track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    white-space: nowrap;
    padding: 0.75rem 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    /* Status chrome, not editorial type: 13px uppercase strip text looks
       the same in system faces, so it paints once with zero webfont
       dependency and never repaints (a font-swap repaint here was the
       page's LCP on slow connections). */
    font-family:
      system-ui,
      -apple-system,
      'Segoe UI',
      Roboto,
      'PingFang TC',
      'Microsoft JhengHei',
      'PingFang SC',
      'Microsoft YaHei',
      sans-serif;
  }
  .ticker__track::-webkit-scrollbar {
    display: none;
  }
  @media (min-width: 40rem) {
    .ticker__track {
      padding-inline: 1.5rem;
    }
  }

  .ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-text-dim);
    flex-shrink: 0;
  }

  .ticker__item::before {
    content: '';
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: currentColor;
    flex-shrink: 0;
  }

  .ticker__item--live {
    color: var(--color-accent);
  }
  .ticker__item--live::before {
    background: var(--color-accent);
    box-shadow: 0 0 0 0 var(--color-accent);
    animation: live-pulse 1.6s ease-in-out infinite;
  }
  .ticker__item--upcoming {
    color: var(--color-accent-2);
  }
  .ticker__item--win {
    color: var(--color-win);
  }
  .ticker__item--loss {
    color: var(--color-loss);
  }
  .ticker__item--tbd,
  .ticker__item--neutral {
    color: var(--color-text-dim);
  }

  .ticker__link {
    color: inherit;
    text-decoration: none;
  }
  .ticker__link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Fade the trailing edge so the overflow reads as "more this way". */
  .ticker__edge {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 64px;
    z-index: 1;
    pointer-events: none;
  }
  .ticker__edge--right {
    right: 0;
    background: linear-gradient(to left, var(--color-surface), transparent);
  }

  /* The live dot pulse is a status indicator, not decoration; it still
     respects reduced motion below. */
  @keyframes live-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in oklab, var(--color-accent) 60%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker__item--live::before {
      animation: none;
    }
  }
</style>
