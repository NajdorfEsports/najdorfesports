---
import Badge from '../ui/Badge.astro';
import type { MatchEntry } from '../../data/site';
import { DEFAULT_LOCALE, useT, type Locale } from '../../i18n';
import { formatDate, translateTournament } from '../../i18n/format';

interface Props {
  match: MatchEntry;
}
const { match } = Astro.props;

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);

const date = new Date(match.date);
const weekday = formatDate(date, locale, { weekday: 'short' });
const dayNum = formatDate(date, locale, { day: 'numeric' });
const monthShort = formatDate(date, locale, { month: 'short' });
const timePretty = new Intl.DateTimeFormat(locale, {
  hour: 'numeric',
  minute: '2-digit',
}).format(date);

const resultLabel = match.result === 'win' ? t.match.win : match.result === 'loss' ? t.match.loss : '·';
const aggregate = match.mapScores?.reduce(
  (acc, m) => {
    if (m.ourScore > m.theirScore) acc.ours += 1;
    else if (m.theirScore > m.ourScore) acc.theirs += 1;
    return acc;
  },
  { ours: 0, theirs: 0 },
);
---
<article class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-4 sm:p-5 grid grid-cols-[auto_1fr_auto] gap-4 items-center">
  <div class="text-center w-16">
    <p class="text-xs uppercase tracking-wider text-[var(--color-text-dim)]">
      {weekday}
    </p>
    <p class="font-display text-2xl leading-none mt-1">{dayNum}</p>
    <p class="text-xs uppercase tracking-wider text-[var(--color-text-dim)] mt-1">
      {monthShort}
    </p>
  </div>

  <div class="min-w-0">
    <p class="text-xs uppercase tracking-wider text-[var(--color-accent-2)]">
      {translateTournament(match.tournament, locale)}
    </p>
    <p class="font-display text-xl truncate mt-0.5">
      {t.match.vs(match.opponent)}
    </p>
    <p class="text-xs text-[var(--color-text-dim)] mt-1">
      {timePretty} · {match.format}
      {match.streamUrl && (
        <>
          {' · '}
          <a
            href={match.streamUrl}
            target="_blank"
            rel="noopener"
            class="link-arrow has-glyph text-[var(--color-accent-2)] hover:text-[var(--color-accent)]"
          >
            <span>{t.match.watch}</span>
          </a>
        </>
      )}
    </p>
  </div>

  <div class="text-right">
    {match.result === 'tbd' ? (
      <Badge tone="neutral">{t.match.tbd}</Badge>
    ) : (
      <div class="flex flex-col items-end gap-1">
        <Badge tone={match.result === 'win' ? 'win' : 'loss'}>
          {resultLabel}
        </Badge>
        {aggregate && (
          <p class="font-display text-lg leading-none">
            {aggregate.ours}–{aggregate.theirs}
          </p>
        )}
      </div>
    )}
  </div>
</article>
