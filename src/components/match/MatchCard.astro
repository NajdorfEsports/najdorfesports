---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Badge from '../ui/Badge.astro';
import MapScoreTable from './MapScoreTable.astro';
import type { MatchEntry } from '../../data/site';
import { getLocale, useT } from '../../i18n';
import {
  formatDate,
  formatMatchTime,
  translateTournament,
  MATCH_TIME_ZONE,
} from '../../i18n/format';
import { formatCount } from '../../data/social';
import { seriesScore } from '../../lib/matches';
import { mapImagesByName, mapImagesBySlug } from '../../lib/assetImages';

interface Props {
  match: MatchEntry;
  /** 0-based position in the list. The first cards sit above the fold and
   *  load their backdrops eagerly; everything below lazy-loads. */
  index?: number;
}
const { match, index = 0 } = Astro.props;
const eager = index < 1;

const locale = getLocale(Astro);
const t = useT(locale);

const date = new Date(match.date);
const weekday = formatDate(date, locale, { weekday: 'short', timeZone: MATCH_TIME_ZONE });
const dayNum = formatDate(date, locale, { day: 'numeric', timeZone: MATCH_TIME_ZONE });
const monthShort = formatDate(date, locale, { month: 'short', timeZone: MATCH_TIME_ZONE });
const timePretty = formatMatchTime(date, locale);

const resultLabel =
  match.result === 'win' ? t.match.win : match.result === 'loss' ? t.match.loss : '·';
const aggregate = seriesScore(match);

// Watch-link resolution.
//   Upcoming match  -> streamUrl (live channel) labelled 'Watch'.
//   Past match      -> only render a link if vodUrl points at a specific
//                      saved VOD. Channel-root URLs are NEVER surfaced
//                      for past matches: a "Watch" link that lands on
//                      the live channel (or a stale VOD list) reads as
//                      misleading more than helpful. Owner fills vodUrl
//                      in matches.manual.json as they find direct
//                      Twitch /videos/N or YouTube watch URLs.
const isPast = date.getTime() < Date.now();
const watchUrl = isPast ? match.vodUrl : match.streamUrl;
const watchLabel = isPast ? t.match.watchVod : t.match.watch;

// Backdrop image, in priority order:
//   1. The LAST map of the match (the deciding map) with a known icon.
//      Picking the decider gives matches that share a Control opener
//      (Lijiang / Busan run a lot) different backdrops and ties the
//      artwork to the moment the series was decided.
//   2. Any earlier map in the match with a known icon (walking back).
//   3. A deterministic-random pick from the full pre-fetched map pool,
//      seeded by the match id. Same match -> same backdrop on every
//      page load; different matches -> different picks. Handles
//      upcoming/TBD matches and matches imported before their maps
//      had icons cached.
//
// `lookupMap` falls back to a normalized comparison when a direct key
// hit misses, so casing or punctuation drift in match data ("kings
// row", "King's Row", "King’s Row") still resolves to the canonical
// image. `maps.json` stays keyed by canonical display name (the
// human-edited surface); images flow through astro:assets via the
// name-to-image join in src/lib/assetImages.ts.
const normalizeMapKey = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '');
function lookupMap(name: string | undefined): ImageMetadata | null {
  if (!name) return null;
  if (mapImagesByName[name]) return mapImagesByName[name];
  const target = normalizeMapKey(name);
  if (target.length === 0) return null;
  for (const k of Object.keys(mapImagesByName)) {
    if (normalizeMapKey(k) === target) return mapImagesByName[k] ?? null;
  }
  return null;
}

const heroMap = (match.mapScores ?? [])
  .slice()
  .reverse()
  .map((m) => m.map)
  .find((name) => lookupMap(name));

function hashStr(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i += 1) {
    h = ((h << 5) - h + s.charCodeAt(i)) | 0;
  }
  return Math.abs(h);
}

let backdrop: ImageMetadata | null = heroMap ? lookupMap(heroMap) : null;
if (!backdrop) {
  // Deterministic-random fallback pool keyed off the filesystem glob (not
  // the JSON), so a JSON/file drift can never produce a broken backdrop.
  const pool = Object.values(mapImagesBySlug);
  if (pool.length > 0) {
    backdrop = pool[hashStr(match.id) % pool.length] ?? null;
  }
}
---

<article
  class:list={[
    'match-card relative overflow-hidden isolate bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-4 sm:p-5 grid grid-cols-[auto_1fr_auto] gap-4 items-center',
    backdrop ? 'match-card--has-backdrop' : '',
  ]}
>
  {
    backdrop && (
      <>
        {/* Backdrop art is texture, not content: it sits behind an 80-92%
            scrim, so one 640w candidate (the pre-redesign served 600w for
            this same full-bleed treatment) is plenty at every viewport.
            Native lazy-loading prefetches far ahead on slow connections,
            so per-image bytes are what keep this page's backdrops from
            starving the display font (the LCP). The map art deliberately
            keeps its natural colors: no ink duotone here (owner call,
            2026-06). */}
        <Image
          src={backdrop}
          alt=""
          widths={[640]}
          sizes="640px"
          loading={eager ? 'eager' : 'lazy'}
          decoding="async"
          aria-hidden="true"
          data-map={heroMap}
          class="match-card__backdrop"
        />
        <div class="match-card__overlay" aria-hidden="true" />
      </>
    )
  }

  <div class="match-card__content relative z-10 text-center w-16">
    <p class="text-xs uppercase tracking-wider text-[var(--color-text-dim)]">
      {weekday}
    </p>
    <p class="font-display text-2xl leading-none mt-1">{dayNum}</p>
    <p class="text-xs uppercase tracking-wider text-[var(--color-text-dim)] mt-1">
      {monthShort}
    </p>
  </div>

  <div class="match-card__content relative z-10 min-w-0">
    <p class="text-xs uppercase tracking-wider text-[var(--color-accent-2)]">
      {translateTournament(match.tournament, locale)}
    </p>
    <p class="font-display text-xl truncate mt-0.5">
      {t.match.vs(match.opponent)}
    </p>
    <p class="text-xs text-[var(--color-text-dim)] mt-1">
      {timePretty} · {match.format}
      {
        watchUrl && (
          <>
            {' · '}
            <a
              href={watchUrl}
              target="_blank"
              rel="noopener"
              class="link-arrow has-glyph text-[var(--color-accent-2)] hover:text-[var(--color-accent)]"
            >
              <span>{watchLabel}</span>
            </a>
          </>
        )
      }
    </p>
    {
      match.broadcastPeakViewers && (
        <p
          class="text-[0.7rem] text-[var(--color-text-dim)] mt-1"
          aria-label={`Peak concurrent viewers on the OWCS Pacific broadcast: ${match.broadcastPeakViewers}`}
        >
          {t.match.broadcastPeak(formatCount(match.broadcastPeakViewers))}
        </p>
      )
    }
  </div>

  <div class="match-card__content relative z-10 text-right">
    {
      match.result === 'tbd' ? (
        <Badge tone="neutral">{t.match.tbd}</Badge>
      ) : (
        <div class="flex flex-col items-end gap-1">
          <Badge tone={match.result === 'win' ? 'win' : 'loss'}>{resultLabel}</Badge>
          {aggregate && (
            <p class="font-display text-lg leading-none">
              {aggregate.ours}–{aggregate.theirs}
            </p>
          )}
        </div>
      )
    }
  </div>

  {
    (match.mapScores ?? []).length > 0 && (
      <div class="match-card__content relative z-10 col-span-full">
        <MapScoreTable match={match} />
      </div>
    )
  }
</article>

<style>
  .match-card {
    transition:
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.2s ease-out,
      box-shadow 0.25s ease-out;
  }

  .match-card--has-backdrop:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--color-accent) 60%, var(--color-border));
    box-shadow:
      0 1px 0 0 color-mix(in oklab, var(--color-accent) 35%, transparent),
      0 14px 36px -18px color-mix(in oklab, var(--color-accent) 55%, transparent);
  }

  /* Map backdrop, vertically fills the card. Soft Ken-Burns zoom on hover
   * matches the player card "breathing" effect: subtle, cinematic, not a
   * jarring scale-up. (:global because the img is emitted by <Image>,
   * outside this component's style scope.) */
  .match-card :global(.match-card__backdrop) {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 45%;
    border-radius: inherit;
    transform-origin: 50% 45%;
    transition: transform 800ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
    pointer-events: none;
  }
  .match-card--has-backdrop:hover :global(.match-card__backdrop) {
    transform: scale(1.05);
  }

  /* Dark overlay so text stays readable over the map. Slightly heavier
   * on the left + right edges (where the date pillar and result badge
   * live) so those numbers don't fight the backdrop. */
  .match-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(11, 11, 15, 0.92) 0%,
      rgba(11, 11, 15, 0.74) 18%,
      rgba(11, 11, 15, 0.62) 50%,
      rgba(11, 11, 15, 0.74) 82%,
      rgba(11, 11, 15, 0.92) 100%
    );
    transition: opacity 450ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .match-card--has-backdrop:hover .match-card__overlay {
    opacity: 0.88;
  }

  @media (prefers-reduced-motion: reduce) {
    .match-card,
    .match-card :global(.match-card__backdrop),
    .match-card__overlay {
      transition: none;
    }
    .match-card--has-backdrop:hover {
      transform: none;
    }
    .match-card--has-backdrop:hover :global(.match-card__backdrop) {
      transform: none;
    }
  }
</style>
