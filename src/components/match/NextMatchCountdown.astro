---
import type { MatchEntry } from '../../data/site';
import { getLocale, useT } from '../../i18n';
import { translateTournament } from '../../i18n/format';

interface Props {
  match?: MatchEntry;
}
const { match } = Astro.props;

const locale = getLocale(Astro);
const t = useT(locale);

const countdownLabels = [
  { key: 'days',  label: t.nextMatch.days  },
  { key: 'hours', label: t.nextMatch.hours },
  { key: 'min',   label: t.nextMatch.min   },
  { key: 'sec',   label: t.nextMatch.sec   },
];

const tournament = match ? translateTournament(match.tournament, locale) : '';
---
{match ? (
  <section
    class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-6 sm:p-8"
    aria-label="Next match countdown"
  >
    <p class="text-xs uppercase tracking-wider text-[var(--color-accent-2)]">
      {t.nextMatch.eyebrow(tournament)}
    </p>
    <p class="font-display text-3xl sm:text-4xl mt-2 tracking-wide">
      {t.nextMatch.vs(match.opponent)}
    </p>

    <div
      class="mt-5 grid grid-cols-4 gap-3 max-w-md"
      data-countdown
      data-target={match.date}
    >
      {countdownLabels.map((u, i) => (
        <div class="bg-[var(--color-surface-2)] border border-[var(--color-border)] rounded-sm py-3 text-center">
          <p class="font-display text-2xl sm:text-3xl tabular-nums" data-slot={i}>--</p>
          <p class="text-[0.6rem] uppercase tracking-widest text-[var(--color-text-dim)] mt-1">{u.label}</p>
        </div>
      ))}
    </div>

    {match.streamUrl && (
      <p class="mt-4 text-sm">
        <a href={match.streamUrl} target="_blank" rel="noopener" class="link-arrow has-glyph text-[var(--color-accent-2)] hover:text-[var(--color-accent)] uppercase tracking-wider">
          <span>{t.nextMatch.watchLive}</span>
        </a>
      </p>
    )}
  </section>
) : (
  <section
    class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-6 sm:p-8"
    aria-label="Next match"
  >
    <p class="text-xs uppercase tracking-wider text-[var(--color-accent-2)]">{t.nextMatch.eyebrowEmpty}</p>
    <p class="font-display text-2xl sm:text-3xl mt-2 tracking-wide">
      {t.nextMatch.placeholderHeadline}
    </p>
    <p class="text-[var(--color-text-dim)] text-sm mt-2">
      {t.nextMatch.placeholderBody}
    </p>
  </section>
)}

<script is:inline>
  // Runs on initial load AND on every ClientRouter navigation. Each call
  // tears down the previous interval (if any) before starting a new one,
  // so navigating away from / and back doesn't double-tick.
  (() => {
    let intervalId = null;

    function init() {
      if (intervalId !== null) {
        clearInterval(intervalId);
        intervalId = null;
      }
      const root = document.querySelector('[data-countdown]');
      if (!root) return;
      const target = new Date(root.getAttribute('data-target')).getTime();
      // Bail on an unparseable date so the tick loop never spins on NaN
      // (mirrors the guard in LiveHero.astro).
      if (Number.isNaN(target)) return;
      const slots = root.querySelectorAll('[data-slot]');
      const pad = (n) => String(Math.max(0, n)).padStart(2, '0');

      const tick = () => {
        const diff = target - Date.now();
        if (diff <= 0) {
          slots.forEach((s) => (s.textContent = '00'));
          if (intervalId !== null) {
            clearInterval(intervalId);
            intervalId = null;
          }
          return;
        }
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const mins = Math.floor((diff % 3600000) / 60000);
        const secs = Math.floor((diff % 60000) / 1000);
        slots[0].textContent = String(days);
        slots[1].textContent = pad(hours);
        slots[2].textContent = pad(mins);
        slots[3].textContent = pad(secs);
      };
      tick();
      intervalId = setInterval(tick, 1000);
    }

    init();
    document.addEventListener('astro:page-load', init);
    // Stop the timer when navigating away so it doesn't leak.
    document.addEventListener('astro:before-swap', () => {
      if (intervalId !== null) {
        clearInterval(intervalId);
        intervalId = null;
      }
    });
  })();
</script>
