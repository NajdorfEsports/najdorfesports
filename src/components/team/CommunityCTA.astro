---
/**
 * "Join the community" band. Surfaced near the bottom of the home page
 * as the closing CTA. Pulls from `socials` in src/data/site.ts; any
 * channel with url: 'TODO' is filtered out so partial info never ships.
 * The whole section hides itself when no channels are confirmed yet.
 *
 * Visual language mirrors <WatchHub>: surface cards on the standard
 * border, with a platform-coloured icon chip on the right and a hover
 * lift to accent-2 (gold). Discord and X are the only two platforms
 * the org runs today, keep the icon switch small and explicit; add a
 * new branch when (if) a third channel ships.
 */
import { socials, confirmed } from '../../data/site';
import { getLocale, useT } from '../../i18n';
import PlatformIcon from '../ui/PlatformIcon.astro';

const locale = getLocale(Astro);
const t = useT(locale);

const visible = confirmed(socials);

const ctaFor = (name: string) =>
  name === 'Discord' ? t.community.discordCta
  : name === 'X'     ? t.community.xCta
  : `Follow on ${name}`;
---
{visible.length > 0 && (
  <section
    class="community mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-20"
    aria-label="Join the community"
  >
    <div class="max-w-2xl">
      <p class="text-[0.65rem] uppercase tracking-[0.25em] text-[var(--color-accent-2)]">
        {t.community.eyebrow}
      </p>
      <h2 class="font-display text-3xl sm:text-4xl mt-1 tracking-wide">
        {t.community.headline}
      </h2>
      <p class="mt-3 text-[var(--color-text-dim)] leading-relaxed">
        {t.community.body}
      </p>
    </div>

    <ul class="mt-8 grid gap-4 sm:grid-cols-2">
      {visible.map((s) => (
        <li>
          <a
            href={s.url}
            target="_blank"
            rel="me noopener"
            class:list={[
              'community-card group relative flex items-start gap-4 bg-[var(--color-surface)]',
              'border border-[var(--color-border)] rounded-md p-5 sm:p-6',
              s.name === 'Discord' ? 'community-card--discord' : '',
              s.name === 'X'       ? 'community-card--x'       : '',
            ]}
            aria-label={`Najdorf Esports on ${s.name}${s.handle ? ` (${s.handle})` : ''}`}
          >
            <span
              class="community-card__chip inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
              aria-hidden="true"
            >
              <PlatformIcon platform={s.name} size={s.name === 'Discord' ? 22 : 20} />
            </span>

            <div class="min-w-0 flex-1">
              <div class="flex items-baseline justify-between gap-3">
                <p class="font-display text-xl tracking-wide">{s.name}</p>
                {s.handle && (
                  <span class="text-[0.7rem] uppercase tracking-wider text-[var(--color-text-dim)] truncate">
                    {s.handle}
                  </span>
                )}
              </div>
              {s.blurb && (
                <p class="mt-2 text-sm text-[var(--color-text-dim)] leading-relaxed">
                  {s.blurb}
                </p>
              )}
              <p class="link-arrow has-glyph mt-3 text-xs uppercase tracking-wider text-[var(--color-accent-2)] group-hover:text-[var(--color-accent)]">
                <span>{ctaFor(s.name)}</span>
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .community-card {
    transition:
      border-color 0.2s ease-out,
      transform 0.22s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .community-card:hover {
    border-color: var(--color-accent-2);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px -16px color-mix(in oklab, var(--color-accent-2) 60%, transparent);
  }
  .community-card__chip {
    transition:
      background-color 0.22s ease-out,
      color 0.22s ease-out,
      transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .community-card:hover .community-card__chip {
    transform: scale(1.06);
  }

  /* Default chip, keep brand-neutral so the card reads as part of the
     org's palette. On hover the chip lifts into the platform colour as
     a small recognition cue. Platform brand colors live in tokens.css. */
  .community-card--discord .community-card__chip {
    background-color: color-mix(in oklab, var(--color-discord) 14%, transparent);
    color: var(--color-discord-fg);
  }
  .community-card--discord:hover .community-card__chip {
    background-color: var(--color-discord);
    color: #fff;
  }

  .community-card--x .community-card__chip {
    background-color: color-mix(in oklab, var(--color-text) 10%, transparent);
    color: var(--color-text);
  }
  .community-card--x:hover .community-card__chip {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .community-card,
    .community-card__chip {
      transition: none;
    }
    .community-card:hover,
    .community-card:hover .community-card__chip {
      transform: none;
    }
  }
</style>
