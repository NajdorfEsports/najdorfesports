---
/**
 * Home-page highlights strip. The latest match highlight renders as a centered
 * click-to-load player sized to its own shape; any older ones fill the grid
 * below. Hides itself entirely when there are no (non-draft) highlights, so the
 * feature is invisible until content exists.
 *
 * Highlights are authored once (English title) and shown on all locales; the
 * surrounding chrome is localized. Titles are short match labels (proper
 * nouns), so they are not triple-authored like news articles.
 */
import { getCollection } from 'astro:content';
import HighlightPlayer from '../highlight/HighlightPlayer.astro';
import { getLocale, useT } from '../../i18n';
import { formatDate } from '../../i18n/format';

const locale = getLocale(Astro);
const t = useT(locale);

const all = (await getCollection('highlights', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);

// The latest highlight is the hero: a centered player sized to its own shape,
// so the frame hugs the clip instead of letterboxing it (a 9:16 Short sits in
// a compact vertical column, a 16:9 clip goes wide). Older highlights fill the
// grid below. CSS aspect-ratio wants the spaced form ("9 / 16"); the stored
// value is compact ("9/16").
const featured = all[0];
const shorts = all.slice(1, 5);
const cssAspect = (a: string) => (a === '16/9' ? '16 / 9' : '9 / 16');
// Portrait heroes sit in a narrow column; landscape ones go wide.
const featuredMaxW = (a: string) => (a === '16/9' ? 'max-w-3xl' : 'max-w-xs');
---
{(featured || shorts.length > 0) && (
  <section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-16" aria-label="Match highlights">
    <div class="flex items-end justify-between mb-5">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-2)]">
          {t.highlights.eyebrow}
        </p>
        <h2 class="font-display text-3xl sm:text-4xl mt-1 tracking-wide">
          {t.highlights.heading}
        </h2>
      </div>
    </div>

    {featured && (
      <figure class:list={['mx-auto w-full', featuredMaxW(featured.data.aspect)]}>
        <HighlightPlayer
          videoId={featured.data.videoId}
          title={featured.data.title}
          poster={featured.data.poster}
          aspect={cssAspect(featured.data.aspect)}
        />
        <figcaption class="mt-3 text-xs text-[var(--color-text-dim)] text-center">
          {formatDate(featured.data.date, locale, { month: 'short', day: 'numeric', year: 'numeric' })}
          {featured.data.opponent ? ` · ${t.match.vs(featured.data.opponent)}` : ''}
        </figcaption>
      </figure>
    )}

    {shorts.length > 0 && (
      <ul class:list={['grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5', featured ? 'mt-8' : '']} role="list">
        {shorts.map((h) => (
          <li>
            <HighlightPlayer videoId={h.data.videoId} title={h.data.title} poster={h.data.poster} aspect={cssAspect(h.data.aspect)} />
            <p class="mt-2 text-xs text-[var(--color-text-dim)]">
              {formatDate(h.data.date, locale, { month: 'short', day: 'numeric' })}
              {h.data.opponent ? ` · ${t.match.vs(h.data.opponent)}` : ''}
            </p>
          </li>
        ))}
      </ul>
    )}
  </section>
)}
