---
/**
 * Home-page highlights strip. Match highlights render as a left-aligned row of
 * vertical click-to-load cards (YouTube Playables style): each card is a fixed
 * width and they flow side by side, wrapping to the next line. A single
 * highlight simply sits at the left. Hides itself entirely when there are no
 * (non-draft) highlights, so the feature is invisible until content exists.
 *
 * Highlights are authored once (English title) and shown on all locales; the
 * surrounding chrome is localized. Titles are short match labels (proper
 * nouns), so they are not triple-authored like news articles.
 */
import { getCollection } from 'astro:content';
import HighlightPlayer from '../highlight/HighlightPlayer.astro';
import { getLocale, useT } from '../../i18n';
import { formatDate } from '../../i18n/format';

const locale = getLocale(Astro);
const t = useT(locale);

const all = (await getCollection('highlights', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);

// CSS aspect-ratio wants the spaced form ("9 / 16"); the stored value is the
// compact "9/16". Vertical Shorts default to 9:16; a 16:9 clip passes through.
const cssAspect = (a: string) => (a === '16/9' ? '16 / 9' : '9 / 16');
---

{
  all.length > 0 && (
    <section
      class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-16"
      aria-label="Match highlights"
    >
      <div class="flex items-end justify-between mb-5">
        <div>
          <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-2)]">
            {t.highlights.eyebrow}
          </p>
          <h2 class="font-display text-3xl sm:text-4xl mt-1 tracking-wide">
            {t.highlights.heading}
          </h2>
        </div>
      </div>

      {/* Fixed-width vertical cards, left-aligned. auto-fill (not auto-fit) keeps
        a lone card at its natural ~20rem width instead of stretching it across
        the row; extra cards flow side by side and wrap. */}
      <ul
        class="grid gap-5 sm:gap-6 [grid-template-columns:repeat(auto-fill,minmax(0,20rem))]"
        role="list"
      >
        {all.map((h) => (
          <li>
            <HighlightPlayer
              videoId={h.data.videoId}
              title={h.data.title}
              poster={h.data.poster}
              aspect={cssAspect(h.data.aspect)}
            />
            <p class="mt-3 text-xs text-[var(--color-text-dim)]">
              {formatDate(h.data.date, locale, { month: 'short', day: 'numeric', year: 'numeric' })}
              {h.data.opponent ? ` · ${t.match.vs(h.data.opponent)}` : ''}
            </p>
          </li>
        ))}
      </ul>
    </section>
  )
}
