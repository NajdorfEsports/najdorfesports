---
/**
 * Home-page highlights band, built for 9:16 Shorts as the primary medium:
 * a horizontal scroll-snap rail of fixed-width vertical frames. With only
 * one published Short, the rail is completed by a "more film on the way"
 * card naming the next real fixture and a ghost card linking the YouTube
 * channel, so a lone vertical frame reads as a curated rail instead of a
 * broken grid. Both companions retire naturally as real Shorts land. A
 * 16:9 clip, when one exists, takes a featured slot above the rail.
 * Hides itself entirely when there are no (non-draft) highlights.
 *
 * Highlights are authored once (English title) and shown on all locales;
 * the surrounding chrome is localized. Titles are short match labels
 * (proper nouns), so they are not triple-authored like news articles.
 */
import { getCollection } from 'astro:content';
import HighlightPlayer from '../highlight/HighlightPlayer.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import { channels } from '../../data/channels';
import { getLocale, useT } from '../../i18n';
import { formatDate } from '../../i18n/format';

interface Props {
  /** Scoresheet index from the home spine (aria-hidden, never translated). */
  move?: string | null;
  /** Next fixture, for the placeholder card's copy. */
  nextFilm?: { opponent: string; date: string };
}
const { move, nextFilm } = Astro.props;

const locale = getLocale(Astro);
const t = useT(locale);

const all = (await getCollection('highlights', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);

// A widescreen clip, when one exists, gets the featured slot above the rail.
const featured = all.find((h) => h.data.aspect === '16/9') ?? null;
const rail = featured ? all.filter((h) => h.id !== featured.id) : all;

// Companion cards keep a thin rail honest; they drop off once three or
// more real Shorts exist. The subscribe ghost only renders with a real
// channel URL ('TODO' entries stay dormant, same convention as SocialRow).
const showPlaceholder = rail.length > 0 && rail.length < 3;
const youtube = channels.find((c) => c.platform === 'youtube' && c.url !== 'TODO');

// CSS aspect-ratio wants the spaced form ("9 / 16"); the stored value is the
// compact "9/16". Vertical Shorts default to 9:16; a 16:9 clip passes through.
const cssAspect = (a: string) => (a === '16/9' ? '16 / 9' : '9 / 16');

const metaLine = (h: (typeof all)[number]) =>
  [
    formatDate(h.data.date, locale, { month: 'short', day: 'numeric', year: 'numeric' }),
    h.data.opponent ? t.match.vs(h.data.opponent) : null,
  ]
    .filter(Boolean)
    .join(' · ');
---

{
  all.length > 0 && (
    <section class="section" aria-label="Match highlights">
      <SectionHeader move={move} eyebrow={t.highlights.eyebrow} heading={t.highlights.heading} />

      {featured && (
        <div class="mt-6 grid gap-6 sm:grid-cols-[auto_1fr] sm:items-end">
          <div class="w-full max-w-2xl">
            <HighlightPlayer
              videoId={featured.data.videoId}
              title={featured.data.title}
              poster={featured.data.poster}
              aspect={cssAspect(featured.data.aspect)}
            />
          </div>
          <div class="min-w-0 sm:pb-2">
            <p class="text-xs uppercase tracking-wider text-(--color-text-dim)">
              {metaLine(featured)}
            </p>
            <h3 class="font-display text-2xl sm:text-3xl mt-2 tracking-wide">
              {featured.data.title}
            </h3>
          </div>
        </div>
      )}

      {rail.length > 0 && (
        <ul class="mt-6 flex gap-4 sm:gap-5 overflow-x-auto snap-x snap-mandatory pb-2" role="list">
          {rail.map((h) => (
            <li class="snap-start shrink-0 w-60 sm:w-64">
              <HighlightPlayer
                videoId={h.data.videoId}
                title={h.data.title}
                poster={h.data.poster}
                aspect={cssAspect(h.data.aspect)}
              />
              <p class="mt-3 text-xs text-(--color-text-dim)">{metaLine(h)}</p>
            </li>
          ))}

          {showPlaceholder && (
            <li class="snap-start shrink-0 w-60 sm:w-64" aria-hidden="false">
              <div class="film-card relative isolate overflow-hidden rounded-md border border-(--color-border) bg-(--color-surface)">
                <div class="texture-diag" aria-hidden="true" />
                <div class="relative z-10 flex flex-col justify-end h-full p-4">
                  <p class="font-display text-lg tracking-wide leading-snug">
                    {t.highlights.placeholderTitle}
                  </p>
                  <p class="mt-2 text-xs text-(--color-text-dim) leading-relaxed">
                    {nextFilm
                      ? t.highlights.placeholderBody(nextFilm.opponent, nextFilm.date)
                      : t.highlights.placeholderBodyEmpty}
                  </p>
                </div>
              </div>
            </li>
          )}

          {showPlaceholder && youtube && (
            <li class="snap-start shrink-0 w-60 sm:w-64">
              <a
                href={youtube.url}
                target="_blank"
                rel="noopener"
                class="film-card film-card--ghost relative isolate overflow-hidden rounded-md border border-dashed border-(--color-border) flex"
              >
                <div class="relative z-10 flex flex-col items-center justify-center gap-3 w-full p-4 text-center">
                  <span
                    class="inline-flex items-center justify-center w-12 h-12 rounded-full"
                    style="background-color: color-mix(in oklab, var(--color-youtube) 15%, transparent); color: var(--color-youtube-fg);"
                    aria-hidden="true"
                  >
                    <svg width="16" height="16" viewBox="0 0 14 14" fill="currentColor">
                      <polygon points="3,2 12,7 3,12" />
                    </svg>
                  </span>
                  <span class="font-display text-base tracking-wide">
                    {t.highlights.subscribeCta}
                  </span>
                  <span class="text-[0.65rem] uppercase tracking-wider text-(--color-text-dim)">
                    {youtube.handle}
                  </span>
                </div>
              </a>
            </li>
          )}
        </ul>
      )}
    </section>
  )
}

<style>
  /* Companion cards share the rail's 9:16 frame so the row scans as one
     filmstrip. */
  .film-card {
    aspect-ratio: 9 / 16;
    display: flex;
  }
  .film-card--ghost {
    transition: border-color 0.2s ease-out;
  }
  .film-card--ghost:hover {
    border-color: var(--color-accent-2);
  }
</style>
