---
/**
 * Home-page roster preview: one slim vertical slat per player, the
 * signature hero art running through the sitewide ink treatment with the
 * handle set along the bottom. Staff are excluded here (they live on
 * /roster/). Players without hero art get the board texture instead, so
 * a brand-new signing never renders broken.
 */
import { Image } from 'astro:assets';
import CountryFlag from '../player/CountryFlag.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import { playerSlug, hasDetailPage, type RosterEntry, type Role } from '../../data/site';
import { firstHeroImage } from '../../lib/heroes';
import { getLocale, pathFor, useT } from '../../i18n';
import { displayCountry } from '../../i18n/format';

interface Props {
  players: ReadonlyArray<RosterEntry>;
  /** Hide entries with these roles from the preview (e.g., coaches/managers). */
  excludeRoles?: ReadonlyArray<string>;
  href?: string;
  /** Scoresheet index from the home spine (aria-hidden, never translated). */
  move?: string | null;
}
const locale = getLocale(Astro);
const t = useT(locale);

const {
  players,
  excludeRoles = ['Coach', 'Manager'],
  href = pathFor(locale, '/roster/'),
  move,
} = Astro.props;

const visible = players.filter((p) => !excludeRoles.includes(p.role));
const countries = new Set(visible.map((p) => p.country).filter(Boolean));
const coaches = players.filter((p) => p.role === 'Coach');

const slats = visible.map((p) => ({
  player: p,
  art: firstHeroImage(p.signatureHeroes),
  href: hasDetailPage(p)
    ? pathFor(locale, `/roster/${playerSlug(p.handle)}/`)
    : (p.liquipediaUrl ?? href),
  external: !hasDetailPage(p) && !!p.liquipediaUrl,
}));
---

<section class="section" aria-label="Roster preview">
  <SectionHeader
    move={move}
    eyebrow={t.rosterStrip.activeRoster}
    heading={t.rosterStrip.countLine(visible.length, countries.size, coaches.length)}
  >
    <a
      href={href}
      class="link-arrow has-glyph text-sm uppercase tracking-wider text-(--color-accent-2) hover:text-(--color-accent)"
    >
      <span>{t.rosterStrip.fullRoster}</span>
    </a>
  </SectionHeader>

  <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3" role="list">
    {
      slats.map(({ player: p, art, href: slatHref, external }, i) => (
        <li class="roster-slat" style={`--stagger:${i};`}>
          <a
            href={slatHref}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener' : undefined}
            class="roster-slat__link group relative isolate block overflow-hidden rounded-md border border-(--color-border) bg-(--color-surface)"
            aria-label={t.player.avatarAlt(p.handle, t.roles[p.role as Role] ?? p.role)}
          >
            {art ? (
              <>
                <Image
                  src={art}
                  alt=""
                  widths={[320]}
                  sizes="320px"
                  loading="lazy"
                  decoding="async"
                  class="roster-slat__art ink-img"
                  aria-hidden="true"
                />
                <div class="ink-wash" aria-hidden="true" />
              </>
            ) : (
              <div class="texture-board" aria-hidden="true" />
            )}
            <div class="roster-slat__scrim" aria-hidden="true" />
            <div class="relative z-10 flex flex-col justify-end h-full p-3">
              <p class="font-display text-lg tracking-wide leading-none">{p.handle}</p>
              <p class="mt-1.5 flex items-center gap-1.5 text-[0.6rem] uppercase tracking-wider text-(--color-text-dim)">
                {t.roles[p.role as Role] ?? p.role}
                {p.countryCode && (
                  <>
                    <span aria-hidden="true">·</span>
                    <CountryFlag
                      code={p.countryCode}
                      name={displayCountry(p.countryCode, p.country, locale)}
                      size="sm"
                    />
                  </>
                )}
              </p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .roster-slat {
    animation: slat-fade 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--stagger, 0) * 60ms);
  }
  .roster-slat__link {
    aspect-ratio: 3 / 4.5;
    transition:
      border-color 0.2s ease-out,
      transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .roster-slat__link:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
  }
  .roster-slat__link :global(.roster-slat__art) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 12%;
    transform-origin: 50% 25%;
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .roster-slat__link:hover :global(.roster-slat__art) {
    transform: scale(1.05);
  }
  .roster-slat__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 11, 15, 0.92) 0%,
      rgba(11, 11, 15, 0.35) 45%,
      rgba(11, 11, 15, 0.12) 100%
    );
    pointer-events: none;
  }

  @keyframes slat-fade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .roster-slat {
      animation: none;
    }
    .roster-slat__link,
    .roster-slat__link :global(.roster-slat__art) {
      transition: none;
    }
    .roster-slat__link:hover {
      transform: none;
    }
    .roster-slat__link:hover :global(.roster-slat__art) {
      transform: none;
    }
  }
</style>
