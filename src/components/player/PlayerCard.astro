---
import { Image } from 'astro:assets';
import CountryFlag from './CountryFlag.astro';
import Badge from '../ui/Badge.astro';
import { playerSlug, hasDetailPage, type RosterEntry, type Role } from '../../data/site';
import { roleAccent, ageFromBirth } from '../../lib/player';
import { resolveHeroIcons, heroFocusX } from '../../lib/heroes';
import { getLocale, pathFor, useT } from '../../i18n';
import { displayCountry } from '../../i18n/format';

interface Props {
  player: RosterEntry;
  /** 0-based index used to stagger the fade-in animation. */
  index?: number;
  /** Eager-load the backdrop art (the page's first, above-fold card). */
  eager?: boolean;
}
const { player, index = 0, eager = false } = Astro.props;

const locale = getLocale(Astro);
const t = useT(locale);
const countryName = displayCountry(player.countryCode, player.country, locale);

const isDnp = player.status === 'dnp';
const isInactive = player.status === 'inactive';
const hasCountry = !!(player.country && player.country !== 'TBD');

const accent = roleAccent(player.role);

// The handle now links to the internal player detail page when one exists
// (players + coach). Managers have no detail page, so their handle falls back
// to the outbound Liquipedia profile (kept, per the brief). The full Liquipedia
// link lives on the detail page for everyone who has one.
const detailHref = hasDetailPage(player)
  ? pathFor(locale, `/roster/${playerSlug(player.handle)}/`)
  : null;
const handleHref = detailHref ?? player.liquipediaUrl ?? null;
const handleExternal = !detailHref && !!player.liquipediaUrl;

const age = ageFromBirth(player.birthDate);

const allRoles = [player.role, ...(player.altRoles ?? [])].filter((r, i, a) => a.indexOf(r) === i);

// Signature heroes that have an icon, capped at 4 for the card backdrop.
const backdropHeroes = resolveHeroIcons(player.signatureHeroes, 4);
const hasBackdrop = backdropHeroes.length > 0;

// When Liquipedia lists only one or two signature heroes, the crisp strips
// leave the transparent-PNG voids showing card-dark, so the figure floats in a
// gap. A soft, enlarged, blurred echo of the same art sits behind to flood
// those voids with the character's own colors, turning a 1-2 hero card into a
// full-bleed poster like the coach/manager cards. Three or four heroes already
// fill the card edge to edge, so the aura is skipped (it would be hidden).
const sparseBackdrop = hasBackdrop && backdropHeroes.length < 3;

// Each strip's flex-grow tracks its render's canvas aspect ratio, but the
// raw ratio is compressed into a tight band so widths stay close to even: a
// tall render (Sigma, Ana) no longer collapses to a sliver beside a wide one
// (Hazard), which was the main thing that made a mixed trio look lopsided.
// The band is deliberately narrow (0.82-1.18); the per-hero focal point below
// does the work of framing, so the width only needs to keep every strip a
// fair share of the card.
const stripGrow = (image: { width: number; height: number }) =>
  Math.min(1.18, Math.max(0.82, 0.55 + (image.width / image.height) * 0.5)).toFixed(3);
---

<article
  class:list={[
    'player-card relative bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-5 flex flex-col shadow-[var(--shadow-card)] isolate overflow-hidden',
    isDnp || isInactive ? 'player-card--muted' : '',
    hasBackdrop ? 'player-card--has-backdrop' : '',
  ]}
  style={`--accent:${accent};--stagger:${index};`}
>
  {
    hasBackdrop && (
      <>
        <div class="player-card__backdrop" aria-hidden="true">
          {sparseBackdrop && (
            <div class="player-card__aura" aria-hidden="true">
              {backdropHeroes.map((h) => (
                <span
                  class="player-card__aura-cell"
                  style={`--strip-grow:${stripGrow(h.image)};--focus-x:${heroFocusX(h.name)}%`}
                >
                  <Image
                    src={h.image}
                    alt=""
                    widths={[320]}
                    sizes="320px"
                    loading={eager ? 'eager' : 'lazy'}
                    decoding="async"
                    class="player-card__aura-img ink-img"
                  />
                </span>
              ))}
            </div>
          )}
          {backdropHeroes.map((h) => (
            <span
              class="player-card__hero"
              data-hero={h.name}
              style={`--strip-grow:${stripGrow(h.image)};--focus-x:${heroFocusX(h.name)}%`}
            >
              {/* One 320w candidate: strips render ~130-190px wide under
                  the ink wash and scrim, and keeping each under ~20KB
                  stops the lazy-load lookahead from starving the display
                  font on slow connections. */}
              <Image
                src={h.image}
                alt=""
                widths={[320]}
                sizes="320px"
                loading={eager ? 'eager' : 'lazy'}
                decoding="async"
                class="player-card__hero-img ink-img"
              />
            </span>
          ))}
          <div class="ink-wash" aria-hidden="true" />
        </div>
        <div class="player-card__overlay" aria-hidden="true" />
      </>
    )
  }

  <span class="player-card__rail" aria-hidden="true"></span>

  {
    (isDnp || isInactive) && (
      <span class="absolute top-3 right-3 max-w-[60%] text-right z-10">
        <Badge tone="neutral">
          {player.statusNote ?? (isDnp ? t.player.dnp : t.player.inactive)}
        </Badge>
      </span>
    )
  }

  {
    /* Nameplate anchored bottom-left, scoresheet style: the art carries the
      top of the card, the type carries the bottom. */
  }
  <div
    class="player-card__content relative z-10 mt-auto flex flex-col items-start text-left w-full"
  >
    {
      hasBackdrop && (
        <p class="text-[0.6rem] uppercase tracking-[0.2em] text-[var(--color-text-dim)] mb-2">
          {backdropHeroes.map((h) => h.name).join(' · ')}
        </p>
      )
    }

    <h3 class="font-display text-3xl sm:text-4xl tracking-wide leading-none">
      {
        handleHref ? (
          <a
            href={handleHref}
            target={handleExternal ? '_blank' : undefined}
            rel={handleExternal ? 'noopener' : undefined}
            class="player-card__handle hover:underline underline-offset-4 decoration-[var(--accent)]"
          >
            {player.handle}
          </a>
        ) : (
          player.handle
        )
      }
    </h3>

    {
      (player.realName || age !== null) && (
        <p class="text-sm text-[var(--color-text-dim)] mt-2">
          {player.realName}
          {player.realName && age !== null && ' · '}
          {age !== null && <span class="tabular-nums">{age}</span>}
        </p>
      )
    }

    <div class="mt-3 flex items-center gap-2 text-xs uppercase tracking-wider flex-wrap">
      {
        allRoles.map((r) => {
          const a = roleAccent(r);
          return (
            <span
              class="px-2 py-0.5 rounded-sm border font-semibold bg-[var(--color-bg)]/60 backdrop-blur-sm"
              style={`color: ${a}; border-color: ${a};`}
            >
              {t.roles[r as Role] ?? r}
            </span>
          );
        })
      }
      {
        hasCountry && (
          <span class="flex items-center gap-1.5 text-[var(--color-text-dim)] ml-1">
            <CountryFlag code={player.countryCode} name={countryName} size="md" />
            <span class="text-[0.7rem]">{countryName}</span>
          </span>
        )
      }
    </div>

    {
      (player.twitter || player.twitch) && (
        <div class="mt-3 flex items-center gap-3 text-[0.7rem] uppercase tracking-wider text-[var(--color-text-dim)]">
          {player.twitter && (
            <a
              href={player.twitter}
              target="_blank"
              rel="noopener"
              class="hover:text-[var(--color-accent-2)] transition-colors"
            >
              {t.player.twitter}
            </a>
          )}
          {player.twitch && (
            <a
              href={player.twitch}
              target="_blank"
              rel="noopener"
              class="hover:text-[var(--color-accent-2)] transition-colors"
            >
              {t.player.twitch}
            </a>
          )}
        </div>
      )
    }
  </div>
</article>

<style>
  .player-card {
    transition:
      transform 0.2s ease-out,
      border-color 0.2s ease-out,
      box-shadow 0.2s ease-out;
    animation: card-rise 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--stagger, 0) * 70ms);
    aspect-ratio: 4 / 4.4;
    min-height: 320px;
  }

  .player-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow:
      0 1px 0 0 var(--accent),
      0 12px 40px -12px color-mix(in oklab, var(--accent) 50%, transparent);
  }

  /* Hero backdrop, vertical strips with soft edge masks for a poster blend.
     Lives behind the content via z-index. */
  .player-card__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    border-radius: inherit;
    overflow: hidden;
    pointer-events: none;
  }

  /* Sparse-backdrop aura: a blurred, enlarged echo of the same art that floods
     the transparent voids a 1-2 hero card would otherwise leave card-dark. Sits
     at the very back of the backdrop (negative z) so the crisp strips and the
     ink wash both paint over it. */
  .player-card__aura {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: flex;
    overflow: hidden;
    border-radius: inherit;
  }
  .player-card__aura-cell {
    /* Mirror each strip's grow so the wash for a hero sits behind that hero.
       No clip here: the blurred copies bleed across the seam so two heroes
       read as one continuous field rather than two halves. */
    flex: var(--strip-grow, 1) 1 0%;
  }
  .player-card__aura :global(.player-card__aura-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--focus-x, 50%) 28%;
    display: block;
    /* Blow the art up and blur it into an ambient field; the ink filter is
       repeated here because this more-specific rule overrides .ink-img. */
    transform: scale(1.7);
    filter: grayscale(1) contrast(1.06) brightness(0.84) blur(16px);
    opacity: 0.6;
  }

  .player-card__hero {
    /* Grow factor set inline per strip from the render's aspect ratio; see
       stripGrow in the frontmatter. Basis 0 so widths split purely by grow. */
    flex: var(--strip-grow, 1) 1 0%;
    overflow: hidden;
    /* Feather the inner edges so adjacent heroes blend rather than collide */
    mask-image: linear-gradient(90deg, transparent 0%, black 12%, black 88%, transparent 100%);
  }
  .player-card__hero :global(.player-card__hero-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* X is the render's focal point (default 50%, overridden per hero so a
       face never lands on the crop edge); Y stays high so heads, which sit
       near the top of every render, survive any vertical crop. */
    object-position: var(--focus-x, 50%) 20%;
    display: block;
    /* Cinematic zoom on hover. Each strip gets a slightly different
       transform-origin via :nth-child below so the heroes don't all
       move in lockstep, it reads like a poster gently breathing. */
    transform-origin: 50% 30%;
    transition: transform 800ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .player-card__hero:nth-child(1) :global(.player-card__hero-img) {
    transform-origin: 30% 35%;
  }
  .player-card__hero:nth-child(2) :global(.player-card__hero-img) {
    transform-origin: 50% 30%;
  }
  .player-card__hero:nth-child(3) :global(.player-card__hero-img) {
    transform-origin: 70% 35%;
  }
  .player-card__hero:nth-child(4) :global(.player-card__hero-img) {
    transform-origin: 85% 30%;
  }

  .player-card:hover .player-card__hero :global(.player-card__hero-img) {
    transform: scale(1.05);
  }
  .player-card:hover .player-card__hero:nth-child(2) :global(.player-card__hero-img) {
    /* Middle hero leads with a touch of vertical drift */
    transform: scale(1.05) translateY(-2px);
  }
  /* Outer edges of the strip stay solid against the card edge */
  .player-card__hero:first-child {
    mask-image: linear-gradient(90deg, black 0%, black 88%, transparent 100%);
  }
  .player-card__hero:last-child {
    mask-image: linear-gradient(90deg, transparent 0%, black 12%, black 100%);
  }
  .player-card__hero:only-child {
    mask-image: none;
  }

  /* Bottom-weighted scrim: the art breathes up top, the nameplate sits on
     solid ground below. */
  .player-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background: linear-gradient(
      to top,
      rgba(11, 11, 15, 0.96) 0%,
      rgba(11, 11, 15, 0.72) 32%,
      rgba(11, 11, 15, 0.28) 62%,
      rgba(11, 11, 15, 0.08) 100%
    );
    pointer-events: none;
    /* Smooth dimming via opacity rather than the un-animatable bg property */
    transition: opacity 450ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* On hover the overlay dims slightly so the hero backdrop "breathes" */
  .player-card--has-backdrop:hover .player-card__overlay {
    opacity: 0.82;
  }

  .player-card__rail {
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease-out;
    z-index: 2;
  }

  .player-card:hover .player-card__rail {
    opacity: 1;
  }

  .player-card__handle {
    color: inherit;
    transition:
      color 0.15s ease-out,
      text-shadow 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .player-card:hover .player-card__handle {
    color: var(--accent);
    /* Soft accent halo, picks up the role color set on the card */
    text-shadow:
      0 0 18px color-mix(in oklab, var(--accent) 55%, transparent),
      0 0 36px color-mix(in oklab, var(--accent) 25%, transparent);
  }

  .player-card--muted {
    opacity: 0.7;
  }

  .player-card--muted:hover {
    opacity: 1;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .player-card,
    .player-card__hero :global(.player-card__hero-img),
    .player-card__overlay,
    .player-card__handle {
      animation: none !important;
      transition: border-color 0.2s ease-out !important;
    }
    .player-card:hover {
      transform: none;
    }
    .player-card:hover .player-card__hero :global(.player-card__hero-img),
    .player-card:hover .player-card__hero:nth-child(2) :global(.player-card__hero-img) {
      transform: none !important;
    }
    .player-card:hover .player-card__handle {
      text-shadow: none;
    }
    .player-card--has-backdrop:hover .player-card__overlay {
      opacity: 1;
    }
  }
</style>
