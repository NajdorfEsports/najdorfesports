---
import PlayerAvatar from './PlayerAvatar.astro';
import CountryFlag from './CountryFlag.astro';
import Badge from '../ui/Badge.astro';
import heroIcons from '../../data/heroes.json';
import type { RosterEntry, Role } from '../../data/site';
import { DEFAULT_LOCALE, useT, type Locale } from '../../i18n';
import { displayCountry } from '../../i18n/format';

interface Props {
  player: RosterEntry;
  /** 0-based index used to stagger the fade-in animation. */
  index?: number;
}
const { player, index = 0 } = Astro.props;

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);
const countryName = displayCountry(player.countryCode, player.country, locale);

const isDnp = player.status === 'dnp';
const isInactive = player.status === 'inactive';
const hasCountry = !!(player.country && player.country !== 'TBD');

const roleAccent: Record<string, string> = {
  Tank: 'var(--color-accent)',
  DPS: 'var(--color-accent-2)',
  Support: '#4ADE80',
  Flex: '#A78BFA',
  Coach: '#60A5FA',
  Manager: '#60A5FA',
};
const accent = roleAccent[player.role] ?? 'var(--color-accent-2)';
const cardLink = player.liquipediaUrl;

function ageFromBirth(iso?: string): number | null {
  if (!iso) return null;
  const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return null;
  const [, y, mo, d] = m;
  const now = new Date();
  let age = now.getUTCFullYear() - Number(y);
  const todayMD = now.getUTCMonth() * 100 + now.getUTCDate();
  const birthMD = (Number(mo) - 1) * 100 + Number(d);
  if (todayMD < birthMD) age -= 1;
  return age >= 0 && age < 100 ? age : null;
}
const age = ageFromBirth(player.birthDate);

const allRoles = [player.role, ...(player.altRoles ?? [])].filter(
  (r, i, a) => a.indexOf(r) === i,
);

// Resolve signature heroes to icon URLs. Heroes we don't have an icon for
// are silently dropped — no fallback letter cluttering the backdrop.
const heroMap = heroIcons as Record<string, string>;
const backdropHeroes = (player.signatureHeroes ?? [])
  .map((name) => ({ name, iconUrl: heroMap[name] }))
  .filter((h): h is { name: string; iconUrl: string } => !!h.iconUrl)
  .slice(0, 4);
const hasBackdrop = backdropHeroes.length > 0;
---
<article
  class:list={[
    'player-card relative bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-5 flex flex-col items-center text-center shadow-[var(--shadow-card)] isolate overflow-hidden',
    isDnp || isInactive ? 'player-card--muted' : '',
    hasBackdrop ? 'player-card--has-backdrop' : '',
  ]}
  style={`--accent:${accent};--stagger:${index};`}
>
  {hasBackdrop && (
    <>
      <div class="player-card__backdrop" aria-hidden="true">
        {backdropHeroes.map((h) => (
          <span
            class="player-card__hero"
            style={`background-image: url('${h.iconUrl}');`}
            data-hero={h.name}
          ></span>
        ))}
      </div>
      <div class="player-card__overlay" aria-hidden="true"></div>
    </>
  )}

  <span class="player-card__rail" aria-hidden="true"></span>

  {(isDnp || isInactive) && (
    <span class="absolute top-3 right-3 max-w-[60%] text-right z-10">
      <Badge tone="neutral">{player.statusNote ?? (isDnp ? t.player.dnp : t.player.inactive)}</Badge>
    </span>
  )}

  <div class="player-card__content relative z-10 flex flex-col items-center w-full">
    <PlayerAvatar handle={player.handle} size={96} />

    <h3 class="font-display text-2xl sm:text-3xl mt-4 tracking-wide leading-none">
      {cardLink ? (
        <a
          href={cardLink}
          target="_blank"
          rel="noopener"
          class="player-card__handle hover:underline underline-offset-4 decoration-[var(--accent)]"
        >
          {player.handle}
        </a>
      ) : (
        player.handle
      )}
    </h3>

    {(player.realName || age !== null) && (
      <p class="text-sm text-[var(--color-text-dim)] mt-1.5">
        {player.realName}
        {player.realName && age !== null && ' · '}
        {age !== null && (
          <span class="tabular-nums">{age}</span>
        )}
      </p>
    )}

    <div class="mt-3 flex items-center gap-2 text-xs uppercase tracking-wider flex-wrap justify-center">
      {allRoles.map((r) => {
        const a = roleAccent[r] ?? accent;
        return (
          <span
            class="px-2 py-0.5 rounded-sm border font-semibold bg-[var(--color-bg)]/60 backdrop-blur-sm"
            style={`color: ${a}; border-color: ${a};`}
          >
            {t.roles[r as Role] ?? r}
          </span>
        );
      })}
      {hasCountry && (
        <span class="flex items-center gap-1.5 text-[var(--color-text-dim)] ml-1">
          <CountryFlag code={player.countryCode} name={countryName} size="md" />
          <span class="text-[0.7rem]">{countryName}</span>
        </span>
      )}
    </div>

    {hasBackdrop && (
      <p class="mt-3 text-[0.6rem] uppercase tracking-[0.2em] text-[var(--color-text-dim)]">
        {backdropHeroes.map((h) => h.name).join(' · ')}
      </p>
    )}

    {(player.twitter || player.twitch) && (
      <div class="mt-3 flex items-center gap-3 text-[0.7rem] uppercase tracking-wider text-[var(--color-text-dim)]">
        {player.twitter && (
          <a
            href={player.twitter}
            target="_blank"
            rel="noopener"
            class="hover:text-[var(--color-accent-2)] transition-colors"
          >
            {t.player.twitter}
          </a>
        )}
        {player.twitch && (
          <a
            href={player.twitch}
            target="_blank"
            rel="noopener"
            class="hover:text-[var(--color-accent-2)] transition-colors"
          >
            {t.player.twitch}
          </a>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .player-card {
    transition: transform 0.2s ease-out, border-color 0.2s ease-out, box-shadow 0.2s ease-out;
    animation: card-rise 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--stagger, 0) * 70ms);
    min-height: 320px;
  }

  .player-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow:
      0 1px 0 0 var(--accent),
      0 12px 40px -12px color-mix(in oklab, var(--accent) 50%, transparent);
  }

  /* Hero backdrop — vertical strips with soft edge masks for a poster blend.
     Lives behind the content via z-index. */
  .player-card__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    border-radius: inherit;
    overflow: hidden;
    pointer-events: none;
  }

  .player-card__hero {
    flex: 1;
    background-size: cover;
    background-position: 50% 18%;
    background-repeat: no-repeat;
    /* Feather the inner edges so adjacent heroes blend rather than collide */
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
    /* Cinematic zoom on hover. Each strip gets a slightly different
       transform-origin via :nth-child below so the heroes don't all
       move in lockstep — it reads like a poster gently breathing. */
    transform-origin: 50% 30%;
    transition: transform 800ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .player-card__hero:nth-child(1) { transform-origin: 30% 35%; }
  .player-card__hero:nth-child(2) { transform-origin: 50% 30%; }
  .player-card__hero:nth-child(3) { transform-origin: 70% 35%; }
  .player-card__hero:nth-child(4) { transform-origin: 85% 30%; }

  .player-card:hover .player-card__hero {
    transform: scale(1.08);
  }
  .player-card:hover .player-card__hero:nth-child(2) {
    /* Middle hero leads with a hair more zoom + a touch of vertical drift */
    transform: scale(1.1) translateY(-2px);
  }
  /* Outer edges of the strip stay solid against the card edge */
  .player-card__hero:first-child {
    mask-image: linear-gradient(90deg, black 0%, black 88%, transparent 100%);
  }
  .player-card__hero:last-child {
    mask-image: linear-gradient(90deg, transparent 0%, black 12%, black 100%);
  }
  .player-card__hero:only-child {
    mask-image: none;
  }

  /* Dark gradient overlay: lighter at top so faces show, darker at bottom for text */
  .player-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background:
      radial-gradient(
        ellipse 80% 50% at 50% 28%,
        rgba(11, 11, 15, 0.35) 0%,
        rgba(11, 11, 15, 0.78) 60%,
        rgba(11, 11, 15, 0.95) 100%
      );
    pointer-events: none;
    /* Smooth dimming via opacity rather than the un-animatable bg property */
    transition: opacity 450ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* On hover the overlay dims slightly so the hero backdrop "breathes" */
  .player-card--has-backdrop:hover .player-card__overlay {
    opacity: 0.82;
  }

  /* Diagonal shine sweep — one-shot streak from upper-left to lower-right
     when the cursor enters. Inspired by Apple product card hovers. */
  .player-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.06) 48%,
      rgba(255, 255, 255, 0.12) 50%,
      rgba(255, 255, 255, 0.06) 52%,
      transparent 70%
    );
    pointer-events: none;
    opacity: 0;
    transform: translateX(-110%);
    transition: transform 0s linear, opacity 0s linear;
  }
  .player-card:hover::before {
    opacity: 1;
    transform: translateX(110%);
    transition:
      transform 1.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s ease-out;
  }

  .player-card__rail {
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease-out;
    z-index: 2;
  }

  .player-card:hover .player-card__rail {
    opacity: 1;
  }

  .player-card__handle {
    color: inherit;
    transition:
      color 0.15s ease-out,
      text-shadow 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .player-card:hover .player-card__handle {
    color: var(--accent);
    /* Soft accent halo — picks up the role color set on the card */
    text-shadow:
      0 0 18px color-mix(in oklab, var(--accent) 55%, transparent),
      0 0 36px color-mix(in oklab, var(--accent) 25%, transparent);
  }

  .player-card--muted {
    opacity: 0.7;
  }

  .player-card--muted:hover {
    opacity: 1;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .player-card,
    .player-card__hero,
    .player-card__overlay,
    .player-card__handle,
    .player-card::before {
      animation: none !important;
      transition: border-color 0.2s ease-out !important;
    }
    .player-card:hover {
      transform: none;
    }
    .player-card:hover .player-card__hero,
    .player-card:hover .player-card__hero:nth-child(2) {
      transform: none;
    }
    .player-card:hover::before {
      opacity: 0;
      transform: translateX(-110%);
    }
    .player-card:hover .player-card__handle {
      text-shadow: none;
    }
    .player-card--has-backdrop:hover .player-card__overlay {
      opacity: 1;
    }
  }
</style>
