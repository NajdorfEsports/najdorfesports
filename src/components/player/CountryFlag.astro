---
/**
 * Country flag, rendered from self-hosted SVG art (src/assets/flags,
 * vendored from MIT-licensed lipis/flag-icons). Emoji flags are only the
 * fallback for codes without a local SVG: Windows has no color flag emoji
 * and renders the regional-indicator pair as bare letters ("CN", "TW"),
 * which is exactly the bug this component exists to avoid.
 */
import type { ImageMetadata } from 'astro';

interface Props {
  /** ISO 3166-1 alpha-2 country code. Case-insensitive. */
  code?: string;
  /** Country name as fallback label and for aria-label. */
  name?: string;
  size?: 'sm' | 'md' | 'lg';
  showCode?: boolean;
}

const { code, name, size = 'md', showCode = false } = Astro.props;

const codeUpper = code?.toUpperCase();
const isValid = codeUpper && /^[A-Z]{2}$/.test(codeUpper);

// Lowercase-code -> bundled SVG. Fail-soft: an unknown code simply has no
// entry here and drops to the emoji fallback below.
const flagSvgs = import.meta.glob<{ default: ImageMetadata }>('../../assets/flags/*.svg', {
  eager: true,
});
const svg = isValid
  ? (flagSvgs[`../../assets/flags/${codeUpper.toLowerCase()}.svg`]?.default ?? null)
  : null;

// Convert two-letter ISO code to a flag emoji via regional indicator symbols.
// 'A' (0x41) maps to 🇦 (0x1F1E6); the offset is constant for the whole alphabet.
const flag = isValid
  ? codeUpper
      .split('')
      .map((c) => String.fromCodePoint(0x1f1e6 + c.charCodeAt(0) - 0x41))
      .join('')
  : null;

// 4:3 art; heights track the former emoji sizes (sm/md/lg = 16/20/24px type).
const px = { sm: { w: 16, h: 12 }, md: { w: 20, h: 15 }, lg: { w: 24, h: 18 } }[size];
const sizeClass = { sm: 'text-base', md: 'text-xl', lg: 'text-2xl' }[size];
const ariaLabel = name ? `${name} flag` : codeUpper ? `${codeUpper} flag` : 'Unknown country';
---

{
  svg ? (
    <span class="inline-flex items-center gap-1.5 leading-none">
      <img
        src={svg.src}
        alt={ariaLabel}
        width={px.w}
        height={px.h}
        loading="lazy"
        decoding="async"
        class="rounded-[2px] ring-1 ring-white/15 select-none"
      />
      {showCode && codeUpper && (
        <span class="text-[0.7em] font-semibold tracking-wider text-[var(--color-text-dim)]">
          {codeUpper}
        </span>
      )}
    </span>
  ) : flag ? (
    <span
      class={`inline-flex items-center gap-1.5 leading-none ${sizeClass}`}
      role="img"
      aria-label={ariaLabel}
    >
      <span class="select-none">{flag}</span>
      {showCode && codeUpper && (
        <span class="text-[0.7em] font-semibold tracking-wider text-[var(--color-text-dim)]">
          {codeUpper}
        </span>
      )}
    </span>
  ) : name || codeUpper ? (
    <span class="text-xs uppercase tracking-wider text-[var(--color-text-dim)]">
      {name ?? codeUpper}
    </span>
  ) : null
}
