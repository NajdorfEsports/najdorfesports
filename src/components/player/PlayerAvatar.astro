---
import { hasPortrait, portraitPath } from '../../data/roster-portraits';
import { firstHeroIcon } from '../../lib/heroes';

interface Props {
  handle: string;
  /**
   * Signature heroes for this person (1-3), the same list that drives the
   * roster-card backdrop. When no real headshot exists, the first hero with
   * a known icon becomes the avatar so every person reads as a portrait
   * rather than a flat monogram. Heroes without an icon are skipped.
   */
  heroes?: ReadonlyArray<string>;
  /** Pixel size for the 1x render. Component emits a 2x srcset variant. */
  size?: number;
  /**
   * Accessible name for the avatar image. Callers pass a descriptive string
   * derived from roster data (e.g. "Skel3d1rge, Tank, signature hero Zarya").
   * Defaults to the bare handle. Used as the <img> alt / role="img" aria-label.
   */
  label?: string;
}

const { handle, heroes = [], size = 96, label } = Astro.props;
const alt = label ?? handle;

const px = size;

// Fallback chain: real headshot -> first signature hero with an icon ->
// monogram. The hero art is the single source of truth shared with the card
// backdrop, so an avatar and its card always show the same character.
const heroIconUrl = firstHeroIcon(heroes);

function hashHue(s: string) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return Math.abs(h) % 360;
}

const hue = hashHue(handle);
const initials = handle
  .replace(/[^A-Za-z0-9 ]/g, '')
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]!.toUpperCase())
  .join('');

const gradient = `linear-gradient(135deg, hsl(${hue} 50% 22%) 0%, hsl(${(hue + 40) % 360} 60% 12%) 100%)`;

const showPortrait = hasPortrait(handle);
const src = portraitPath(handle);
---
{showPortrait ? (
  <img
    src={src}
    srcset={`${src} 2x`}
    alt={alt}
    width={px}
    height={px}
    loading="lazy"
    decoding="async"
    class="rounded-full object-cover border border-[var(--color-border)]"
    style={`width:${px}px;height:${px}px;`}
  />
) : heroIconUrl ? (
  /*
   * Hero portrait fallback. The signature character is cropped into the
   * circle with the face pushed toward the top (background-position) so the
   * head, not the chest, lands in frame. A faint inner ring + bottom vignette
   * keep it cohesive with the monogram chips on the same card.
   */
  <div
    role="img"
    aria-label={alt}
    class="player-avatar-hero relative border border-[var(--color-border)] overflow-hidden"
    style={`width:${px}px;height:${px}px;background-image:url('${heroIconUrl}');border-radius:9999px;`}
  ></div>
) : (
  /*
   * Monogram fallback. A faint outlined bishop SVG sits behind the
   * letters so the avatar reads as branded rather than a flat color
   * chip. Bishop opacity is intentionally low (0.16 stroke vs the page's
   * 0.05–0.08 hero-bg drift), visible at size=96 on roster cards, still
   * present but subliminal at size=48 on the home roster strip.
   */
  <div
    role="img"
    aria-label={alt}
    class="player-avatar-mono relative isolate flex items-center justify-center font-display border border-[var(--color-border)] select-none overflow-hidden"
    style={`width:${px}px;height:${px}px;background:${gradient};border-radius:9999px;color:#E9ECF1;letter-spacing:0.02em;`}
  >
    <svg
      class="player-avatar-mono__bishop"
      viewBox="0 0 64 96"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      <path fill-rule="evenodd" d="M32 6 C 40 18, 44 30, 44 38 C 44 46, 38 50, 32 50 C 26 50, 20 46, 20 38 C 20 30, 24 18, 32 6 Z"/>
      <path d="M28 12 L 38 22 L 36 24 L 26 14 Z"/>
      <rect x="26" y="46" width="12" height="12"/>
      <rect x="20" y="56" width="24" height="6" rx="1"/>
      <path d="M22 60 L 42 60 L 46 78 L 18 78 Z"/>
      <path d="M14 78 L 50 78 L 52 88 L 12 88 Z"/>
      <ellipse cx="32" cy="90" rx="22" ry="3.5"/>
    </svg>
    <span class="player-avatar-mono__initials relative" style={`font-size:${px * 0.42}px;`}>{initials || '·'}</span>
  </div>
)}

<style>
  .player-avatar-hero {
    background-size: cover;
    /* Face sits near the top of these full/upper-body hero renders, so bias
       the crop upward, same framing intent as the card backdrop (50% 18%). */
    background-position: 50% 14%;
    background-repeat: no-repeat;
    /* Bottom vignette + soft inner ring so the portrait reads as a branded
       chip rather than a bare photo cutout. */
    box-shadow:
      inset 0 -10px 18px -8px rgba(11, 11, 15, 0.7),
      inset 0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  .player-avatar-mono__bishop {
    position: absolute;
    inset: 12% 22%;
    width: auto;
    height: 76%;
    color: var(--color-text);
    opacity: 0.16;
    pointer-events: none;
  }
  .player-avatar-mono__initials {
    z-index: 1;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.55);
  }
</style>
