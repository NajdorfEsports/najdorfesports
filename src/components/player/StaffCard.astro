---
/**
 * Staff row card for coaches and managers on /roster/. Deliberately NOT
 * the player-card treatment: a manager wearing Kiriko art reads wrong, so
 * staff get a quiet horizontal card on board texture with the monogram
 * avatar. The coach keeps the link to a detail page (hasDetailPage covers
 * that); managers link out to their socials only.
 */
import PlayerAvatar from './PlayerAvatar.astro';
import CountryFlag from './CountryFlag.astro';
import { playerSlug, hasDetailPage, type RosterEntry, type Role } from '../../data/site';
import { roleAccent, ageFromBirth } from '../../lib/player';
import { getLocale, pathFor, useT } from '../../i18n';
import { displayCountry } from '../../i18n/format';

interface Props {
  person: RosterEntry;
}
const { person } = Astro.props;

const locale = getLocale(Astro);
const t = useT(locale);

const countryName = displayCountry(person.countryCode, person.country, locale);
const hasCountry = !!(person.country && person.country !== 'TBD');
const accent = roleAccent(person.role);
const age = ageFromBirth(person.birthDate);

const detailHref = hasDetailPage(person)
  ? pathFor(locale, `/roster/${playerSlug(person.handle)}/`)
  : null;
---

<article
  class="staff-card relative isolate overflow-hidden bg-(--color-surface) border border-(--color-border) rounded-md p-5 flex items-center gap-4"
  style={`--accent:${accent};`}
>
  <div class="texture-board opacity-60" aria-hidden="true"></div>

  <div class="relative z-10 shrink-0">
    <PlayerAvatar
      handle={person.handle}
      size={64}
      label={t.player.avatarAlt(person.handle, t.roles[person.role as Role] ?? person.role)}
    />
  </div>

  <div class="relative z-10 min-w-0 flex-1">
    <h3 class="font-display text-2xl tracking-wide leading-none">
      {
        detailHref ? (
          <a href={detailHref} class="hover:underline underline-offset-4 decoration-(--accent)">
            {person.handle}
          </a>
        ) : (
          person.handle
        )
      }
    </h3>
    {
      (person.realName || age !== null) && (
        <p class="text-sm text-(--color-text-dim) mt-1">
          {person.realName}
          {person.realName && age !== null && ' · '}
          {age !== null && <span class="tabular-nums">{age}</span>}
        </p>
      )
    }
    <div class="mt-2 flex items-center gap-2 text-xs uppercase tracking-wider flex-wrap">
      <span
        class="px-2 py-0.5 rounded-sm border font-semibold"
        style={`color:${accent};border-color:${accent};`}
      >
        {t.roles[person.role as Role] ?? person.role}
      </span>
      {
        hasCountry && (
          <span class="flex items-center gap-1.5 text-(--color-text-dim)">
            <CountryFlag code={person.countryCode} name={countryName} size="sm" />
            <span class="text-[0.7rem]">{countryName}</span>
          </span>
        )
      }
    </div>
  </div>

  {
    (person.twitter || person.twitch) && (
      <div class="relative z-10 shrink-0 flex flex-col items-end gap-1.5 text-[0.7rem] uppercase tracking-wider text-(--color-text-dim)">
        {person.twitter && (
          <a
            href={person.twitter}
            target="_blank"
            rel="noopener"
            class="hover:text-(--color-accent-2) transition-colors"
          >
            {t.player.twitter}
          </a>
        )}
        {person.twitch && (
          <a
            href={person.twitch}
            target="_blank"
            rel="noopener"
            class="hover:text-(--color-accent-2) transition-colors"
          >
            {t.player.twitch}
          </a>
        )}
      </div>
    )
  }
</article>

<style>
  .staff-card {
    transition:
      border-color 0.2s ease-out,
      transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .staff-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .staff-card {
      transition: none;
    }
    .staff-card:hover {
      transform: none;
    }
  }
</style>
