---
import {
  SUPPORTED_LOCALES,
  LOCALE_LABEL,
  pathFor,
  unlocalizedPath,
  DEFAULT_LOCALE,
  type Locale,
} from '../../i18n';

const current = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const base = unlocalizedPath(Astro.url.pathname);

// Routes that have localized variants. Anything else (matches, news, privacy,
// terms, feed, 404) is English-only by spec — for those, the non-English
// links route to the locale home instead of re-prefixing a path that has no
// translated counterpart. Stops "I'm on /matches/, switch to zh-CN" from
// landing on a 404 at /zh-CN/matches/.
const LOCALIZED_ROUTES = new Set(['/', '/roster/', '/about/']);
const baseIsLocalized = LOCALIZED_ROUTES.has(base);

function hrefFor(locale: Locale): string {
  if (locale === DEFAULT_LOCALE) return pathFor(locale, base);
  return baseIsLocalized ? pathFor(locale, base) : pathFor(locale, '/');
}
---
<nav class="language-switcher" aria-label="Language">
  <ul class="flex items-center gap-3 text-[0.7rem] uppercase tracking-wider">
    {SUPPORTED_LOCALES.map((locale) => (
      <li>
        <a
          href={hrefFor(locale)}
          hreflang={locale}
          lang={locale}
          aria-current={locale === current ? 'true' : undefined}
          class:list={[
            'transition-colors hover:text-[var(--color-accent-2)]',
            locale === current
              ? 'text-[var(--color-accent-2)]'
              : 'text-[var(--color-text-dim)]',
          ]}
        >
          {LOCALE_LABEL[locale]}
        </a>
      </li>
    ))}
  </ul>
</nav>
