---
/**
 * Compact icon-chip row of the org's social channels. Used in the About
 * page "Follow along" block and in the SiteFooter brand column. Any
 * channel with url: 'TODO' is filtered out, the row hides itself when
 * nothing is confirmed yet.
 *
 * Two sizes via the `size` prop: `md` (32px chips, the default, fits
 * the About page) and `sm` (28px chips for the footer). Both render the
 * platform name as an sr-only label so assistive tech announces the
 * link target; sighted users get the platform glyph + a tooltip via
 * `title`.
 */
import { socials } from '../../data/site';

interface Props {
  size?: 'sm' | 'md';
}

const { size = 'md' } = Astro.props;
const visible = socials.filter((s) => s.url && s.url !== 'TODO');

const dims = size === 'sm'
  ? { box: 'w-8 h-8',  icon: 14 }
  : { box: 'w-10 h-10', icon: 16 };
---
{visible.length > 0 && (
  <ul class="flex items-center gap-2.5" role="list">
    {visible.map((s) => (
      <li>
        <a
          href={s.url}
          rel="me noopener"
          target="_blank"
          title={s.handle ? `${s.name} · ${s.handle}` : s.name}
          aria-label={`Najdorf Esports on ${s.name}`}
          class:list={[
            'social-chip group inline-flex items-center justify-center rounded-full',
            'border border-[var(--color-border)] bg-[var(--color-surface)]',
            'text-[var(--color-text-dim)] transition-colors',
            dims.box,
            s.name === 'Discord' ? 'social-chip--discord' : '',
            s.name === 'X'       ? 'social-chip--x'       : '',
          ]}
        >
          <span class="sr-only">{s.name}</span>
          {s.name === 'Discord' && (
            <svg width={dims.icon} height={dims.icon} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.74 19.74 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          )}
          {s.name === 'X' && (
            <svg width={dims.icon} height={dims.icon} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
)}

<style>
  .social-chip--discord:hover {
    border-color: #5865F2;
    color: #B8BFFF;
  }
  .social-chip--x:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }
</style>
