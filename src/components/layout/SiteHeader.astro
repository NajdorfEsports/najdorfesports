---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { DEFAULT_LOCALE, pathFor, useT, type Locale } from '../../i18n';

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const t = useT(locale);

const nav = [
  { href: pathFor(locale, '/'),         label: t.nav.home    },
  { href: pathFor(locale, '/roster/'),  label: t.nav.roster  },
  // Matches and News are English-only per spec — link goes to the un-prefixed path.
  { href: '/matches/',                  label: t.nav.matches },
  { href: '/news/',                     label: t.nav.news    },
  { href: pathFor(locale, '/about/'),   label: t.nav.about   },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const norm = href.replace(/\/$/, '') || '/';
  if (norm === '/') return pathname === '/' || pathname === `/${locale}`;
  return pathname === norm || pathname.startsWith(norm + '/');
};

const homeHref = pathFor(locale, '/');
---
<header class="border-b border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur sticky top-0 z-50">
  <div class="mx-auto max-w-[var(--max-content)] flex items-center justify-between px-4 sm:px-6 h-16">
    <a href={homeHref} class="wordmark-hover flex items-center gap-3" aria-label="Najdorf Esports home">
      {/*
        Full bishop + X-chess mark, sourced from the owner's artwork. The
        white-on-transparent variant (negated in generate-og.mjs) lets the
        dark site bg show through the chess board's "white" squares so the
        pattern reads as a real chess alternation without a solid bg.
        Sized to fill the header's 4rem row with a touch of breathing room.
      */}
      <span class="inline-block shrink-0" aria-hidden="true" transition:name="bishop-mark">
        <img
          src="/branding/bishop-logo-dark.png"
          alt=""
          width="658"
          height="750"
          class="block h-12 w-auto sm:h-14"
          loading="eager"
          decoding="async"
        />
      </span>
      <span class="font-display text-2xl sm:text-2xl tracking-wide" transition:name="wordmark-compact">
        <span class="text-[var(--color-accent)]">NAJDORF</span>
        <span class="text-[var(--color-text)]">ESPORTS</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <nav class="flex items-center gap-6" aria-label="Primary">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'link-slide text-sm font-medium tracking-wide uppercase transition-colors',
              isActive(item.href)
                ? 'text-[var(--color-accent-2)]'
                : 'text-[var(--color-text-dim)] hover:text-[var(--color-text)]',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <span class="h-5 w-px bg-[var(--color-border)]" aria-hidden="true"></span>
      <LanguageSwitcher />
    </div>

    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded border border-[var(--color-border)] text-[var(--color-text)]"
      aria-controls="mobile-nav"
      aria-expanded="false"
      data-mobile-toggle
    >
      <span class="sr-only">Toggle menu</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-nav"
    class="md:hidden hidden border-t border-[var(--color-border)] px-4 sm:px-6 py-3"
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-2">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-2 text-sm font-medium uppercase tracking-wide',
              isActive(item.href)
                ? 'text-[var(--color-accent-2)]'
                : 'text-[var(--color-text-dim)] hover:text-[var(--color-text)]',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-4 pt-4 border-t border-[var(--color-border)]">
      <LanguageSwitcher />
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const btn = document.querySelector('[data-mobile-toggle]');
    const panel = document.getElementById('mobile-nav');
    if (!btn || !panel) return;
    btn.addEventListener('click', () => {
      const open = panel.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
