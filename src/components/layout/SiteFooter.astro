---
import { site } from '../../data/site';
import SocialRow from './SocialRow.astro';
import { getLocale, pathFor, primaryNav, useT } from '../../i18n';

const locale = getLocale(Astro);
const t = useT(locale);

// Primary nav (top row of the footer). Shared with SiteHeader via primaryNav
// so the two never drift; every route is localized. Partners is appended here
// (footer only, not the header nav) per the audit placement decision. Press is
// intentionally NOT linked: it is dormant until the owner surfaces it.
const footerLinks = [
  ...primaryNav(locale, t),
  { href: pathFor(locale, '/partners/'), label: t.partners.eyebrow },
];

// Legal links demoted to the meta row, they don't need primary-nav weight.
const legalLinks = [
  { href: '/privacy/', label: 'Privacy' },
  { href: '/terms/', label: 'Terms' },
];

const year = new Date().getFullYear();

// The Liquipedia attribution must carry real links to the source and the
// CC BY-SA 3.0 license (compliance, same as /matches and /roster). The
// localized credit strings all contain these two locale-independent
// tokens; splitting around them adds the links without touching the
// strings themselves. Falls back to plain text if a future string drops
// a token.
const credit = t.footer.dataCredit;
const lpToken = 'Liquipedia';
const ccToken = 'CC BY-SA 3.0';
const lpIdx = credit.indexOf(lpToken);
const ccIdx = credit.indexOf(ccToken);
const creditParts =
  lpIdx !== -1 && ccIdx > lpIdx
    ? {
        before: credit.slice(0, lpIdx),
        between: credit.slice(lpIdx + lpToken.length, ccIdx),
        after: credit.slice(ccIdx + ccToken.length),
      }
    : null;
---

<footer class="border-t border-[var(--color-border)] mt-24">
  <div class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 py-7">
    {/* Row 1, brand + horizontal nav, single row on desktop, stacked on mobile. */}
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5">
      <div>
        {
          /* text-2xl, not xl: 24px is the WCAG large-text threshold, where
            the brand blue's 3.8:1 contrast passes AA (3:1). At 20px it
            would need 4.5:1 and fail. Matches the header treatment. */
        }
        <p class="font-display text-2xl tracking-wide">
          <span class="text-[var(--color-accent)]">NAJDORF</span>
          <span class="text-[var(--color-text)]">ESPORTS</span>
        </p>
        <p class="text-xs text-[var(--color-text-dim)] mt-1.5">
          {t.footer.foundedLine(site.yearFounded, site.region)}
          {' · '}
          <Fragment set:html={'<!--email_off-->'} />
          <a
            href={`mailto:${site.contactEmail}`}
            class="hover:text-[var(--color-accent-2)] transition-colors"
          >
            {site.contactEmail}
          </a>
          <Fragment set:html={'<!--/email_off-->'} />
        </p>
        <div class="mt-3">
          <SocialRow size="sm" />
        </div>
      </div>

      <nav aria-label="Footer">
        <ul
          class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-[var(--color-text-dim)]"
        >
          {
            footerLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="link-slide hover:text-[var(--color-text)] transition-colors"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    {
      /* Row 2, one wrapping legal line; everything that used to be three
        separate rows now sits inline with · separators. Smaller font + a
        thin top border keeps it visually subordinate. */
    }
    <div
      class="mt-5 pt-4 border-t border-[var(--color-border)]/60 flex flex-wrap items-center gap-x-3 gap-y-1 text-[0.7rem] text-[var(--color-text-dim)]"
    >
      <span>{t.footer.copyright(year, site.name)}</span>
      {
        legalLinks.map((l) => (
          <>
            <span aria-hidden="true" class="opacity-50">
              ·
            </span>
            <a href={l.href} class="hover:text-[var(--color-text)] transition-colors">
              {l.label}
            </a>
          </>
        ))
      }
      <span aria-hidden="true" class="opacity-50">·</span>
      <span class="opacity-90">{t.footer.trademark}</span>
      <span aria-hidden="true" class="opacity-50">·</span>
      <span class="opacity-90">
        {
          creditParts ? (
            <>
              {creditParts.before}
              <a
                href="https://liquipedia.net/overwatch/"
                target="_blank"
                rel="noopener"
                class="hover:text-[var(--color-text)] transition-colors underline decoration-[var(--color-border)] underline-offset-2"
              >
                {lpToken}
              </a>
              {creditParts.between}
              <a
                href="https://creativecommons.org/licenses/by-sa/3.0/"
                target="_blank"
                rel="noopener"
                class="hover:text-[var(--color-text)] transition-colors underline decoration-[var(--color-border)] underline-offset-2"
              >
                {ccToken}
              </a>
              {creditParts.after}
            </>
          ) : (
            t.footer.dataCredit
          )
        }
      </span>
    </div>
  </div>
</footer>
