---
import type { Product } from '../../data/products';

interface Props {
  product: Product;
}
const { product } = Astro.props;

const price = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: product.currency,
}).format(product.priceCents / 100);
---
<article class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md overflow-hidden">
  {product.image && (
    <img src={product.image} alt="" class="w-full aspect-square object-cover" loading="lazy" />
  )}
  <div class="p-4">
    <h3 class="font-display text-lg">{product.title}</h3>
    <p class="text-sm text-[var(--color-text-dim)] mt-1 line-clamp-2">{product.description}</p>
    <p class="font-display text-xl mt-3 text-[var(--color-accent-2)]">{price}</p>
  </div>
</article>
