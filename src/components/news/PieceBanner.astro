---
/**
 * The animated news-banner chess piece. Renders the approved single-path
 * outline for `piece` and draws it on once, the first time it scrolls into
 * view (see `src/scripts/piece-banner.ts`).
 *
 * Placement and size are owned by the parent banner (`.news-cover__piece`
 * in NewsCover.astro): this component only contributes the artwork, the
 * stroke styling, and the draw-on. The piece is a decorative backdrop, so
 * it is `aria-hidden` and outline-only (never inked solid).
 *
 * No-JS doctrine: the path renders FULLY DRAWN by default. Only when
 * scripting is enabled (gated on `@media (scripting: enabled)`) does it
 * start hidden, so a blocked or absent script can never strand the outline
 * invisible. Reduced motion freezes it to the completed outline.
 */
import { NEWS_PIECE_PATHS, type NewsPiece } from '../../lib/news-pieces';

interface Props {
  piece?: NewsPiece;
}

const { piece = 'pawn' } = Astro.props;
const d = NEWS_PIECE_PATHS[piece];
---

<svg
  class="piece-banner"
  data-piece-banner
  viewBox="0 0 64 96"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linejoin="round"
  stroke-linecap="round"
  aria-hidden="true"
>
  <path class="piece-banner__path" d={d}></path>
</svg>

<style>
  .piece-banner {
    display: block;
    width: auto;
    height: 100%;
  }

  /* Scripting enabled: start the outline hidden so the draw-on has somewhere
     to draw FROM. `--draw-len` is the path length the script measures with
     getTotalLength() and sets on the svg; until it lands, the 9999 fallback
     (larger than any piece's length) keeps the path fully retracted. With
     scripting OFF this whole block never applies, so the path stays fully
     drawn (no-JS safe). */
  @media (scripting: enabled) {
    .piece-banner__path {
      stroke-dasharray: var(--draw-len, 9999);
      stroke-dashoffset: var(--draw-len, 9999);
    }
    /* The draw-on loops: ~1.4s to stroke the piece in, a beat held complete,
       then it restarts. The whole cycle is 3s, so each piece redraws every
       three seconds. The script adds `is-drawing` only while the banner is in
       view, so off-screen banners don't animate. */
    .piece-banner.is-drawing .piece-banner__path {
      animation: piece-draw 3s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
  }

  @keyframes piece-draw {
    0% {
      stroke-dashoffset: var(--draw-len, 9999);
    }
    46% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  /* Reduced motion: show the completed outline immediately, no draw-on and no
     loop. The !important beats the inline custom property the script writes. */
  @media (prefers-reduced-motion: reduce) {
    .piece-banner__path {
      stroke-dasharray: none !important;
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  import { initPieceBanners } from '../../scripts/piece-banner';
  initPieceBanners();
</script>
