---
/**
 * Typographic news cover. Used in two variants:
 *   - `variant="hero"`, full-width article hero block on /news/<slug>/
 *   - `variant="card"`, compact thumb at the top of each card on /news/
 *
 * The "image" is rendered from the post metadata + a bishop motif rather
 * than from a static asset, so adding a new post doesn't require running
 * a generator script or committing a binary. Tone (primary / secondary /
 * split) drives the gradient + accent color; eyebrow is the small
 * uppercase chip above the title.
 */
import { formatDate } from '../../i18n/format';
import { DEFAULT_LOCALE, type Locale } from '../../i18n';
import BishopMark from '../ui/BishopMark.astro';

interface Props {
  title: string;
  date: Date;
  eyebrow?: string;
  tone?: 'primary' | 'secondary' | 'split';
  variant?: 'hero' | 'card';
  locale?: Locale;
}

const {
  title,
  date,
  eyebrow,
  tone = 'primary',
  variant = 'hero',
  locale = DEFAULT_LOCALE,
} = Astro.props;

const isHero = variant === 'hero';
// The cover title is a real heading, not decorative text. On an article page
// (hero) it is the page's single h1; in the index grid (card) each title is an
// h2 under that page's "From the team" h1. Tailwind preflight zeroes heading
// margins and inherits font-size, so the tag swap is visually identical.
const TitleTag = isHero ? 'h1' : 'h2';
const dateLabel = formatDate(date, locale, {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<div class:list={['news-cover', `news-cover--${tone}`, `news-cover--${variant}`]}>
  {
    /* Top accent rule, gives the cover a defined "card top" edge so the
      cover never reads as empty space, even when the bishop watermark
      sits low in the frame. */
  }
  <span class="news-cover__rule" aria-hidden="true"></span>

  {
    /* Bishop motif, larger + more opaque than the previous pass so the
      cover always carries clear visual weight, even at card sizes. */
  }
  <span class="news-cover__bishop" aria-hidden="true">
    <BishopMark strokeWidth={1.4} />
  </span>

  {
    /* X chess cross watermark in the lower-left, echoes the org mark so
      the cover reads as branded, not as an empty placeholder. */
  }
  <span class="news-cover__cross" aria-hidden="true">
    <svg viewBox="0 0 120 120" fill="currentColor">
      <polygon points="22,38 33,49 22,60 11,49"></polygon>
      <polygon points="22,60 33,71 22,82 11,71"></polygon>
      <polygon points="87,49 98,60 87,71 76,60"></polygon>
      <polygon points="109,49 120,60 109,71 98,60"></polygon>
      <polygon points="11,89 22,100 11,111 0,100"></polygon>
      <polygon points="33,89 44,100 33,111 22,100"></polygon>
      <polygon points="98,78 109,89 98,100 87,89"></polygon>
      <polygon points="98,100 109,111 98,122 87,111"></polygon>
      <polygon points="60,68 68,76 60,84 52,76"></polygon>
    </svg>
  </span>

  <div class="news-cover__content">
    <p class="news-cover__meta">
      {
        eyebrow && (
          <>
            <>
              <span class="news-cover__eyebrow">{eyebrow}</span>
              <span aria-hidden="true" class="news-cover__sep">
                ·
              </span>
            </>
          </>
        )
      }
      <span class="news-cover__date">{dateLabel}</span>
    </p>
    <TitleTag
      class={isHero
        ? 'news-cover__title news-cover__title--hero'
        : 'news-cover__title news-cover__title--card'}
    >
      {title}
    </TitleTag>
  </div>
</div>

<style>
  .news-cover {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    border-radius: 0.375rem;
    background: linear-gradient(
      165deg,
      color-mix(in oklab, var(--cover-accent, var(--color-accent)) 18%, var(--color-surface)) 0%,
      var(--color-surface) 60%,
      color-mix(in oklab, var(--color-bg) 60%, var(--color-surface)) 100%
    );
    border: 1px solid var(--color-border);
  }

  .news-cover--primary {
    --cover-accent: var(--color-accent);
  }
  .news-cover--secondary {
    --cover-accent: var(--color-accent-2);
  }
  .news-cover--split {
    --cover-accent: var(--color-accent);
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--color-accent) 22%, var(--color-surface)) 0%,
      var(--color-surface) 45%,
      color-mix(in oklab, var(--color-accent-2) 20%, var(--color-surface)) 100%
    );
  }

  /* Variant-specific sizing. Tightened from the previous 16:7 / 24:9 so
   * the middle band stops reading as empty space. */
  .news-cover--hero {
    aspect-ratio: 21 / 9;
    padding: 2.25rem 2rem;
  }
  .news-cover--card {
    aspect-ratio: 16 / 9;
    padding: 1.5rem 1.5rem;
  }

  /* Top accent rule. 2px tinted line anchors the cover. */
  .news-cover__rule {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--cover-accent, var(--color-accent)) 0%,
      color-mix(in oklab, var(--cover-accent, var(--color-accent)) 40%, transparent) 60%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* Bishop watermark. The svg must be sized off a parent with a RESOLVED
     height: a percentage height on the svg itself collapses to 0 because its
     wrapping span is auto-height, which is why the mark used to render at 0x0
     and the covers looked empty. So the height lives on the span (a real % of
     the card, which has a definite aspect-ratio height) and the svg fills it. */
  .news-cover__bishop {
    position: absolute;
    color: var(--cover-accent, var(--color-accent));
    pointer-events: none;
  }
  .news-cover__bishop :global(svg) {
    display: block;
    width: auto;
    height: 100%;
  }
  /* Hero (article page): large, faint linework anchored bottom-right. */
  .news-cover--hero .news-cover__bishop {
    height: 200%;
    right: -2%;
    bottom: -55%;
    opacity: 0.28;
  }
  /* Card (index thumbnail): tall and brighter, pulled into frame so the mark
     actually fills the body of the thumbnail instead of reading as empty. */
  .news-cover--card .news-cover__bishop {
    height: 150%;
    right: -3%;
    bottom: -26%;
    opacity: 0.4;
  }

  /* X chess cross watermark in the lower-left, echoes the org mark. */
  .news-cover__cross {
    position: absolute;
    left: 1.25rem;
    bottom: 1rem;
    width: 64px;
    color: var(--cover-accent, var(--color-accent));
    opacity: 0.28;
    pointer-events: none;
  }
  .news-cover__cross svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .news-cover--hero .news-cover__cross {
    width: 96px;
    left: 2rem;
    bottom: 1.75rem;
  }
  .news-cover--card .news-cover__cross {
    width: 52px;
  }

  /* Diagonal hatch, slightly more visible than before. */
  .news-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      135deg,
      transparent 0,
      transparent 14px,
      color-mix(in oklab, var(--cover-accent, var(--color-accent)) 14%, transparent) 14px,
      color-mix(in oklab, var(--cover-accent, var(--color-accent)) 14%, transparent) 15px
    );
    mix-blend-mode: overlay;
    opacity: 0.55;
  }

  .news-cover__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    max-width: 80%;
  }
  /* Card: center the eyebrow + title as a group so the title isn't stranded
     at the very bottom with a dead band above it. (Hero keeps space-between.) */
  .news-cover--card .news-cover__content {
    justify-content: center;
  }

  .news-cover__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  /* Keep the eyebrow and date each on one line; on a narrow card the date
     wraps to its own line instead of both phrases breaking mid-word. */
  .news-cover__eyebrow,
  .news-cover__date {
    white-space: nowrap;
  }
  .news-cover__eyebrow {
    color: var(--cover-accent, var(--color-accent));
    font-weight: 600;
  }
  .news-cover__sep {
    opacity: 0.55;
  }

  .news-cover__title {
    font-family: var(--font-display);
    color: var(--color-text);
    letter-spacing: -0.005em;
    line-height: 1.05;
    margin-top: 1.5rem;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
  }
  .news-cover__title--hero {
    font-size: clamp(1.75rem, 3.6vw, 3.25rem);
  }
  .news-cover__title--card {
    font-size: clamp(1.45rem, 2.3vw, 1.9rem);
    margin-top: 0.75rem;
  }
</style>
