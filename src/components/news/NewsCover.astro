---
/**
 * Typographic news cover. Used in two variants:
 *   - `variant="hero"`  — full-width article hero block on /news/<slug>/
 *   - `variant="card"`  — compact thumb at the top of each card on /news/
 *
 * The "image" is rendered from the post metadata + a bishop motif rather
 * than from a static asset, so adding a new post doesn't require running
 * a generator script or committing a binary. Tone (crimson / gold /
 * split) drives the gradient + accent color; eyebrow is the small
 * uppercase chip above the title.
 */
import { formatDate } from '../../i18n/format';
import { DEFAULT_LOCALE } from '../../i18n';

interface Props {
  title: string;
  date: Date;
  eyebrow?: string;
  tone?: 'crimson' | 'gold' | 'split';
  variant?: 'hero' | 'card';
}

const {
  title,
  date,
  eyebrow,
  tone = 'crimson',
  variant = 'hero',
} = Astro.props;

const isHero = variant === 'hero';
const dateLabel = formatDate(date, DEFAULT_LOCALE, {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---
<div class:list={['news-cover', `news-cover--${tone}`, `news-cover--${variant}`]} aria-hidden="false">
  <span class="news-cover__bishop" aria-hidden="true">
    <svg viewBox="0 0 64 96" fill="none" stroke="currentColor" stroke-width="1.4">
      <path fill-rule="evenodd" d="M32 6 C 40 18, 44 30, 44 38 C 44 46, 38 50, 32 50 C 26 50, 20 46, 20 38 C 20 30, 24 18, 32 6 Z"/>
      <path d="M28 12 L 38 22 L 36 24 L 26 14 Z"/>
      <rect x="26" y="46" width="12" height="12"/>
      <rect x="20" y="56" width="24" height="6" rx="1"/>
      <path d="M22 60 L 42 60 L 46 78 L 18 78 Z"/>
      <path d="M14 78 L 50 78 L 52 88 L 12 88 Z"/>
      <ellipse cx="32" cy="90" rx="22" ry="3.5"/>
    </svg>
  </span>

  <div class="news-cover__content">
    <p class="news-cover__meta">
      {eyebrow && <><span class="news-cover__eyebrow">{eyebrow}</span><span aria-hidden="true" class="news-cover__sep">·</span></>}
      <span class="news-cover__date">{dateLabel}</span>
    </p>
    <p class={isHero ? 'news-cover__title news-cover__title--hero' : 'news-cover__title news-cover__title--card'}>
      {title}
    </p>
  </div>
</div>

<style>
  .news-cover {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    border-radius: 0.375rem;
    background:
      linear-gradient(180deg,
        color-mix(in oklab, var(--cover-accent, var(--color-accent)) 12%, var(--color-surface)) 0%,
        var(--color-surface) 70%);
    border: 1px solid var(--color-border);
  }

  .news-cover--crimson { --cover-accent: var(--color-accent); }
  .news-cover--gold    { --cover-accent: var(--color-accent-2); }
  .news-cover--split {
    --cover-accent: var(--color-accent);
    background:
      linear-gradient(135deg,
        color-mix(in oklab, var(--color-accent) 18%, var(--color-surface)) 0%,
        var(--color-surface) 45%,
        color-mix(in oklab, var(--color-accent-2) 16%, var(--color-surface)) 100%);
  }

  /* Variant-specific sizing. Hero is the full article header band; card
   * is the smaller thumbnail above the news-index summary text. */
  .news-cover--hero {
    aspect-ratio: 24 / 9;
    padding: 2rem 1.75rem;
  }
  .news-cover--card {
    aspect-ratio: 16 / 7;
    padding: 1.25rem 1.25rem;
  }

  /* Bishop motif sits behind the content. Larger + brighter on hero;
   * subtler on card. Uses currentColor so the tone modifier above
   * tints the watermark. */
  .news-cover__bishop {
    position: absolute;
    right: -2.5%;
    bottom: -18%;
    color: var(--cover-accent, var(--color-accent));
    opacity: 0.18;
    pointer-events: none;
  }
  .news-cover__bishop svg {
    display: block;
    width: auto;
  }
  .news-cover--hero .news-cover__bishop svg { height: 200%; }
  .news-cover--card .news-cover__bishop svg { height: 180%; }
  .news-cover--card .news-cover__bishop {
    right: -10%;
    bottom: -30%;
  }

  /* Faint diagonal hatch — subliminal "draft / chess notation" feel.
   * Tinted by the cover accent so it carries the tone. */
  .news-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      135deg,
      transparent 0,
      transparent 14px,
      color-mix(in oklab, var(--cover-accent, var(--color-accent)) 10%, transparent) 14px,
      color-mix(in oklab, var(--cover-accent, var(--color-accent)) 10%, transparent) 15px
    );
    mix-blend-mode: overlay;
    opacity: 0.45;
  }

  .news-cover__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    max-width: 80%;
  }

  .news-cover__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .news-cover__eyebrow {
    color: var(--cover-accent, var(--color-accent));
    font-weight: 600;
  }
  .news-cover__sep { opacity: 0.55; }

  .news-cover__title {
    font-family: var(--font-display);
    color: var(--color-text);
    letter-spacing: -0.005em;
    line-height: 1.05;
    margin-top: 1.5rem;
  }
  .news-cover__title--hero {
    font-size: clamp(1.75rem, 3.6vw, 3.25rem);
  }
  .news-cover__title--card {
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    margin-top: 0.75rem;
  }
</style>
