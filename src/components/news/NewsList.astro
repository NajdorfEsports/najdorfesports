---
/**
 * News index body: the eyebrow + heading and the grid of article cards.
 * Shared by the English `/news/` page and the localized `/zh-TW/news/`,
 * `/zh-CN/news/` pages. Article hrefs are built with `pathFor(locale, ...)`
 * off each post's shared `slug`, so the same article resolves to the right
 * per-locale URL.
 */
import NewsCover from './NewsCover.astro';
import { pathFor, useT, type Locale } from '../../i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'news'>[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const t = useT(locale);
---
<section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 pt-12">
  <p class="text-sm uppercase tracking-wider text-[var(--color-accent-2)]">{t.news.eyebrow}</p>
  <h1 class="font-display text-4xl sm:text-5xl mt-2 tracking-wide">{t.news.heading}</h1>
</section>

<section class="mx-auto max-w-[var(--max-content)] px-4 sm:px-6 mt-10 grid gap-6 md:grid-cols-2">
  {posts.map((post) => (
    <a
      href={pathFor(locale, `/news/${post.data.slug}/`)}
      class="news-link group block surface-hover bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md overflow-hidden"
    >
      <NewsCover
        title={post.data.title}
        date={post.data.date}
        eyebrow={post.data.eyebrow}
        tone={post.data.tone}
        variant="card"
        locale={locale}
      />
      {post.data.description && (
        <p class="text-sm text-[var(--color-text-dim)] px-5 py-4 leading-relaxed">{post.data.description}</p>
      )}
    </a>
  ))}
</section>

<style>
  /* The cover is a self-contained block; on hover lift the whole card
   * and tint the cover's accent line. */
  .news-link {
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.2s ease-out, box-shadow 0.25s ease-out;
  }
  .news-link:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent-2);
    box-shadow: 0 14px 32px -18px color-mix(in oklab, var(--color-accent-2) 50%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .news-link,
    .news-link:hover {
      transition: none;
      transform: none;
    }
  }
</style>
