---
/**
 * News index body: the eyebrow + heading and the grid of article cards.
 * Shared by the English `/news/` page and the localized `/zh-TW/news/`,
 * `/zh-CN/news/` pages. Article hrefs are built with `pathFor(locale, ...)`
 * off each post's shared `slug`, so the same article resolves to the right
 * per-locale URL.
 */
import NewsCover from './NewsCover.astro';
import { pathFor, useT, type Locale } from '../../i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'news'>[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const t = useT(locale);

// The newest article leads the page at full width with the hero-variant
// cover; the rest grid below as cards. With a single post the featured
// block IS the page, no orphan grid.
const [featured, ...rest] = posts;
---

<section class="relative isolate overflow-hidden border-b border-(--color-border)">
  <div class="texture-board" aria-hidden="true"></div>
  <div class="mx-auto max-w-(--max-content) px-4 sm:px-6 pt-12 pb-10">
    <p class="eyebrow">{t.news.eyebrow}</p>
    <h1 class="font-display text-(length:--text-h1) mt-2 tracking-wide leading-none">
      {t.news.heading}
    </h1>
  </div>
</section>

{
  featured && (
    <section class="mx-auto max-w-(--max-content) px-4 sm:px-6 mt-10">
      <a href={pathFor(locale, `/news/${featured.data.slug}/`)} class="news-link group block">
        <NewsCover
          title={featured.data.title}
          date={featured.data.date}
          eyebrow={featured.data.eyebrow}
          tone={featured.data.tone}
          variant="hero"
          locale={locale}
        />
        {featured.data.description && (
          <p class="text-sm text-(--color-text-dim) leading-relaxed mt-4 max-w-prose">
            {featured.data.description}
          </p>
        )}
      </a>
    </section>
  )
}

{
  rest.length > 0 && (
    <section class="mx-auto max-w-(--max-content) px-4 sm:px-6 mt-10 grid gap-6 md:grid-cols-2">
      {rest.map((post) => (
        <a
          href={pathFor(locale, `/news/${post.data.slug}/`)}
          class="news-link group block bg-(--color-surface) border border-(--color-border) rounded-md overflow-hidden"
        >
          <NewsCover
            title={post.data.title}
            date={post.data.date}
            eyebrow={post.data.eyebrow}
            tone={post.data.tone}
            variant="card"
            locale={locale}
          />
          {post.data.description && (
            <p class="text-sm text-(--color-text-dim) px-5 py-4 leading-relaxed">
              {post.data.description}
            </p>
          )}
        </a>
      ))}
    </section>
  )
}

<style>
  /* The cover is a self-contained block; on hover lift the whole card
   * and tint the cover's accent line. */
  .news-link {
    transition:
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.2s ease-out,
      box-shadow 0.25s ease-out;
  }
  .news-link:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent-2);
    box-shadow: 0 14px 32px -18px color-mix(in oklab, var(--color-accent-2) 50%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .news-link,
    .news-link:hover {
      transition: none;
      transform: none;
    }
  }
</style>
