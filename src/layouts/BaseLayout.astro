---
import '../styles/global.css';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import { site } from '../data/site';
import { buildOrgJsonLd } from '../data/org-jsonld';
import { serializeJsonLd } from '../lib/jsonld';
import { SUPPORTED_LOCALES, getLocale, pathFor, unlocalizedPath, useT } from '../i18n';

interface Props {
  title: string;
  // When true, use `title` verbatim as the document <title>, with no
  // " · {site name}" suffix. The home page sets this so it can carry a full
  // SEO title ("Najdorf Esports | OWCS Pacific Overwatch Team").
  exactTitle?: boolean;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  canonical?: string;
  // Set false on pages that exist only in English (privacy, terms, shop,
  // 404). hreflang alternates are only valid when the page genuinely has
  // other-locale versions; pointing them at /zh-TW/... URLs that 404 is a
  // Search Console error. Localized pages (index, about, matches, roster,
  // news) leave this true so all three locales cross-link.
  localized?: boolean;
  // When true, the sitewide SportsOrganization block is replaced with the
  // enriched form that embeds the athlete roster + coach (Task E). Set on the
  // home and roster pages only; everywhere else gets the minimal identity node.
  enrichedOrg?: boolean;
  // When true, emit a noindex robots meta. Used for pages that exist but are
  // not ready to surface publicly yet (e.g. the dormant Press / Media Kit).
  noindex?: boolean;
}

const {
  title,
  exactTitle = false,
  description = site.description,
  ogImage = '/branding/og-default.png',
  jsonLd,
  canonical,
  localized = true,
  enrichedOrg = false,
  noindex = false,
} = Astro.props;

const fullTitle = exactTitle ? title : title === site.name ? title : `${title} · ${site.name}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.url).toString();

// Cache-bust the og:image URL so Discord / Slack / X / Facebook stop
// serving the prior branding from their CDN caches. Bump OG_VERSION
// whenever the OG card artwork changes, the URL change is what forces
// every unfurl service to re-scrape and re-fetch the image.
const OG_VERSION = '2026-06-17';
const ogImageUrlObj = new URL(ogImage, site.url);
ogImageUrlObj.searchParams.set('v', OG_VERSION);
const ogImageUrl = ogImageUrlObj.toString();

const locale = getLocale(Astro);
const t = useT(locale);
// BCP47 language for the <html lang> attribute. Script subtags (zh-Hant /
// zh-Hans) are more explicit than region subtags (zh-TW / zh-CN) for declaring
// the written language of the content, which is what a screen reader needs.
const HTML_LANG: Record<string, string> = {
  en: 'en',
  'zh-TW': 'zh-Hant',
  'zh-CN': 'zh-Hans',
};
const htmlLang = HTML_LANG[locale] ?? locale;
const basePath = unlocalizedPath(Astro.url.pathname);
const alternates = SUPPORTED_LOCALES.map((l) => ({
  locale: l,
  href: new URL(pathFor(l, basePath), site.url).toString(),
}));

// serializeJsonLd (escapes <>& so a Liquipedia-sourced "</script>" cannot break
// out of the JSON-LD block) is shared from ../lib/jsonld, imported above.

// SportsOrganization Schema.org block, emitted on every page so the org
// identity is discoverable wherever a crawler lands. Stable @id lets Person
// and SportsEvent blocks elsewhere reference it; `sameAs` and the optional
// embedded roster are both built from site data (see data/org-jsonld.ts).
const orgJsonLd = buildOrgJsonLd({ withRoster: enrichedOrg });

// BreadcrumbList for every non-root page, built from the (locale-stripped)
// URL hierarchy so Google can render breadcrumb rich results and stitch the
// nested pages under the org. Known section segments use the localized nav
// label; the final segment (article slug, player handle, legal page) falls
// back to this page's `title`. The home page has no crumb trail, so it is
// skipped. URLs are re-localized via pathFor so each locale links within
// itself.
const NAV_LABELS: Record<string, string> = {
  roster: t.nav.roster,
  matches: t.nav.matches,
  news: t.nav.news,
  coaching: t.nav.coaching,
  about: t.nav.about,
};
const crumbSegments = basePath.split('/').filter(Boolean);
let breadcrumbJsonLd: Record<string, unknown> | null = null;
if (crumbSegments.length > 0) {
  const crumbs = [{ name: t.nav.home, path: '/' }];
  let acc = '';
  crumbSegments.forEach((seg, i) => {
    acc += `/${seg}`;
    const isLast = i === crumbSegments.length - 1;
    crumbs.push({
      name: NAV_LABELS[seg] ?? (isLast ? title : seg),
      path: `${acc}/`,
    });
  });
  breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: crumbs.map((c, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      name: c.name,
      item: new URL(pathFor(locale, c.path), site.url).toString(),
    })),
  };
}
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />
    {
      localized && (
        <Fragment>
          {alternates.map((alt) => (
            <link rel="alternate" hreflang={alt.locale} href={alt.href} />
          ))}
          <link
            rel="alternate"
            hreflang="x-default"
            href={new URL(pathFor('en', basePath), site.url).toString()}
          />
        </Fragment>
      )
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} · News`}
      href="/feed.xml"
    />
    <meta name="theme-color" content="#0B0B0F" />

    {
      /*
      Fonts self-hosted (see global.css @font-face) instead of loaded from
      fonts.googleapis.com / fonts.gstatic.com, hot-linking those sends
      visitor IPs to Google and has been ruled a GDPR violation in some
      EU jurisdictions (Landgericht München, 2022). Preloading the two
      latin woff2 files keeps first-paint snappy.
    */
    }
    <link rel="preload" as="font" type="font/woff2" href="/fonts/anton-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />
    {
      /* The CJK faces are deliberately NOT preloaded. They ship with
         font-display: optional (a late ~140KB arrival must never repaint
         the page), so a preload cannot buy a first-view render on slow
         connections anyway; what it DID do was starve the small Latin
         faces above and push every zh page's font-swap LCP out by
         seconds. First zh view renders in the metrics-matched system
         face (PingFang / Microsoft families, declared in global.css);
         Noto serves from cache on every later view. The unicode-range on
         the faces keeps en pages at zero CJK bytes. */
    }

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@najdorfesports" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline type="application/ld+json" set:html={serializeJsonLd(orgJsonLd)} />
    {
      breadcrumbJsonLd && (
        <script is:inline type="application/ld+json" set:html={serializeJsonLd(breadcrumbJsonLd)} />
      )
    }
    {jsonLd && <script is:inline type="application/ld+json" set:html={serializeJsonLd(jsonLd)} />}

    {
      /*
      Navigation is plain cross-document. The crossfade and the header
      wordmark/bishop morphs come from NATIVE view transitions declared in
      global.css (`@view-transition`), zero JS: Chromium and Safari animate,
      Firefox does a normal full-page navigation. The old ClientRouter was
      removed with the CSP hardening pass; its SPA swap also silently broke
      inline scripts that were not re-executed after navigation.
    */
    }
  </head>
  <body>
    <a href="#main" class="skip-link">{t.skipLink}</a>
    <SiteHeader />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <SiteFooter />

    {
      /*
      Sitewide client behaviors, bundled by Astro into a fingerprinted
      /_astro/*.js module so the CSP needs no 'unsafe-inline' for scripts.
      Each module runs once per full page load. JSON-LD blocks above stay
      inline on purpose: they are non-executable data, not script-src
      subjects.
    */
    }
    <script>
      import '../scripts/reveal.ts';
      import '../scripts/count-up.ts';
      import '../scripts/nav-toggle.ts';
      import '../scripts/fonts.ts';
    </script>
  </body>
</html>
