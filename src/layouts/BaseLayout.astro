---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import { site, socials } from '../data/site';
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  pathFor,
  unlocalizedPath,
  type Locale,
} from '../i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  canonical?: string;
}

const {
  title,
  description = site.description,
  ogImage = '/branding/og-default.png',
  jsonLd,
  canonical,
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} · ${site.name}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.url).toString();

// Cache-bust the og:image URL so Discord / Slack / X / Facebook stop
// serving the prior branding from their CDN caches. Bump OG_VERSION
// whenever the OG card artwork changes — the URL change is what forces
// every unfurl service to re-scrape and re-fetch the image.
const OG_VERSION = '2026-05-25';
const ogImageUrlObj = new URL(ogImage, site.url);
ogImageUrlObj.searchParams.set('v', OG_VERSION);
const ogImageUrl = ogImageUrlObj.toString();

const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const basePath = unlocalizedPath(Astro.url.pathname);
const alternates = SUPPORTED_LOCALES.map((l) => ({
  locale: l,
  href: new URL(pathFor(l, basePath), site.url).toString(),
}));

// SportsOrganization Schema.org block — emitted on every page so the org
// identity is discoverable wherever a crawler lands. Stable @id allows
// Person and SportsEvent blocks elsewhere to reference it. `sameAs`
// pulls confirmed social URLs from src/data/site.ts so search engines
// link the org's identity to its profiles (Discord URLs are accepted
// here per Google's guidelines).
const socialSameAs = socials
  .filter((s) => s.url && s.url !== 'TODO')
  .map((s) => s.url);

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  '@id': `${site.url}/#org`,
  name: site.name,
  alternateName: site.shortName,
  url: `${site.url}/`,
  logo: `${site.url}/branding/og-default.png`,
  foundingDate: String(site.yearFounded),
  sport: 'Overwatch',
  areaServed: { '@type': 'Place', name: site.region },
  ...(socialSameAs.length > 0 ? { sameAs: socialSameAs } : {}),
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.locale} href={alt.href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(pathFor('en', basePath), site.url).toString()}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} · News`}
      href="/feed.xml"
    />
    <meta name="theme-color" content="#0B0B0F" />

    {/*
      Fonts self-hosted (see global.css @font-face) instead of loaded from
      fonts.googleapis.com / fonts.gstatic.com — hot-linking those sends
      visitor IPs to Google and has been ruled a GDPR violation in some
      EU jurisdictions (Landgericht München, 2022). Preloading the two
      latin woff2 files keeps first-paint snappy.
    */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/anton-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@najdorfesports" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(orgJsonLd)}
    />
    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}

    {/*
      Astro 5 client-side router. Replaces full-page navigations with a
      View-Transitions-API crossfade, persisting <header> / <footer> across
      page changes. ~3 KB inlined first-party JS, no cookies, no network
      calls — falls back cleanly to standard nav on browsers that don't
      support the View Transitions API. Reduced-motion preference is
      respected automatically. Per-element transition names live on the
      wordmark and the OWCS badge below so they morph between routes.
    */}
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <SiteHeader transition:persist />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <SiteFooter transition:persist />

    <script is:inline>
      // Reveal-on-scroll. Re-attaches on every ClientRouter navigation
      // because page body content is swapped underneath us. Wraps the
      // original IIFE in an astro:page-load handler.
      (() => {
        function init() {
          const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const els = document.querySelectorAll('.reveal:not(.is-visible)');
          if (els.length === 0) return;
          if (reduced || !('IntersectionObserver' in window)) {
            for (const el of els) el.classList.add('is-visible');
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.15, rootMargin: '0px 0px -60px 0px' },
          );
          for (const el of els) io.observe(el);
        }
        // Fire on initial load and on every ClientRouter navigation.
        init();
        document.addEventListener('astro:page-load', init);
      })();
    </script>

    <script is:inline>
      // Count-up on intersect. Opt in by adding `data-count-up` and
      // `data-target="<integer>"` to any element. The element's textContent
      // is overwritten with values from 0 → target across COUNT_DURATION_MS
      // using ease-out cubic. Reduced-motion + non-IO browsers + already-
      // animated elements all snap straight to the final value.
      (() => {
        const DURATION_MS = 700;
        const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

        function animate(el, target) {
          if (el.dataset.countDone === '1') return;
          el.dataset.countDone = '1';
          const start = performance.now();
          // Preserve any prefix/suffix the author wants kept after the digits
          // (e.g. "+", "%"). Read once at start so we don't re-parse mid-anim.
          const prefix = el.dataset.countPrefix || '';
          const suffix = el.dataset.countSuffix || '';

          function frame(now) {
            const t = Math.min(1, (now - start) / DURATION_MS);
            const v = Math.round(easeOutCubic(t) * target);
            el.textContent = prefix + v + suffix;
            if (t < 1) requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
        }

        function init() {
          const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const els = document.querySelectorAll('[data-count-up]:not([data-count-done="1"])');
          if (els.length === 0) return;

          if (reduced || !('IntersectionObserver' in window)) {
            // Snap straight to final value, no animation.
            for (const el of els) {
              const target = parseInt(el.getAttribute('data-target') || '0', 10);
              const prefix = el.dataset.countPrefix || '';
              const suffix = el.dataset.countSuffix || '';
              el.textContent = prefix + target + suffix;
              el.dataset.countDone = '1';
            }
            return;
          }

          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  const target = parseInt(e.target.getAttribute('data-target') || '0', 10);
                  animate(e.target, isNaN(target) ? 0 : target);
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.4 },
          );
          for (const el of els) io.observe(el);
        }

        init();
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>
