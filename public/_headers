# Cloudflare Pages, response headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Defaults for every response
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; frame-src https://player.twitch.tv; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  X-XSS-Protection: 0
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site

# Fingerprinted Astro assets (the hash in the filename means content is immutable)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts, content-addressed by version, safe to cache for a year.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Brand assets, change rarely, fine to cache a day
/branding/*
  Cache-Control: public, max-age=86400

# Hero portraits, fetched from Liquipedia on a weekly cadence and only
# replaced when the roster's signatureHeroes list changes. Safe to cache
# for a week so repeat visitors don't re-fetch each card backdrop.
/heroes/*
  Cache-Control: public, max-age=604800

# Player portraits, same cadence as hero icons; updated rarely.
/roster/*
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# RSS feed
/feed.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/rss+xml; charset=utf-8

# Sitemap and robots
/sitemap-*.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600
